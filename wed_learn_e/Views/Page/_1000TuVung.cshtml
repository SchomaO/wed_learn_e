@model List<wed_learn_e.Models.Vocabulary>
@{
    ViewBag.Title = "1000 Từ Vựng Thông Dụng";
    Layout = "~/Views/Shared/_Layoutcauhoi.cshtml";
}

<style>

    .page-title {
        text-align: center;
        font-size: 34px;
        font-weight: bold;
        color: #0d6efd;
        margin-top: 40px;
    }

    .page-desc {
        text-align: center;
        color: #555;
        margin-bottom: 30px;
    }

    .vocab-container {
        width: 90%;
        margin: auto;
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(220px,1fr));
        gap: 20px;
    }

    .vocab-card {
        background: white;
        border-radius: 12px;
        padding: 25px;
        text-align: center;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        transition: 0.3s;
    }

        .vocab-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }

    .word {
        font-size: 22px;
        font-weight: bold;
        color: #007bff;
    }

    .meaning {
        margin-top: 10px;
        color: #555;
    }

    .example {
        margin-top: 10px;
        font-size: 13px;
        color: #888;
        font-style: italic;
    }

    .control {
        text-align: center;
        margin: 40px;
    }

    .btn-vocab {
        background: #0d6efd;
        color: white;
        padding: 10px 18px;
        border-radius: 6px;
        text-decoration: none;
        margin: 5px;
    }

        .btn-vocab:hover {
            background: #0b5ed7;
        }

    /* mèo mascot */

    .cat-mascot {
        position: fixed;
        bottom: 20px;
        right: 20px;
        font-size: 55px;
        animation: floatCat 10s infinite ease-in-out;
    }

    .cat-text {
        position: absolute;
        bottom: 70px;
        right: 0;
        background: white;
        padding: 6px 10px;
        border-radius: 10px;
        font-size: 14px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    }

    @@keyframes floatCat {
        0% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-8px);
        }

        100% {
            transform: translateY(0);
        }
    }
</style>


<div class="page-title">
    1000 Từ Vựng Tiếng Anh Thông Dụng
</div>

<div class="page-desc">

    Học mỗi ngày một ít để cải thiện vốn từ vựng của bạn.
</div>


<div class="vocab-container">

    @foreach (var item in Model)
    {
        <div class="vocab-card">

            <div class="word">@item.Word</div>

            <div class="meaning">@item.Meaning</div>

            <div class="example">@item.Example</div>

        </div>
    }

</div>


<div class="control">

    @if (ViewBag.Page > 1)
    {
        <a class="btn-vocab" href="@Url.Action("_1000TuVung","Page", new { page = ViewBag.Page - 1 })">
            ← Previous
        </a>
    }

    @if (ViewBag.Page < ViewBag.TotalPage)
    {
        <a class="btn-vocab" href="@Url.Action("_1000TuVung","Page", new { page = ViewBag.Page + 1 })">
            Next →
        </a>
    }

</div>



<div class="cat-mascot">
    <img src="https://cdn-icons-png.flaticon.com/512/763/763704.png" width="50">
    <div class="cat-text" id="catText">Learn new words today!</div>
</div>



<script>

    var texts = [
        "Learn new words today!",
        "English is fun!",
        "Keep practicing!",
        "Vocabulary power!",
        "One word at a time!"
    ];

    function changeText() {
        var random = Math.floor(Math.random() * texts.length);
        document.getElementById("catText").innerText = texts[random];
    }

    setInterval(changeText, 10000);

</script>