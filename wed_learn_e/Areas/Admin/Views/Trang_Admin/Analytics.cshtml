@{
    ViewBag.Title = "Admin - Thống Kê Hệ Thống";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<h2>
    <i class="fas fa-chart-line w-5"></i> @ViewBag.Title
</h2>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="mb-8">
    <h2 class="text-2xl font-bold text-gray-800">Tổng quan hệ thống KityLearn</h2>
    <p class="text-gray-500">Số liệu được cập nhật theo thời gian thực (Real-time)</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-white p-6 rounded-xl shadow-sm border border-l-4 border-indigo-500 flex justify-between items-center">
        <div>
            <p class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-1">Tổng Học Viên</p>
            <h3 class="text-3xl font-extrabold text-gray-800">@ViewBag.TongHocVien</h3>
        </div>
        <div class="w-12 h-12 bg-indigo-50 rounded-full flex items-center justify-center text-indigo-500 text-2xl">
            <i class="fas fa-users"></i>
        </div>
    </div>

    <div class="bg-white p-6 rounded-xl shadow-sm border border-l-4 border-green-500 flex justify-between items-center">
        <div>
            <p class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-1">Tổng Khóa Học</p>
            <h3 class="text-3xl font-extrabold text-gray-800">@ViewBag.TongKhoaHoc</h3>
        </div>
        <div class="w-12 h-12 bg-green-50 rounded-full flex items-center justify-center text-green-500 text-2xl">
            <i class="fas fa-book-open"></i>
        </div>
    </div>

    <div class="bg-white p-6 rounded-xl shadow-sm border border-l-4 border-orange-500 flex justify-between items-center">
        <div>
            <p class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-1">Bình luận chờ duyệt</p>
            <h3 class="text-3xl font-extrabold text-orange-600">@ViewBag.BinhLuanCho</h3>
        </div>
        <div class="w-12 h-12 bg-orange-50 rounded-full flex items-center justify-center text-orange-500 text-2xl">
            <i class="fas fa-comments"></i>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
        <h3 class="font-bold text-gray-700 mb-4 text-lg">Top 5 Khóa Học Phổ Biến Nhất</h3>
        <canvas id="barChart" height="250"></canvas>
    </div>

    <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
        <h3 class="font-bold text-gray-700 mb-4 text-lg">Tỷ Lệ Học Viên Theo Cấp Độ</h3>
        <div style="width: 80%; margin: auto;">
            <canvas id="pieChart" height="250"></canvas>
        </div>
    </div>
</div>

<script>
    // 1. CHUẨN BỊ DỮ LIỆU TỪ C# CHUYỂN SANG JAVASCRIPT (Định dạng JSON)
    var labelKhoaHoc = @Html.Raw(Json.Encode(ViewBag.LabelKhoaHoc));
    var dataKhoaHoc = @Html.Raw(Json.Encode(ViewBag.DataKhoaHoc));

    var labelCapDo = @Html.Raw(Json.Encode(ViewBag.LabelCapDo));
    var dataCapDo = @Html.Raw(Json.Encode(ViewBag.DataCapDo));

    // 2. VẼ BIỂU ĐỒ CỘT (Khóa học)
    var ctxBar = document.getElementById('barChart').getContext('2d');
    new Chart(ctxBar, {
        type: 'bar',
        data: {
            labels: labelKhoaHoc,
            datasets: [{
                label: 'Số lượt đăng ký',
                data: dataKhoaHoc,
                backgroundColor: 'rgba(99, 102, 241, 0.8)', // Màu xanh Indigo
                borderRadius: 5 // Bo tròn góc cột
            }]
        },
        options: {
            responsive: true,
            scales: { y: { beginAtZero: true } }
        }
    });

    // 3. VẼ BIỂU ĐỒ TRÒN (Cấp độ)
    var ctxPie = document.getElementById('pieChart').getContext('2d');
    new Chart(ctxPie, {
        type: 'doughnut', // Biểu đồ tròn vành khuyên
        data: {
            labels: labelCapDo,
            datasets: [{
                data: dataCapDo,
                backgroundColor: [
                    '#4f46e5', // Xanh đậm
                    '#10b981', // Xanh lá
                    '#f59e0b', // Vàng
                    '#ef4444', // Đỏ
                    '#8b5cf6'  // Tím
                ],
                borderWidth: 0
            }]
        },
        options: { responsive: true }
    });
</script>