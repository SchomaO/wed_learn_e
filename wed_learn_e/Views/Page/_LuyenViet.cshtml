@{
    ViewBag.Title = "Luyện Viết";
    Layout = "~/Views/Shared/_Layoutcauhoi.cshtml";
}

<style>
    body { background: #eef3f9; }

    .banner {
        text-align: center;
        padding: 50px;
        background: linear-gradient(135deg,#36d1dc,#5b86e5);
        color: white;
    }

    .box {
        width: 85%;
        margin: 30px auto;
        background: white;
        padding: 25px;
        border-radius: 15px;
        box-shadow: 0 6px 15px rgba(0,0,0,0.1);
    }

    textarea {
        width: 100%;
        height: 220px;
        padding: 15px;
        border-radius: 10px;
        border: 1px solid #ccc;
    }

    .toolbar {
        display: flex;
        justify-content: space-between;
        margin-top: 10px;
    }

    .btn {
        padding: 8px 15px;
        border: none;
        border-radius: 6px;
        color: white;
        cursor: pointer;
    }

    .btn-blue { background: #0d6efd; }
    .btn-green { background: green; }
    .btn-orange { background: orange; }

    /* MODAL */
    .modal {
        display: none;
        position: fixed;
        z-index: 999;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.5);
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .modal-content {
        background: white;
        width: 90%;
        max-width: 500px;
        margin: 6% auto;
        padding: 20px;
        border-radius: 15px;
        position: relative;
        max-height: 75vh;
        overflow-y: auto;
        animation: fadeIn 0.3s;
    }

    .close {
        position: absolute;
        right: 15px;
        top: 10px;
        font-size: 25px;
        cursor: pointer;
    }

    @@keyframes fadeIn {
        from { transform: scale(0.8); opacity: 0; }
        to { transform: scale(1); opacity: 1; }
    }
</style>

<div class="banner">
    <h1>🔥 Luyện Viết Tiếng Anh</h1>
    <p>
        Tập viết mỗi ngày để nâng cao khả năng viết của bạn.
    </p>
</div>

<div class="box">

    <div>
        <b>📌 Topic:</b>
        <span id="topic"></span>
    </div>

    <textarea id="writingBox" placeholder="Write your essay..."></textarea>

    <div class="toolbar">
        <span id="wordCount">Words: 0</span>
        <span id="time">00:00</span>
    </div>

    <div class="toolbar">
        <button class="btn btn-blue" onclick="newTopic()">Đề mới</button>
        <button class="btn btn-green" onclick="checkGrammar()">Grammar</button>
        <button class="btn btn-orange" onclick="scoreEssay()">Chấm điểm</button>
    </div>

</div>

<!-- MODAL -->
<div id="modal" class="modal">
    <div class="modal-content">
        <span class="close" onclick="closeModal()">×</span>
        <div id="modalContent"></div>
    </div>
</div>

<script>

    // ===== RANDOM TOPIC =====
    const topics = [
        "Do you prefer studying at home or school?",
        "Is social media good or bad?",
        "City or countryside?",
        "Should students use technology?",
        "Is online learning effective?"
    ];

    function newTopic() {
        let i = Math.floor(Math.random() * topics.length);
        document.getElementById("topic").innerText = topics[i];
    }

    newTopic();

    // ===== WORD COUNT =====
    const box = document.getElementById("writingBox");

    box.addEventListener("input", () => {
        let words = box.value.trim().split(/\s+/).filter(w => w);
        document.getElementById("wordCount").innerText = "Words: " + words.length;
    });

    // ===== TIMER =====
    let sec = 0;
    setInterval(() => {
        sec++;
        let m = Math.floor(sec / 60);
        let s = sec % 60;
        document.getElementById("time").innerText =
            (m < 10 ? "0" : "") + m + ":" + (s < 10 ? "0" : "") + s;
    }, 1000);

    // ===== MODAL =====
    function showModal(content) {
        document.getElementById("modal").style.display = "block";
        document.getElementById("modalContent").innerHTML = content;
    }

    function closeModal() {
        document.getElementById("modal").style.display = "none";
    }

    // click ngoài để tắt
    window.onclick = function (event) {
        let modal = document.getElementById("modal");
        if (event.target == modal) {
            modal.style.display = "none";
        }
    }

    // ===== GRAMMAR CHECK =====
    async function checkGrammar() {

        let text = box.value;

        if (text.trim().length < 5) {
            showModal("❌ Viết gì đó rồi hãy check grammar!");
            return;
        }

        let res = await fetch("https://api.languagetool.org/v2/check", {
            method: "POST",
            headers: { "Content-Type": "application/x-www-form-urlencoded" },
            body: "text=" + encodeURIComponent(text) + "&language=en-US"
        });

        let data = await res.json();

        let html = "<b>🔎 Grammar:</b><br>";

        if (data.matches.length === 0) {
            html += "✅ No errors";
        } else {
            data.matches.forEach(e => {
                html += "❌ " + e.message + "<br>";
            });
        }

        showModal(html);
    }

    // ===== CHẤM ĐIỂM =====
    function scoreEssay() {

        let text = box.value.trim();
        let words = text.split(/\s+/).filter(w => w);

        if (words.length < 5) {
            showModal("❌ Bạn chưa viết đủ để chấm điểm!");
            return;
        }

        let textLower = text.toLowerCase();

        let task = 3;
        let coherence = 3;
        let vocab = 3;
        let grammar = 3;

        // TASK
        if (words.length > 50) task++;
        if (words.length > 100) task++;
        if (words.length > 150) task++;

        // COHERENCE
        if (textLower.includes("first") || textLower.includes("second")) coherence++;
        if (textLower.includes("however") || textLower.includes("therefore")) coherence++;

        // VOCAB
        let uniqueWords = new Set(words);
        if (uniqueWords.size > 30) vocab++;
        if (uniqueWords.size > 60) vocab++;

        // GRAMMAR
        if (textLower.includes("because")) grammar++;
        if (textLower.includes("although")) grammar++;

        // GIỚI HẠN MAX 9
        task = Math.min(task, 9);
        coherence = Math.min(coherence, 9);
        vocab = Math.min(vocab, 9);
        grammar = Math.min(grammar, 9);

        // TÍNH ĐIỂM
        let overall = (task + coherence + vocab + grammar) / 4;
        overall = Math.round(overall * 2) / 2;

        let html = `
            <b>📊 Band Score: ${overall}/9</b><br><br>

            <b>Task:</b> ${task}/9 <br><br>
            <b>Coherence:</b> ${coherence}/9 <br><br>
            <b>Vocabulary:</b> ${vocab}/9 <br><br>
            <b>Grammar:</b> ${grammar}/9 <br><br>

            👉 Gợi ý:
            <ul>
                <li>Viết ít nhất 80–120 từ</li>
                <li>Dùng linking words (however, therefore)</li>
                <li>Viết câu phức (because, although)</li>
            </ul>
        `;

        showModal(html);
    }

</script>