        function closeQuestionViet() { $("#modalQuestionViet").addClass("hidden").removeClass("flex"); $("body").removeClass("overflow-hidden"); }
        function resetFormCauHoiViet() { currentEditQuestionVietId = null; $("#formQuestionVietTitle").text("Thêm Câu Hỏi Mới"); $("#txtQViet_VN, #txtQViet_EN").val(""); }
        function loadQuestionVietList() { $.get("/Admin/Trang_Admin/GetCauHoiViet", { id_bai_viet: currentManageVietId }, function (res) { if (res.success) { let html = res.data.map((q, i) => `<div class="border rounded-lg p-4 relative group bg-white mb-2"><p class="font-bold">Câu ${i + 1}: ${q.cau_tieng_viet}</p><p class="text-sm text-green-700 bg-green-50 p-2 mt-1">Đáp án: ${q.dap_an_tieng_anh}</p><div class="absolute top-3 right-3 flex gap-2"><button onclick="editCauHoiViet(${q.id_cau_hoi_viet}, '${safeStr(q.cau_tieng_viet)}', '${safeStr(q.dap_an_tieng_anh)}')" class="text-blue-500 bg-white shadow-sm p-1 rounded hover:text-blue-700"><i class="fas fa-edit"></i></button><button onclick="deleteCauHoiViet(${q.id_cau_hoi_viet})" class="text-red-400 bg-white shadow-sm p-1 rounded hover:text-red-600"><i class="fas fa-trash"></i></button></div></div>`).join(''); $("#listQuestionViet").html(html); } }); }
        function editCauHoiViet(id, vn, en) { currentEditQuestionVietId = id; $("#formQuestionVietTitle").text("✏️ Cập Nhật Câu Hỏi"); $("#txtQViet_VN").val(vn); $("#txtQViet_EN").val(en); $("#modalQuestionViet .overflow-y-auto").first().animate({ scrollTop: 0 }, "fast"); }
        function saveCauHoiViet() { let data = { id_bai_viet: currentManageVietId, id_cau_hoi: currentEditQuestionVietId, cau_vn: $("#txtQViet_VN").val(), cau_en: $("#txtQViet_EN").val() }; $.post("/Admin/Trang_Admin/LuuCauHoiViet", data, function (res) { if (res.success) { resetFormCauHoiViet(); loadQuestionVietList(); } }); }
        function deleteCauHoiViet(id) { if (confirm("Xóa câu hỏi này?")) $.post("/Admin/Trang_Admin/XoaCauHoiViet", { id: id }, function (res) { if (res.success) loadQuestionVietList(); }); }

        // 11. CÂU HỎI GAME KHÓ BÁU
        let currentManageGameId = null; let currentEditQuestionGameId = null;
        $(document).on('keyup change', '#txtQG_Loai', function () { let loai = $(this).val(); if (loai) loai = loai.trim(); if (loai === 'trac_nghiem') { $("#box-QG-SelectDung").removeClass("hidden"); $("#box-QG-TextDung").addClass("hidden"); } else { $("#box-QG-SelectDung").addClass("hidden"); $("#box-QG-TextDung").removeClass("hidden"); } });
        function openQuestionGame(id, title) { currentManageGameId = id; $("#gameTitleLabel").text(title); resetFormCauHoiGame(); $("#modalQuestionGame").removeClass("hidden").addClass("flex"); $("body").addClass("overflow-hidden"); loadQuestionGameList(); }
        function closeQuestionGame() { $("#modalQuestionGame").addClass("hidden").removeClass("flex"); $("body").removeClass("overflow-hidden"); }
        function resetFormCauHoiGame() { currentEditQuestionGameId = null; $("#formQuestionGameTitle").text("Thêm Câu Hỏi Mới"); $("#txtQG_NoiDung, #txtQG_A, #txtQG_B, #txtQG_C, #txtQG_D, #txtQG_ManhGhep, #txtQG_DungText").val(""); $("#cboQG_Dung").val("A"); $("#txtQG_Loai").val("trac_nghiem").trigger('change'); let nextIndex = $("#listQuestionGame").children().length + 1; $("#txtQG_ThuTu").val(nextIndex); }
        function loadQuestionGameList() { $.get("/Admin/Trang_Admin/GetCauHoiGame", { id_game: currentManageGameId }, function (res) { if (res.success) { let html = res.data.map((q) => { let loai = q.loai_cau_hoi || "trac_nghiem"; return `<div class="border rounded-lg p-4 relative group bg-white mb-2"><p class="font-bold text-gray-800 mb-2"><span class="bg-yellow-100 text-yellow-800 px-2 py-0.5 rounded text-xs mr-2">Câu ${q.thu_tu}</span> ${q.noi_dung}</p><div class="grid grid-cols-2 gap-2 text-sm text-gray-600 mb-2"><div class="${q.dap_an_dung == 'A' ? 'font-bold text-green-600' : ''}">A. ${q.dap_an_a}</div><div class="${q.dap_an_dung == 'B' ? 'font-bold text-green-600' : ''}">B. ${q.dap_an_b}</div><div class="${q.dap_an_dung == 'C' ? 'font-bold text-green-600' : ''}">C. ${q.dap_an_c}</div><div class="${q.dap_an_dung == 'D' ? 'font-bold text-green-600' : ''}">D. ${q.dap_an_d}</div></div><div class="text-xs bg-gray-50 p-2 rounded flex justify-between"><span><i class="fas fa-puzzle-piece text-yellow-500 mr-1"></i> Mảnh ghép: <b>${q.manh_ghep || 'Không có'}</b></span><span class="text-gray-400">Loại: ${q.loai_cau_hoi}</span></div><div class="absolute top-3 right-3 opacity-0 group-hover:opacity-100 flex gap-2"><button onclick="editCauHoiGame(${q.id_cau_hoi}, ${q.thu_tu}, '${safeStr(loai)}', '${safeStr(q.noi_dung)}', '${safeStr(q.dap_an_a)}', '${safeStr(q.dap_an_b)}', '${safeStr(q.dap_an_c)}', '${safeStr(q.dap_an_d)}', '${safeStr(q.dap_an_dung)}', '${safeStr(q.manh_ghep)}')" class="text-blue-500 bg-white shadow-sm p-1 rounded hover:text-blue-700"><i class="fas fa-edit"></i></button><button onclick="deleteCauHoiGame(${q.id_cau_hoi})" class="text-red-400 bg-white shadow-sm p-1 rounded hover:text-red-600"><i class="fas fa-trash-alt"></i></button></div></div>`; }).join(''); $("#listQuestionGame").html(html); $("#txtQG_ThuTu").val(res.data.length + 1); } }); }
        function editCauHoiGame(id, thuTu, loai, q, a, b, c, d, dung, mg) { currentEditQuestionGameId = id; $("#formQuestionGameTitle").text("✏️ Cập Nhật Câu Hỏi"); $("#txtQG_ThuTu").val(thuTu); $("#txtQG_Loai").val(loai).trigger('change'); $("#txtQG_NoiDung").val(q); $("#txtQG_A").val(a); $("#txtQG_B").val(b); $("#txtQG_C").val(c); $("#txtQG_D").val(d); $("#txtQG_ManhGhep").val(mg); if (loai === 'trac_nghiem') { $("#cboQG_Dung").val(dung); } else { $("#txtQG_DungText").val(dung); } $("#modalQuestionGame .overflow-y-auto").first().animate({ scrollTop: 0 }, "fast"); }
        function saveCauHoiGame() { let loai = $("#txtQG_Loai").val(); if (loai) loai = loai.trim(); let dapAnDung = (loai === 'trac_nghiem') ? $("#cboQG_Dung").val() : $("#txtQG_DungText").val(); let data = { id_game: currentManageGameId, id_cau_hoi: currentEditQuestionGameId, thu_tu: $("#txtQG_ThuTu").val(), loai: loai, noi_dung: $("#txtQG_NoiDung").val(), a: $("#txtQG_A").val(), b: $("#txtQG_B").val(), c: $("#txtQG_C").val(), d: $("#txtQG_D").val(), dung: dapAnDung, manh_ghep: $("#txtQG_ManhGhep").val() }; $.post("/Admin/Trang_Admin/LuuCauHoiGame", data, function (res) { if (res.success) { resetFormCauHoiGame(); loadQuestionGameList(); } }); }
        function deleteCauHoiGame(id) { if (confirm("Xóa câu hỏi này?")) { $.post("/Admin/Trang_Admin/XoaCauHoiGame", { id: id }, function (res) { if (res.success) loadQuestionGameList(); }); } }

        // 12. CÂU HỎI MINI TEST (SẮP XẾP)
        let currentManageMiniTestId = null; let currentEditQuestionMiniTestId = null;
        function openQuestionMiniTest(id, title) { currentManageMiniTestId = id; $("#miniTestTitleLabel").text(title); resetFormCauHoiMiniTest(); $("#modalQuestionMiniTest").removeClass("hidden").addClass("flex"); $("body").addClass("overflow-hidden"); loadQuestionMiniTestList(); }
        function closeQuestionMiniTest() { $("#modalQuestionMiniTest").addClass("hidden").removeClass("flex"); $("body").removeClass("overflow-hidden"); }
        function resetFormCauHoiMiniTest() { currentEditQuestionMiniTestId = null; $("#formQuestionMiniTestTitle").text("Thêm Câu Hỏi Mới"); $("#txtQMT_VN, #txtQMT_EN").val(""); }
        function loadQuestionMiniTestList() { $.get("/Admin/Trang_Admin/GetCauHoiMiniTest", { id_bai: currentManageMiniTestId }, function (res) { if (res.success) { let html = res.data.map((q, i) => `<div class="border rounded-lg p-4 relative group bg-white mb-2"><p class="font-bold text-gray-800">Câu ${i + 1}: ${q.cau_tieng_viet}</p><p class="text-sm font-mono text-pink-700 bg-pink-50 p-2 mt-2 rounded border border-pink-100">Đ.án: ${q.dap_an_dung}</p><div class="absolute top-3 right-3 flex gap-2 opacity-0 group-hover:opacity-100 transition"><button onclick="editCauHoiMiniTest(${q.id_cau_hoi}, '${safeStr(q.cau_tieng_viet)}', '${safeStr(q.dap_an_dung)}')" class="text-blue-500 bg-white shadow-sm p-1 rounded hover:text-blue-700"><i class="fas fa-edit"></i></button><button onclick="deleteCauHoiMiniTest(${q.id_cau_hoi})" class="text-red-400 bg-white shadow-sm p-1 rounded hover:text-red-600"><i class="fas fa-trash"></i></button></div></div>`).join(''); $("#listQuestionMiniTest").html(html); } }); }
        function editCauHoiMiniTest(id, vn, en) { currentEditQuestionMiniTestId = id; $("#formQuestionMiniTestTitle").text("✏️ Cập Nhật Câu Hỏi"); $("#txtQMT_VN").val(vn); $("#txtQMT_EN").val(en); $("#modalQuestionMiniTest .overflow-y-auto").first().animate({ scrollTop: 0 }, "fast"); }
        function saveCauHoiMiniTest() { let data = { id_bai: currentManageMiniTestId, id_cau_hoi: currentEditQuestionMiniTestId, cau_vn: $("#txtQMT_VN").val(), dap_an: $("#txtQMT_EN").val() }; if (!data.cau_vn || !data.dap_an) { alert("Nhập đủ 2 ô nhé!"); return; } $.post("/Admin/Trang_Admin/LuuCauHoiMiniTest", data, function (res) { if (res.success) { resetFormCauHoiMiniTest(); loadQuestionMiniTestList(); } }); }
        function deleteCauHoiMiniTest(id) { if (confirm("Xóa câu hỏi sắp xếp này?")) $.post("/Admin/Trang_Admin/XoaCauHoiMiniTest", { id: id }, function (res) { if (res.success) loadQuestionMiniTestList(); }); }
    </script>
}