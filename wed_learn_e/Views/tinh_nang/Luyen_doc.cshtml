
@{
    ViewBag.Title = "Luyen_doc";
    Layout = "~/Views/Shared/_Layoutcauhoi.cshtml";
}

@model wed_learn_e.Models.LuyenDoc

<div style="text-align: center; margin-top: 50px;">
    <h2>Đọc câu dưới đây:</h2>

    <h3 id="targetText" style="color: blue;">@Model.DoanVan</h3>

    <button id="btnRecord" style="padding: 10px 20px; font-size: 16px; margin: 20px; cursor: pointer;">
        🎤 Bắt đầu thu âm
    </button>

    <div style="margin-top: 20px; font-size: 18px;">
        <p><strong>Bạn vừa đọc:</strong> <span id="resultText" style="color: gray;">...</span></p>
        <p id="feedbackMsg" style="font-weight: bold;"></p>
    </div>
</div>

<script>
    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

    if (SpeechRecognition) {
        const recognition = new SpeechRecognition();

        // 2. Cài đặt ngôn ngữ động từ Database!
        recognition.lang = '@Model.NgonNgu';
        recognition.interimResults = false;

        const btnRecord = document.getElementById('btnRecord');
        const targetTextElement = document.getElementById('targetText');
        const resultTextElement = document.getElementById('resultText');
        const feedbackMsgElement = document.getElementById('feedbackMsg');

        btnRecord.addEventListener('click', () => {
            recognition.start();
            btnRecord.innerText = "🔴 Đang nghe...";
            btnRecord.disabled = true;
            resultTextElement.innerText = "...";
            feedbackMsgElement.innerText = "";
        });

        recognition.onresult = (event) => {
            const transcript = event.results[0][0].transcript;
            resultTextElement.innerText = transcript;

            let spokenWord = transcript.toLowerCase().replace(/[.,!?]/g, "").trim();
            let targetWord = targetTextElement.innerText.toLowerCase().replace(/[.,!?]/g, "").trim();

            if (spokenWord === targetWord) {
                feedbackMsgElement.innerText = "🎉 Chính xác! Bạn đọc rất tốt.";
                feedbackMsgElement.style.color = "green";
            } else {
                feedbackMsgElement.innerText = "❌ Chưa đúng rồi. Bạn thử lại nhé!";
                feedbackMsgElement.style.color = "red";
            }
        };

        recognition.onend = () => {
            btnRecord.innerText = "🎤 Bắt đầu thu âm";
            btnRecord.disabled = false;
        };

        recognition.onerror = (event) => {
            alert("Lỗi thu âm: " + event.error);
        };
    } else {
        alert("Trình duyệt không hỗ trợ thu âm.");
    }
</script>
