@{
    ViewBag.Title = "kq_bai_test";
    Layout = "~/Views/Shared/_Layoutcauhoi.cshtml";

    // Đã xóa dấu ``` bao quanh dòng code này
    double diem10 = Math.Round((double)ViewBag.Diem / ViewBag.Tong * 10, 1);
}

<style>
    body {
        background: linear-gradient(120deg,#dff5ff,#c7efff,#bfe7ff);
        font-family: Arial;
    }

    .result-container {
        width: 650px;
        margin: auto;
        margin-top: 120px;
        display: flex;
        flex-direction: column;
        gap: 25px;
    }

    .box {
        background: white;
        padding: 30px;
        border-radius: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        text-align: center;
    }

    .score {
        font-size: 18px;
        margin: 10px 0;
    }

    .review-btn {
        margin-top: 15px;
        padding: 10px 20px;
        border: none;
        border-radius: 10px;
        background: #6ec8ff;
        color: white;
        font-weight: bold;
        cursor: pointer;
    }

    .course-container {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(250px,1fr));
        gap: 20px;
        margin-top: 15px;
    }

    .course-box {
        background: #f7fbff;
        border-radius: 12px;
        padding: 20px;
        text-align: center;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .course-icon {
        font-size: 35px;
        margin-bottom: 10px;
    }

    .course-title {
        font-size: 18px;
        font-weight: bold;
        color: #007bff;
        margin-bottom: 8px;
    }

    .course-desc {
        font-size: 14px;
        color: #555;
        margin-bottom: 15px;
    }

    .btn-course {
        background: #0d6efd;
        color: white;
        padding: 8px 15px;
        border-radius: 6px;
        text-decoration: none;
        display: inline-block;
    }

        .btn-course:hover {
            background: #0b5ed7;
        }
</style>

<div class="result-container">

    <div class="box">

        <h2>Kết quả bài kiểm tra</h2>

        <div class="score">
            Bạn trả lời đúng: <b>@ViewBag.Diem / @ViewBag.Tong</b>
        </div>

        <div class="score">
            Điểm của bạn: <b>@diem10</b>
        </div>

        <div class="score">
            Cấp độ: <b>@ViewBag.CapDo</b>
        </div>

        <a href="@Url.Action("review","bai_test")">
            <button class="review-btn">Xem lại bài làm</button>
        </a>

    </div>

    <div class="box">

        <h3>Khóa học gợi ý</h3>

        <div class="course-container">

            <div class="course-container">

                @if (ViewBag.CapDo == 1)
                {
                    <div class="course-box">
                        <div class="course-icon">📘</div>
                        <div class="course-title">Beginner (A1)</div>
                        <div class="course-desc">
                            Khóa học cơ bản dành cho người mới bắt đầu.
                        </div>
                        <a class="btn-course" href="@Url.Action("thong_tin_khoa_hoc", "Page", new { id = 1 })">Bắt đầu học</a>
                    </div>
                }
                else if (ViewBag.CapDo == 2)
                {
                    <div class="course-box">
                        <div class="course-icon">📗</div>
                        <div class="course-title">Elementary (A2)</div>
                        <div class="course-desc">
                            Nâng cao kỹ năng giao tiếp và ngữ pháp.
                        </div>
                        <a class="btn-course" href="@Url.Action("thong_tin_khoa_hoc", "Page", new { id = 2 })">Bắt đầu học</a>
                    </div>
                }
                else if (ViewBag.CapDo == 3)
                {
                    <div class="course-box">
                        <div class="course-icon">📙</div>
                        <div class="course-title">Intermediate (B1)</div>
                        <div class="course-desc">
                            Thành thạo tiếng Anh giao tiếp văn phòng.
                        </div>
                        <a class="btn-course" href="@Url.Action("thong_tin_khoa_hoc", "Page", new { id = 3 })">Bắt đầu học</a>
                    </div>
                }
                else if (ViewBag.CapDo == 4)
                {
                    <div class="course-box">
                        <div class="course-icon">📕</div>
                        <div class="course-title">Upper-Intermediate (B2)</div>
                        <div class="course-desc">
                            Rèn luyện phong thái và kỹ năng thuyết trình.
                        </div>
                        <a class="btn-course" href="@Url.Action("thong_tin_khoa_hoc", "Page", new { id = 4 })">Bắt đầu học</a>
                    </div>
                }
                else if (ViewBag.CapDo == 5)
                {
                    <div class="course-box">
                        <div class="course-icon">📓</div>
                        <div class="course-title">Advanced (C1)</div>
                        <div class="course-desc">
                            Học cách viết luận học thuật chuyên sâu.
                        </div>
                        <a class="btn-course" href="@Url.Action("thong_tin_khoa_hoc", "Page", new { id = 5 })">Bắt đầu học</a>
                    </div>
                }
                else if (ViewBag.CapDo == 6)
                {
                    <div class="course-box">
                        <div class="course-icon">👑</div>
                        <div class="course-title">Proficient (C2)</div>
                        <div class="course-desc">
                            Giao tiếp tự nhiên như người bản xứ.
                        </div>
                        <a class="btn-course" href="@Url.Action("thong_tin_khoa_hoc", "Page", new { id = 6 })">Bắt đầu học</a>
                    </div>
                }

            </div>
        </div>

        <div style="margin-top:20px;">
            <a href="@Url.Action("khoadaotao","Page")" class="btn-course">
                Tham gia khóa học khác
            </a>
        </div>

    </div>
</div>