@model List<wed_learn_e.Models.cap_do>

@{
    ViewBag.Title = "Khóa Đào Tạo";
    Layout = "~/Views/Shared/_Layoutcauhoi.cshtml";
}

<style>
    body {
        margin: 0;
        font-family: Arial;
        background: #e9f5ff;
    }

    /* --- GIAO DIỆN KHÓA HỌC --- */
    .title {
        text-align: center;
        padding: 40px;
        font-size: 32px;
        font-weight: bold;
        color: #0d6efd;
    }

    .course-container {
        width: 90%;
        margin: auto;
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(250px,1fr));
        gap: 25px;
        padding-bottom: 50px;
    }

    .course-box {
        background: white;
        border-radius: 12px;
        padding: 25px;
        text-align: center;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        transition: 0.3s;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

        .course-box:hover {
            transform: translateY(-6px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }

    .course-icon {
        font-size: 40px;
        margin-bottom: 15px;
    }

    .course-title {
        font-size: 20px;
        font-weight: bold;
        margin-bottom: 10px;
        color: #007bff;
    }

    .course-desc {
        font-size: 14px;
        color: #555;
        margin-bottom: 20px;
        flex-grow: 1;
    }

    .btn-course {
        background: #0d6efd;
        color: white;
        padding: 10px 18px;
        border-radius: 6px;
        text-decoration: none;
        align-self: center;
        cursor: pointer;
        border: none;
        font-size: 16px;
    }

        .btn-course:hover {
            background: #0b5ed7;
        }

    .extra-title {
        text-align: center;
        margin-top: 80px;
        margin-bottom: 20px;
        font-size: 28px;
        font-weight: bold;
        color: #0b5ed7;
        position: relative;
    }

        .extra-title:after {
            content: "";
            width: 120px;
            height: 3px;
            background: #0d6efd;
            display: block;
            margin: 10px auto;
            border-radius: 3px;
        }

    /* --- GIAO DIỆN CON MÈO --- */
    .cat-mascot {
        position: fixed;
        bottom: 20px;
        right: 20px;
        font-size: 55px;
        animation: floatCat 10s infinite ease-in-out;
    }

    .cat-text {
        position: absolute;
        bottom: 70px;
        right: 0;
        background: white;
        padding: 6px 10px;
        border-radius: 10px;
        font-size: 14px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    }

    @@keyframes floatCat {
        0% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-8px);
        }

        100% {
            transform: translateY(0);
        }
    }

    /* --- GIAO DIỆN BẢNG THÔNG BÁO NỔI --- */
    .custom-modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.6);
        z-index: 9999;
        align-items: center;
        justify-content: center;
    }

    .custom-modal-box {
        background: #fff;
        padding: 30px;
        border-radius: 15px;
        width: 400px;
        max-width: 90%;
        text-align: center;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        animation: modalFadeIn 0.3s ease;
    }

    .custom-modal-title {
        font-size: 22px;
        font-weight: bold;
        margin-bottom: 15px;
        color: #0d6efd;
    }

    .custom-modal-message {
        font-size: 16px;
        color: #444;
        margin-bottom: 25px;
        line-height: 1.5;
        white-space: pre-line;
    }

    .custom-modal-buttons {
        display: flex;
        justify-content: center;
        gap: 15px;
    }

    .btn-modal {
        padding: 10px 24px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-weight: bold;
        font-size: 15px;
        transition: 0.2s;
    }

    .btn-modal-cancel {
        background: #e9ecef;
        color: #495057;
    }

        .btn-modal-cancel:hover {
            background: #dde2e6;
        }

    .btn-modal-confirm {
        background: #0d6efd;
        color: #fff;
    }

        .btn-modal-confirm:hover {
            background: #0b5ed7;
        }

    @@keyframes modalFadeIn {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="extra-title">Khóa Đào Tạo Tiếng Anh</div>

<div class="custom-modal-overlay" id="myCustomModal">
    <div class="custom-modal-box">
        <div class="custom-modal-title" id="modalTitle">Thông báo</div>
        <div class="custom-modal-message" id="modalMessage">Nội dung...</div>
        <div class="custom-modal-buttons">
            <button class="btn-modal btn-modal-cancel" id="btnModalCancel">Hủy</button>
            <button class="btn-modal btn-modal-confirm" id="btnModalConfirm">Đồng ý</button>
        </div>
    </div>
</div>

<div class="course-container">
    @{
        string[] colors = { "#ffffff", "#f0f8ff", "#e6f4ff", "#f5fbff", "#eef7ff", "#f2f9ff" };
        string[] icons = { "📘", "📗", "📙", "📕", "🎓", "🏆" };

        // Hứng danh sách đã đăng ký từ Controller sang
        var daDangKy = ViewBag.DaDangKy as List<int> ?? new List<int>();
    }

    @for (int i = 0; i < Model.Count; i++)
    {
        var item = Model[i];
        <div class="course-box" style="background: @(colors[i % colors.Length])">
            <div class="course-icon">@(icons[i % icons.Length])</div>
            <div class="course-title">@item.ten_cap_do</div>
            <div class="course-desc">@item.mo_ta</div>

            @if (daDangKy.Contains(item.id_cap_do))
            {
                <a href="@Url.Action("thong_tin_khoa_hoc", "Page", new { id = item.id_cap_do })" class="btn-course" style="background: #28a745; text-decoration: none; display: inline-block;">
                    Tiếp tục học
                </a>
            }
            else
            {
                <button class="btn-course" onclick="xacNhanDangKy(@item.id_cap_do)">
                    Chọn khóa học
                </button>
            }
        </div>
    }
</div>

<div class="cat-mascot">
    <img src="https://cdn-icons-png.flaticon.com/512/763/763704.png" width="50" alt="cat">
    <div class="cat-text" id="catText">Let's learn English!</div>
</div>


<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    // --- 1. Script cho con mèo ---
    var texts = [
        "Let's learn English!",
        "Practice makes perfect!",
        "Keep studying!",
        "You can do it!",
        "New words today?"
    ];
    function changeText() {
        var random = Math.floor(Math.random() * texts.length);
        document.getElementById("catText").innerText = texts[random];
    }
    setInterval(changeText, 10000);

    // --- 2. Hàm điều khiển Bảng thông báo nổi ---
    function showModal(title, message, isConfirm, onConfirmCallback) {
        $("#modalTitle").text(title);
        $("#modalMessage").text(message);

        // Nút Hủy chỉ hiện khi là câu hỏi Xác nhận
        if (isConfirm) {
            $("#btnModalCancel").show();
        } else {
            $("#btnModalCancel").hide();
        }

        // Hiện popup lên
        $("#myCustomModal").css("display", "flex");

        // Gắn sự kiện nút Đồng ý
        $("#btnModalConfirm").off("click").on("click", function () {
            $("#myCustomModal").css("display", "none");
            if (typeof onConfirmCallback === "function") {
                onConfirmCallback();
            }
        });

        // Gắn sự kiện nút Hủy
        $("#btnModalCancel").off("click").on("click", function () {
            $("#myCustomModal").css("display", "none");
        });
    }

    // --- 3. AJAX Xử lý Đăng ký khóa học ---
    function xacNhanDangKy(idCapDo) {
        showModal("Xác nhận đăng ký", "Bạn có chắc chắn muốn đăng ký tham gia khóa học cấp độ này không?", true, function () {

            // Chạy AJAX sau khi người dùng bấm Đồng ý
            $.ajax({
                url: '@Url.Action("DangKyKhoaHoc", "Page")',
                type: 'POST',
                data: { id_cap_do: idCapDo },
                success: function (res) {
                    if (res.success) {
                        window.location.href = res.redirect;
                    } else {
                        // Vượt giới hạn tài khoản Thường
                        if (res.type === "limit_reached") {
                            showModal("Giới hạn tài khoản", res.message + "\n\nBạn có muốn chuyển đến trang Nâng cấp VIP ngay?", true, function() {
                                window.location.href = res.redirect;
                            });
                        }
                        // Chưa đăng nhập
                        else if (res.type === "not_logged_in") {
                            showModal("Yêu cầu đăng nhập", res.message, false, function() {
                                window.location.href = res.redirect;
                            });
                        }
                        // Các lỗi khác
                        else {
                            showModal("Lỗi", res.message, false);
                        }
                    }
                },
                error: function () {
                    showModal("Lỗi kết nối", "Có lỗi xảy ra khi kết nối với máy chủ! Vui lòng thử lại.", false);
                }
            });
        });
    }
</script>