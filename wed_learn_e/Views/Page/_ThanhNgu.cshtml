@model PagedList.IPagedList<wed_learn_e.Models.Idiom>
@using PagedList.Mvc;
@{
    ViewBag.Title = "Thành Ngữ Tiếng Anh";
    Layout = "~/Views/Shared/_Layoutcauhoi.cshtml";
}

<style>
    body {
        background: linear-gradient(135deg, #eaf8ff, #a6e1ff);
        font-family: Arial;
        margin: 0;
    }

    .page-header {
        text-align: center;
        color: #333;
        margin-top: 30px;
    }

        .page-header p {
            font-size: 14px;
            color: #666;
            margin-top: 15px;
        }

    #searchBox {
        display: block;
        margin: 0 auto 30px auto;
        padding: 10px 18px;
        width: 480px;
        border-radius: 25px;
        border: 1px solid black;
        outline: none;
        background: white;
    }

    .idiom-container {
        width: 90%;
        margin: auto;
        display: grid;
        /* 1. Sửa auto-fit thành auto-fill ở dòng này */
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 20px;
        /* 2. Thêm dòng này để nếu có ít thẻ thì nó sẽ tự động căn giữa màn hình cho đẹp */
        justify-content: center;
    }

    .idiom-card {
        background: linear-gradient(135deg, #ffffff, #d9f1ff);
        border-radius: 12px;
        text-align: center;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        transition: 0.3s;
        cursor: pointer;
        height: 160px;
        perspective: 1000px;
        border: 1px solid #d0eaff;
        position: relative;
    }

        .idiom-card:hover {
            transform: translateY(-6px) scale(1.02);
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }

    .inner {
        width: 100%;
        height: 100%;
        position: relative;
        transform-style: preserve-3d;
        transition: transform 0.5s;
    }

    .idiom-card.flip .inner {
        transform: rotateY(180deg);
    }

    .front, .back {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        border-radius: 12px;
        padding: 15px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        background: #eaf6ff;
        border: 1px solid #e0e0e0;
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
        box-sizing: border-box;
        backface-visibility: hidden;
        -webkit-backface-visibility: hidden;
    }

    .back {
        transform: rotateY(180deg);
    }

    .idiom {
        font-size: 16px;
        font-weight: bold;
        color: #333;
    }

    .meaning {
        margin-top: 6px;
        font-size: 14px;
        color: #666;
    }

    .example {
        margin-top: 6px;
        font-size: 13px;
        color: #777;
        font-style: italic;
    }

    .cat-mascot {
        position: fixed;
        bottom: 15px;
        right: 15px;
    }

    .cat-text {
        position: absolute;
        bottom: 60px;
        right: 0;
        background: white;
        padding: 6px 10px;
        border-radius: 10px;
        font-size: 12px;
        border: 1px solid #ddd;
        white-space: nowrap;
    }

    /* --- CSS CHO THANH PHÂN TRANG (PAGINATION) --- */
    .pagination-container {
        text-align: center;
        margin: 40px 0;
    }

    .pagination {
        display: inline-flex;
        padding-left: 0;
        list-style: none;
        justify-content: center;
        margin-top: 20px;
    }

        .pagination li {
            margin: 0 5px;
        }

            .pagination li a, .pagination li span {
                display: block;
                padding: 10px 18px;
                color: #4786e3;
                text-decoration: none;
                background-color: #fff;
                border: 1px solid #ddd;
                border-radius: 8px;
                font-weight: bold;
                font-size: 16px;
                transition: 0.3s;
            }

                .pagination li a:hover {
                    background-color: #f8f9fa;
                    color: #0b5ed7;
                    border-color: #4786e3;
                }

        .pagination .active span {
            background-color: #4786e3;
            color: white;
            border-color: #4786e3;
        }

        .pagination .disabled span {
            color: #ccc;
            cursor: not-allowed;
            background-color: #f9f9f9;
        }
</style>

<div class="page-header">
    @Html.Partial("_NutQuayLai", new ViewDataDictionary {
      { "LinkQuayVe", Url.Action("thong_tin_khoa_hoc", "Page", new { id = ViewBag.IdCapDo }) },
      { "TieuDe", "Thành Ngữ Tiếng Anh" }
    })
    <p>Khám phá các thành ngữ phổ biến trong tiếng Anh và cách sử dụng chúng trong giao tiếp hàng ngày.</p>
</div>

<form method="get" action="@Url.Action("_ThanhNgu", "Page")" style="text-align: center;">
    @if (ViewBag.IdCapDo != null)
    {
        <input type="hidden" name="id_cap_do" value="@ViewBag.IdCapDo" />
    }
    <input type="text" id="searchBox" name="search" value="@ViewBag.Search" placeholder="Nhập để tìm idiom rồi nhấn Enter..." />
</form>

<div class="idiom-container">
    @if (Model != null && Model.Count > 0)
    {
        foreach (var item in Model)
        {
            <div class="idiom-card">
                <div class="inner">
                    <div class="front">
                        <div class="idiom">@item.IdiomText</div>
                        <div class="meaning">@item.Meaning</div>
                    </div>
                    <div class="back">
                        <div class="example">@item.Example</div>
                        <div class="meaning">→ @item.Meaning</div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div style="grid-column: 1 / -1; text-align: center; padding: 40px;">Không tìm thấy thành ngữ nào!</div>
    }
</div>

<div class="pagination-container">
    @if (Model != null && Model.PageCount > 1)
    {
        @Html.PagedListPager(Model, page => Url.Action("_ThanhNgu", new { page, id_cap_do = ViewBag.IdCapDo, search = ViewBag.Search }))
    }
</div>

<div class="cat-mascot">
    <img src="https://cdn-icons-png.flaticon.com/512/763/763704.png" width="55">
    <div class="cat-text">Idioms make English more natural!</div>
</div>

<script>
    const messages = ["Idioms make English cool 😎", "Learn 5 idioms a day!", "Practice makes perfect!"];
    document.querySelector(".cat-text").innerText = messages[Math.floor(Math.random() * messages.length)];

    // Script lật thẻ
    document.querySelectorAll(".idiom-card").forEach(card => {
        card.onclick = function () { this.classList.toggle("flip"); }
    });
</script>