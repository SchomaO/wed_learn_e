@using PagedList.Mvc;
@model PagedList.IPagedList<wed_learn_e.Models.bai_luyen_viet>
@{
    ViewBag.Title = "Danh Sách Bài Luyện Viết";
    Layout = "~/Views/Shared/_Layoutcauhoi.cshtml";
    // Lấy ra danh sách ID các bài user đã làm xong
    var listDaHoanThanh = ViewBag.ListDaHoanThanh as List<int?> ?? new List<int?>();
}

<link href="~/Content/PagedList.css" rel="stylesheet" type="text/css" />

<style>
    body {
        background: #f4f9ff;
        font-family: Arial;
        margin: 0;
    }

    .list-container {
        max-width: 900px;
        margin: 40px auto;
        padding: 0 20px;
    }

    .page-title {
        text-align: center;
        color: #1a73e8;
        font-size: 32px;
        font-weight: bold;
        margin-bottom: 30px;
    }

    /* CSS THANH TÌM KIẾM */
    .search-box {
        background: white;
        padding: 20px;
        border-radius: 12px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        margin-bottom: 25px;
        display: flex;
        gap: 10px;
    }

    .search-input {
        flex: 1;
        padding: 12px 15px;
        border: 1px solid #ddd;
        border-radius: 8px;
        font-size: 16px;
        outline: none;
        transition: 0.3s;
    }

        .search-input:focus {
            border-color: #1a73e8;
            box-shadow: 0 0 5px rgba(26,115,232,0.3);
        }

    .btn-search {
        background: #1a73e8;
        color: white;
        border: none;
        padding: 0 25px;
        border-radius: 8px;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
        white-space: nowrap;
    }

        .btn-search:hover {
            background: #1557b0;
        }

    /* CSS THẺ BÀI HỌC */
    .lesson-card {
        background: white;
        border-radius: 12px;
        padding: 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        margin-bottom: 20px;
        border-left: 6px solid #1a73e8;
        transition: 0.3s;
    }

        .lesson-card:hover {
            transform: translateX(5px);
            box-shadow: 0 6px 15px rgba(0,0,0,0.1);
        }

        /* CSS RIÊNG CHO BÀI ĐÃ HOÀN THÀNH */
        .lesson-card.completed {
            border-left-color: #28a745;
            background: #f4fff6;
        }

            .lesson-card.completed .lesson-icon {
                background: #d4edda;
                color: #155724;
            }

    .lesson-info {
        display: flex;
        align-items: center;
        gap: 20px;
        width: 75%;
    }

    .lesson-icon {
        font-size: 30px;
        background: #eef7ff;
        min-width: 60px;
        height: 60px;
        display: flex;
        justify-content: center;
        align-items: center;
        border-radius: 50%;
    }

    .lesson-details h3 {
        margin: 0 0 5px 0;
        font-size: 20px;
        color: #333;
    }

    .lesson-details p {
        margin: 0;
        color: #777;
        font-size: 14px;
    }

    .btn-action {
        background: #1a73e8;
        color: white;
        padding: 10px 20px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: bold;
        transition: 0.2s;
        white-space: nowrap;
    }

        .btn-action:hover {
            background: #1557b0;
        }

        /* Nút khi đã hoàn thành */
        .btn-action.btn-success {
            background: #28a745;
        }

            .btn-action.btn-success:hover {
                background: #218838;
            }

    /* CSS PHÂN TRANG */
    .pagination-container {
        text-align: center;
        margin-top: 30px;
    }

    .pagination {
        display: inline-flex;
        padding-left: 0;
        list-style: none;
        border-radius: 0.25rem;
    }
</style>

<div class="list-container">
    @Html.Partial("_NutQuayLai", new ViewDataDictionary {
  // Thêm đoạn new { id = ... } để hệ thống tạo ra link có đuôi /1
  { "LinkQuayVe", Url.Action("thong_tin_khoa_hoc", "Page", new { id = Request.QueryString["id_cap_do"] }) },

})
    <div class="page-title">✍️ Luyện Viết: @ViewBag.TenCapDo</div>

    @using (Html.BeginForm("list_luyen_viet", "tinh_nang", FormMethod.Get))
    {
        <div class="search-box">
            <input type="hidden" name="id_cap_do" value="@ViewBag.IdCapDo" />

            <input type="text" name="searchString" value="@ViewBag.CurrentFilter" class="search-input" placeholder="Nhập tên bài luyện viết bạn muốn tìm kiếm..." />
            <button type="submit" class="btn-search">🔍 Tìm Kiếm</button>
        </div>
    }

    @if (Model == null || Model.Count == 0)
    {
        <div style="text-align: center; color: #dc3545; background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); font-weight: bold;">
            Chưa có bài tập viết nào phù hợp với tìm kiếm của bạn.
        </div>
    }
    else
    {
        // Thuật toán để số thứ tự không bị reset về 1 khi sang trang 2
        int stt = (Model.PageNumber - 1) * Model.PageSize + 1;

        foreach (var item in Model)
        {
            // Kiểm tra xem ID bài này có nằm trong danh sách hoàn thành chưa?
            bool daXong = listDaHoanThanh.Contains(item.id_bai_viet);

            <div class="lesson-card @(daXong ? "completed" : "")">
                <div class="lesson-info">
                    <div class="lesson-icon">@(daXong ? "✔" : "📝")</div>
                    <div class="lesson-details">
                        <h3>Bài @stt: @item.tieu_de</h3>
                        <p>@item.mo_ta</p>
                    </div>
                </div>

                <a href="@Url.Action("LuyenViet", "tinh_nang", new { id_bai_viet = item.id_bai_viet })"
                   class="btn-action @(daXong ? "btn-success" : "")">
                    @(daXong ? "Ôn tập lại" : "Bắt đầu viết")
                </a>
            </div>
            stt++;
        }
    }

    <div class="pagination-container">
        <div style="margin-bottom: 10px; color: #666; font-weight: bold;">
            Trang @(Model.PageCount < Model.PageNumber ? 0 : Model.PageNumber) / @Model.PageCount
        </div>



        @Html.PagedListPager(Model, page => Url.Action("list_luyen_viet",
            new { page, searchString = ViewBag.CurrentFilter, id_cap_do = ViewBag.IdCapDo }),
            new PagedListRenderOptions
                {
                    DisplayLinkToFirstPage = PagedListDisplayMode.Always,
                DisplayLinkToLastPage = PagedListDisplayMode.Always,
                DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
                DisplayLinkToNextPage = PagedListDisplayMode.Always,
                MaximumPageNumbersToDisplay = 5,
                LinkToFirstPageFormat = "« Đầu",
                LinkToPreviousPageFormat = "‹ Trước",
                LinkToNextPageFormat = "Sau ›",
                LinkToLastPageFormat = "Cuối »"
            })
    </div>
</div>