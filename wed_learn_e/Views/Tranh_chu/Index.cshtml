
@{
    ViewBag.Title = "Trang chủ";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title</title>
    <style>
        body {
            margin: 0;
            font-family: Arial;
            background: #f4f4f4;
        }


        /* HEADER */

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #4786e3;
            padding: 20px 60px;
        }

        .logo {
            font-size: 24px;
            font-weight: bold;
            color: white;
        }

        .login {
            color: white;
        }

            .login button {
                margin-left: 15px;
                padding: 8px 18px;
                border: none;
                border-radius: 20px;
                background: white;
                color: #4f83cc;
                font-weight: bold;
                cursor: pointer;
            }


        /* HERO */

        .hero {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 80px;
        }


        /* LEFT IMAGE */

        .hero-left img {
            width: 420px;
        }


        /* RIGHT TEXT */

        .hero-right {
            margin-left: 80px;
        }

        .title {
            color: #f4b400;
        }

        .hero-right h1 {
            color: #4f83cc;
            font-size: 36px;
        }


        .start-btn {
            margin-top: 30px;
            padding: 15px 35px;
            border: none;
            border-radius: 10px;
            background: #4786e3;
            color: white;
            font-size: 18px;
            cursor: pointer;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
        }

            .start-btn:hover {
                background: #2dafff;
            }

        a {
            text-decoration: none;
            color: white;
            border-bottom: 5px solid transparent;
        }
    </style>
</head>
<body>
    <!-- HEADER -->
    <header>
        <div class="logo">
            trang chủ
        </div>

        <div class="login">
            <a href="#"><span> <b>Bạn đã có tài khoản? </b></span></a>
            <button>Đăng nhập</button>
        </div>
    </header>


    <!-- HERO / BANNER -->
    <section class="hero">

        <div class="hero-left">
            <img src="" alt="logo">
        </div>

        <div class="hero-right">

            <h2 class="title">trang chủ</h2>

            <h1>
                
            </h1>

            <button class="start-btn">
                Bắt đầu học
            </button>

        </div>

    </section>

</body>
</html>

