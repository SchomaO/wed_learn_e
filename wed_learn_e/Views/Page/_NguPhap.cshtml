@{
    ViewBag.Title = "Khóa Học Ngữ Pháp";
    Layout = "~/Views/Shared/_Layoutcauhoi.cshtml";
}

<style>

    body {
        background: #f4f7fb;
    }

    /* banner */

    .banner {
        width: 100%;
        padding: 60px 20px;
        text-align: center;
        background: linear-gradient(135deg,#4facfe,#00f2fe);
        color: white;
    }

        .banner h1 {
            font-size: 40px;
            font-weight: bold;
        }

        .banner p {
            font-size: 18px;
            opacity: 0.9;
        }

    /* container */

    .grammar-container {
        width: 90%;
        margin: 50px auto;
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(240px,1fr));
        gap: 25px;
    }

    /* card */

    .grammar-card {
        background: white;
        border-radius: 15px;
        padding: 30px;
        text-align: center;
        box-shadow: 0 6px 15px rgba(0,0,0,0.1);
        transition: 0.3s;
        position: relative;
    }

        .grammar-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.15);
        }

    /* icon */

    .icon {
        font-size: 40px;
        margin-bottom: 15px;
    }

    /* title */

    .lesson-title {
        font-size: 20px;
        font-weight: bold;
        color: #0d6efd;
    }

    /* description */

    .lesson-desc {
        margin-top: 10px;
        color: #666;
        font-size: 14px;
    }

    /* button */

    .btn-learn {
        display: inline-block;
        margin-top: 18px;
        padding: 8px 18px;
        border-radius: 6px;
        background: #0d6efd;
        color: white;
        text-decoration: none;
    }

        .btn-learn:hover {
            background: #0b5ed7;
        }

    /* mascot */

    .cat-mascot {
        position: fixed;
        bottom: 20px;
        right: 20px;
    }

    .cat-text {
        position: absolute;
        bottom: 70px;
        right: 0;
        background: white;
        padding: 6px 10px;
        border-radius: 10px;
        font-size: 14px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    }
</style>


<div class="banner">

    <h1>Khóa Học Ngữ Pháp Tiếng Anh</h1>

    <p>
        Học ngữ pháp từ cơ bản đến nâng cao một cách dễ hiểu.
    </p>

</div>
@Html.Partial("_NutQuayLai", new ViewDataDictionary {
  // Thêm đoạn new { id = ... } để hệ thống tạo ra link có đuôi /1
  { "LinkQuayVe", Url.Action("thong_tin_khoa_hoc", "Page", new { id = Request.QueryString["id_cap_do"] }) },
  { "TieuDe", " "  }
})


<div class="grammar-container">

    <div class="grammar-card">
        <div class="icon">📘</div>
        <div class="lesson-title">Present Simple</div>
        <div class="lesson-desc">
            Thì hiện tại đơn và cách sử dụng.
        </div>
        <a href="#" class="btn-learn">Học ngay</a>
    </div>

    <div class="grammar-card">
        <div class="icon">📗</div>
        <div class="lesson-title">Present Continuous</div>
        <div class="lesson-desc">
            Thì hiện tại tiếp diễn.
        </div>
        <a href="#" class="btn-learn">Học ngay</a>
    </div>

    <div class="grammar-card">
        <div class="icon">📙</div>
        <div class="lesson-title">Past Simple</div>
        <div class="lesson-desc">
            Thì quá khứ đơn.
        </div>
        <a href="#" class="btn-learn">Học ngay</a>
    </div>

    <div class="grammar-card">
        <div class="icon">📕</div>
        <div class="lesson-title">Future Tense</div>
        <div class="lesson-desc">
            Các thì trong tương lai.
        </div>
        <a href="#" class="btn-learn">Học ngay</a>
    </div>

    <div class="grammar-card">
        <div class="icon">⚖️</div>
        <div class="lesson-title">Comparatives</div>
        <div class="lesson-desc">
            So sánh hơn và so sánh nhất.
        </div>
        <a href="#" class="btn-learn">Học ngay</a>
    </div>

    <div class="grammar-card">
        <div class="icon">🔄</div>
        <div class="lesson-title">Passive Voice</div>
        <div class="lesson-desc">
            Câu bị động trong tiếng Anh.
        </div>
        <a href="#" class="btn-learn">Học ngay</a>
    </div>

</div>



<div class="cat-mascot">

    <img src="https://cdn-icons-png.flaticon.com/512/763/763704.png" width="55">

    <div class="cat-text">
        Grammar makes English easier!
    </div>

</div>