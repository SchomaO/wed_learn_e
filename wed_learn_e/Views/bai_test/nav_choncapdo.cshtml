@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Chọn cấp độ</title>

    <style>
        body {
            font-family: Arial;
            background-color: #f4f4f4;
            text-align: center;
        }

        h1 {
            margin-top: 40px;
        }

        .container {
            width: 80%;
            margin: auto;
            margin-top: 50px;
            display: flex;
            justify-content: center;
            gap: 30px;
            flex-wrap: wrap;
        }

        .box {
            width: 180px;
            height: 120px;
            background: white;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }

            .box:hover {
                transform: scale(1.05);
                background: #007bff;
                color: white;
            }

        a {
            text-decoration: none;
            color: inherit;
        }
    </style>
</head>

<body>

    <h1>Chọn cấp độ hiện tại</h1>

    <div class="container">

        <a href="@Url.Action("IELTS1_2","Home")">
            <div class="box">
                IELTS 1 - 2
            </div>
        </a>

        <a href="@Url.Action("IELTS2_3","Home")">
            <div class="box">
                IELTS 2 - 3
            </div>
        </a>

        <a href="@Url.Action("IELTS3_4","Home")">
            <div class="box">
                IELTS 3 - 4
            </div>
        </a>

        <a href="@Url.Action("IELTS4_5","Home")">
            <div class="box">
                IELTS 4 - 5
            </div>
        </a>

    </div>

</body>
</html>