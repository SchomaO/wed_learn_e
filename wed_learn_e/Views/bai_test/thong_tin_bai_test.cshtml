@model wed_learn_e.Models.bai_kiem_tra
@{
    ViewBag.Title = Model.tieu_de;
    Layout = "~/Views/Shared/_Layoutcauhoi.cshtml";
}

<style>
    body {
        background: #f0f7ff;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        margin: 0;
    }

    /* --- KHUNG THÔNG TIN BÀI TEST --- */
    .test-intro-container {
        max-width: 650px;
        margin: 60px auto;
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        overflow: hidden;
        text-align: center;
        border-top: 8px solid #0d6efd;
    }

    .test-header {
        padding: 30px 20px 10px 20px;
    }

    .test-icon {
        font-size: 60px;
        margin-bottom: 15px;
    }

    .test-title {
        color: #0d6efd;
        font-size: 28px;
        font-weight: 800;
        margin: 0;
        text-transform: uppercase;
    }

    .test-subtitle {
        color: #666;
        font-size: 16px;
        margin-top: 10px;
    }

    .rules-box {
        background: #f8f9fa;
        margin: 20px 40px;
        padding: 25px 30px;
        border-radius: 15px;
        text-align: left;
        border: 1px solid #e9ecef;
    }

        .rules-box ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .rules-box li {
            margin-bottom: 15px;
            font-size: 16px;
            color: #333;
            display: flex;
            align-items: flex-start;
            line-height: 1.5;
        }

            .rules-box li:last-child {
                margin-bottom: 0;
            }

    .rule-icon {
        margin-right: 12px;
        font-size: 20px;
    }

    .btn-container {
        padding: 20px 0 40px 0;
    }

    .start-btn {
        background: linear-gradient(135deg, #0d6efd, #4786e3);
        color: white;
        padding: 16px 45px;
        font-size: 20px;
        font-weight: bold;
        border: none;
        border-radius: 50px;
        cursor: pointer;
        box-shadow: 0 6px 15px rgba(13, 110, 253, 0.3);
        transition: all 0.3s ease;
    }

        .start-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(13, 110, 253, 0.4);
        }

    /* --- POPUP XÁC NHẬN (MODAL) --- */
    .modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.6);
        backdrop-filter: blur(5px);
        z-index: 9999;
        align-items: center;
        justify-content: center;
    }

    .modal-box {
        background: white;
        padding: 40px;
        border-radius: 20px;
        width: 400px;
        text-align: center;
        box-shadow: 0 15px 40px rgba(0,0,0,0.2);
        animation: popUp 0.3s ease-out;
    }

    @@keyframes popUp {
        from {
            transform: scale(0.8);
            opacity: 0;
        }

        to {
            transform: scale(1);
            opacity: 1;
        }
    }

    .modal-title {
        font-size: 24px;
        font-weight: bold;
        color: #333;
        margin-bottom: 10px;
    }

    .modal-text {
        color: #666;
        margin-bottom: 25px;
        font-size: 16px;
    }

    .test-info-tags {
        display: flex;
        justify-content: center;
        gap: 15px;
        margin-bottom: 30px;
    }

    .info-tag {
        background: #eef7ff;
        color: #0d6efd;
        padding: 10px 15px;
        border-radius: 10px;
        font-weight: bold;
        font-size: 15px;
        border: 1px solid #cce5ff;
    }

    .modal-buttons {
        display: flex;
        justify-content: center;
        gap: 15px;
    }

    .btn-cancel {
        background: #f8f9fa;
        color: #555;
        padding: 12px 25px;
        border: 1px solid #ccc;
        border-radius: 10px;
        font-weight: bold;
        cursor: pointer;
        transition: 0.2s;
        flex: 1;
    }

        .btn-cancel:hover {
            background: #e2e6ea;
        }

    .btn-confirm {
        background: #28a745;
        color: white;
        padding: 12px 25px;
        border: none;
        border-radius: 10px;
        font-weight: bold;
        cursor: pointer;
        transition: 0.2s;
        flex: 1;
        box-shadow: 0 4px 10px rgba(40, 167, 69, 0.3);
    }

        .btn-confirm:hover {
            background: #218838;
            transform: translateY(-2px);
        }
</style>

<div class="test-intro-container">
    <div class="test-header">
        <div class="test-icon">🎯</div>
        <h1 class="test-title">@Model.tieu_de</h1>
        <div class="test-subtitle">Đánh giá chính xác trình độ tiếng Anh của bạn</div>
    </div>

    <div class="rules-box">
        <div style="font-size: 16px; color: #333; line-height: 1.6;">
            @if (!string.IsNullOrEmpty(Model.mo_ta))
            {
                @Html.Raw(Model.mo_ta.Replace("\n", "<br />"))
            }
            else
            {
                <p>Chưa có hướng dẫn cho bài kiểm tra này.</p>
            }
        </div>
    </div>

    <div class="btn-container">
        <button class="start-btn" onclick="MoXacNhan()">Bắt đầu làm bài 🚀</button>
    </div>
</div>

<div class="modal-overlay" id="confirmModal">
    <div class="modal-box">
        <div class="modal-title">Bạn đã sẵn sàng?</div>
        <div class="modal-text">Thời gian sẽ bắt đầu đếm ngược ngay khi bạn bấm nút Bắt đầu. Hãy tập trung nhé!</div>

        <div class="test-info-tags">
            <div class="info-tag">⏱️ @Model.thoi_gian_phut Phút</div>
            <div class="info-tag">📝 @ViewBag.TongSoCau Câu hỏi</div>
        </div>

        <div class="modal-buttons">
            <button class="btn-cancel" onclick="DongXacNhan()">Chưa, từ từ</button>
            <button class="btn-confirm" onclick="VaoLamBai()">Bắt đầu ngay!</button>
        </div>
    </div>
</div>
<script>
    // Hàm mở bảng xác nhận
    function MoXacNhan() {
        document.getElementById("confirmModal").style.display = "flex";
    }

    // Hàm đóng bảng xác nhận
    function DongXacNhan() {
        document.getElementById("confirmModal").style.display = "none";
    }

    // Hàm chuyển sang trang làm bài thi khi bấm "Bắt đầu ngay!"
    function VaoLamBai() {
        // Đổi chữ trên nút để tạo hiệu ứng đang tải
        document.querySelector(".btn-confirm").innerHTML = "Đang tải...";
        document.querySelector(".btn-confirm").style.opacity = "0.8";

        // Chuyển hướng
        location.href = '@Url.Action("bai_test", "bai_test")';
    }
</script>