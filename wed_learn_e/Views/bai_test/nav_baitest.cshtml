@{
    Layout = null;
}

<style>
    body {
        margin: 0;
        font-family: Arial;
        padding-top: 80px;
    }

    /* Đã gộp 2 thẻ nav lại cho gọn và tránh lỗi giao diện */
    nav {
        position: fixed;
        top: 0px;
        width: 100%;
        z-index: 1000;
        display: flex;
        justify-content: space-between;
        background: linear-gradient(360deg, #e5e5e5, #00aaff);
        padding: 20px 25px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.1);
        box-sizing: border-box; /* Thêm dòng này để width 100% không bị tràn màn hình */
    }

        nav ul {
            list-style: none;
            display: flex;
            margin: 0;
            padding: 0;
            align-items: center; /* Căn giữa chữ theo chiều dọc */
        }

            nav ul li {
                margin-right: 20px;
            }

        nav a {
            text-decoration: none;
            padding: 10px;
            color: #1f3f52;
            font-weight: 700;
            transition: 0.3s;
        }

            nav a:hover {
                color: white; /* Đổi màu hover sang trắng cho nổi bật trên nền xanh */
            }
    .logo {
        position: relative; /* Làm gốc tọa độ cho 2 ảnh bên trong */
        width: 80px; /* Khai báo chiều rộng cụ thể */
        height: 65px; /* Khai báo chiều cao (tùy chỉnh theo ảnh của bạn) */
        display: inline-block; /* Giúp khung bao quanh sát vào ảnh */
        cursor: pointer;
        pointer-events: auto; /* Chỉ cho phép tương tác tại khung logo */
    }

        .logo img {
            position: absolute; /* Chồng 2 ảnh lên nhau */
            top: 0;
            left: 0;
            width: 160px;
            transition: opacity 0.6s ease; /* Thời gian chuyển từ từ (0.6 giây) */
        }

        /* Ảnh 2 mặc định sẽ bị ẩn đi */
        .logo .img-2 {
            opacity: 0;
            z-index: 2; /* Nằm trên ảnh 1 */
        }

        /* Ảnh 1 mặc định hiện ra */
        .logo .img-1 {
            opacity: 1;
            z-index: 1;
        }

        /* Khi rà chuột vào khu vực .logo */
        .logo:hover .img-2 {
            opacity: 1; /* Hiện ảnh 2 lên */
        }

        .logo:hover .img-1 {
            opacity: 0; /* Ẩn ảnh 1 đi */
        }
</style>

<nav>
    <ul>
        <div class="logo">
            <img src="@Url.Content("~/Img/Gemini_Generated_Image_khrd5ikhrd5ikhrd-removebg-preview.png")"
                 class="img-1" alt="">
            <img src="@Url.Content("~/Img/Gemini_Generated_Image_pj8wj4pj8wj4pj8w-removebg-preview.png")"
                 class="img-2" alt="" onclick="location.href='@Url.Action("Index","Trang_chu")'">
        </div>
    </ul>
    <ul>
        @if (Session["TenDN"] != null)
        {
            <li><a href="@Url.Action("thong_tin_bai_test", "bai_test")">Bài test</a></li>
            <li><a href="@Url.Action("khoadaotao", "Page")">Khóa đào tạo</a></li>

            <li>
                <a href="@Url.Action("TrangCaNhan", "User")" style="color: #d4edda;">
                    👤 Xin chào: @Session["HoTen"]
                </a>
            </li>
            <li><a href="@Url.Action("DangXuat", "User")">Đăng xuất</a></li>
        }
        else
        {
            <li>
                <a href="@Url.Action("DangNhap", "User")" onclick="alert('Vui lòng đăng nhập để làm Bài test!');">Bài test</a>
            </li>
            <li>
                <a href="@Url.Action("DangNhap", "User")" onclick="alert('Vui lòng đăng nhập để xem Khóa đào tạo!');">Khóa đào tạo</a>
            </li>

            <li>
                <a href="@Url.Action("DangNhap", "User")" style="background: #1f3f52; color: white; border-radius: 5px;">Đăng nhập</a>
            </li>
        }
    </ul>
</nav>