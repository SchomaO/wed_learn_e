@model wed_learn_e.Models.nguoi_dung

@{
    ViewBag.Title = "Nâng cấp VIP";
    Layout = "~/Views/Shared/_Layoutcauhoi.cshtml";
}

<style>
    body { background: #f4f7f6; font-family: Arial; }

    /* --- KHUNG BẢNG GIÁ --- */
    .pricing-header { text-align: center; margin: 40px 0; }
    .pricing-header h2 { color: #0d6efd; font-size: 32px; font-weight: bold; }
    .pricing-header p { color: #666; font-size: 16px; }

    .pricing-container { display: flex; justify-content: center; gap: 40px; flex-wrap: wrap; margin-bottom: 50px; }

    .pricing-card {
        background: white; width: 320px; border-radius: 20px; padding: 30px 20px;
        text-align: center; position: relative; transition: 0.3s;
        display: flex; flex-direction: column; justify-content: space-between;
    }

    .pricing-card:hover { transform: translateY(-10px); }

    /* Gói Tháng (Xanh) */
    .card-green { border-top: 8px solid #28a745; box-shadow: 0 10px 20px rgba(0,0,0,0.05); }
    .card-green .pkg-name { color: #28a745; }
    .card-green .btn-buy { background: #28a745; }
    .card-green .btn-buy:hover { background: #218838; }

    /* Gói Năm (Vàng + Viền sáng) */
    .card-yellow {
        border-top: 8px solid #ffc107;
        /* Hiệu ứng viền sáng (Glow) */
        box-shadow: 0 0 25px rgba(255, 193, 7, 0.6);
        transform: scale(1.05); /* Cho gói năm to lên một tí để nổi bật */
    }
    .card-yellow .pkg-name { color: #d39e00; }
    .card-yellow .btn-buy { background: #ffc107; color: #000; }
    .card-yellow .btn-buy:hover { background: #e0a800; }
    .best-value { position: absolute; top: -15px; right: -15px; background: #dc3545; color: white; padding: 5px 15px; border-radius: 20px; font-weight: bold; font-size: 14px; box-shadow: 0 4px 8px rgba(0,0,0,0.2); }

    .pkg-name { font-size: 24px; font-weight: bold; margin-bottom: 15px; text-transform: uppercase; }
    .pkg-price { font-size: 35px; font-weight: bold; color: #333; margin-bottom: 20px; }
    .pkg-price span { font-size: 16px; color: #888; font-weight: normal; }

    .pkg-features { list-style: none; padding: 0; margin: 0 0 30px 0; text-align: left; }
    .pkg-features li { padding: 10px 0; border-bottom: 1px solid #eee; color: #555; }
    .pkg-features li::before { content: "✔"; color: #28a745; font-weight: bold; margin-right: 10px; }

    .btn-buy { color: white; padding: 15px; border: none; border-radius: 10px; font-size: 18px; font-weight: bold; cursor: pointer; width: 100%; transition: 0.3s; }

    /* --- POPUP THANH TOÁN (MODAL) --- */
    .checkout-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 9999; justify-content: center; align-items: center; }
    .checkout-box { background: white; padding: 30px; border-radius: 15px; width: 450px; max-width: 90%; box-shadow: 0 10px 30px rgba(0,0,0,0.3); animation: slideDown 0.3s ease; }
    .checkout-title { font-size: 22px; font-weight: bold; margin-bottom: 20px; color: #333; text-align: center; border-bottom: 2px solid #eee; padding-bottom: 10px; }

    .form-group { margin-bottom: 15px; }
    .form-group label { display: block; font-weight: bold; margin-bottom: 5px; color: #555; }
    .form-group input, .form-group select { width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 5px; font-size: 15px; box-sizing: border-box; }
    .form-group input[readonly] { background: #e9ecef; color: #666; cursor: not-allowed; }

    .checkout-actions { display: flex; gap: 10px; margin-top: 25px; }
    .btn-action { flex: 1; padding: 12px; border: none; border-radius: 8px; font-weight: bold; cursor: pointer; font-size: 16px; }
    .btn-cancel { background: #ccc; color: #333; }
    .btn-cancel:hover { background: #bbb; }
    .btn-pay { background: #0d6efd; color: white; }
    .btn-pay:hover { background: #0b5ed7; }

    /* Màn hình thành công */
    #successScreen { display: none; text-align: center; }
    .icon-success { font-size: 60px; color: #28a745; margin-bottom: 15px; }

   /* Màn hình thành công */
#successScreen { display: none; text-align: center; }
.icon-success { font-size: 60px; color: #28a745; margin-bottom: 15px; }

/* SỬA Ở DÒNG NÀY: Thêm 1 dấu  */
@@keyframes slideDown { from { transform: translateY(-30px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
</style>

<div class="pricing-header">
    <h2>Nâng Cấp Tài Khoản VIP</h2>
    <p>Học tiếng Anh không giới hạn, mở khóa toàn bộ lộ trình từ A1 đến C2.</p>
</div>

<div class="pricing-container">
    <div class="pricing-card card-green">
        <div>
            <div class="pkg-name">VIP 1 Tháng</div>
            <div class="pkg-price">
                @(HttpContext.Current.Application["GiaVipThang"] != null ? string.Format("{0:N0}", HttpContext.Current.Application["GiaVipThang"]) : "99,000")đ
                <span>/tháng</span>
            </div>
            <ul class="pkg-features">
                <li>Mở khóa tất cả bài học</li>
                <li>Luyện nói với AI không giới hạn</li>
                <li>Hỗ trợ giải đáp 24/7</li>
            </ul>
        </div>
        <button class="btn-buy" onclick="moKhungThanhToan('VIP 1 Tháng (99.000 VNĐ)', 'VIP_THANG')">Đăng ký ngay</button>
    </div>

    <div class="pricing-card card-yellow">
        <div class="best-value">HOT NHẤT</div>
        <div>
            <div class="pkg-name">VIP 1 Năm</div>
            <div class="pkg-price">
                @(HttpContext.Current.Application["GiaVipNam"] != null ? string.Format("{0:N0}", HttpContext.Current.Application["GiaVipNam"]) : "799,000")đ
                <span>/năm</span>
            </div>
            <ul class="pkg-features">
                <li>Tất cả đặc quyền VIP Tháng</li>
                <li>Tiết kiệm hơn 30% so với mua lẻ</li>
                <li>Huy hiệu VIP trên trang cá nhân</li>
                <li>Tặng bộ Ebook Từ vựng C2</li>
            </ul>
        </div>
        <button class="btn-buy" onclick="moKhungThanhToan('VIP 1 Năm (799.000 VNĐ)', 'VIP_NAM')">Đăng ký ngay</button>
    </div>
</div>

<div class="checkout-overlay" id="checkoutModal">
    <div class="checkout-box">

        <div id="checkoutForm">
            <div class="checkout-title">Xác nhận thanh toán</div>

            <div class="form-group">
                <label>Tài khoản đăng nhập:</label>
                <input type="text" value="@Model.ten_dang_nhap" readonly>
            </div>

            <div class="form-group">
                <label>Họ và tên người mua:</label>
                <input type="text" value="@Model.ho_va_ten" readonly>
            </div>

            <div class="form-group">
                <label>Email liên hệ:</label>
                <input type="text" value="@Model.email" readonly>
            </div>

            <div class="form-group">
                <label>Gói VIP đã chọn:</label>
                <input type="text" id="txtTenGoi" readonly style="font-weight:bold; color:#0d6efd;">
                <input type="hidden" id="txtMaGoi">
            </div>

            <div class="form-group">
                <label>Phương thức thanh toán:</label>
                <select id="cbPhuongThuc">
                    <option value="VNPAY">Thanh toán qua VNPAY</option>
                    <option value="MOMO">Ví điện tử MoMo</option>
                    <option value="BANK">Chuyển khoản ngân hàng</option>
                </select>
            </div>

            <div class="checkout-actions">
                <button class="btn-action btn-cancel" onclick="dongKhungThanhToan()">Hủy bỏ</button>
                <button class="btn-action btn-pay" id="btnXacNhan" onclick="tienHanhThanhToan()">Thanh Toán</button>
            </div>
        </div>

        <div id="successScreen">
            <div class="icon-success">✔</div>
            <h2 style="color:#28a745; margin-bottom: 10px;">Thanh toán thành công!</h2>
            <p style="color:#666; margin-bottom: 20px;">Tài khoản của bạn đã được nâng cấp lên hạng VIP. Bạn có thể học mọi khóa học không giới hạn.</p>
            <button class="btn-action btn-pay" style="width:100%" id="btnVeTrangChu">Quay lại khóa học</button>
        </div>

    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    // Mở popup
    function moKhungThanhToan(tenGoi, maGoi) {
        $("#txtTenGoi").val(tenGoi);
        $("#txtMaGoi").val(maGoi);
        $("#checkoutForm").show();
        $("#successScreen").hide();
        $("#checkoutModal").css("display", "flex");
    }

    // Đóng popup
    function dongKhungThanhToan() {
        $("#checkoutModal").css("display", "none");
    }

    // Xử lý AJAX Thanh toán
    function tienHanhThanhToan() {
        var maGoi = $("#txtMaGoi").val();
        var phuongThuc = $("#cbPhuongThuc").val();
        var btnPay = $("#btnXacNhan");

        // Đổi chữ nút thành Đang xử lý để nhìn chuyên nghiệp
        btnPay.text("Đang xử lý...");
        btnPay.css("opacity", "0.7");
        btnPay.prop("disabled", true);

        // Chạy AJAX
        $.ajax({
            url: '@Url.Action("XuLyThanhToan", "Page")',
            type: 'POST',
            data: {
                goi_vip: maGoi,
                phuong_thuc: phuongThuc
            },
            success: function (res) {
                if (res.success) {
                    // Thành công -> Đổi khung giao diện sang màn hình báo tick xanh
                    $("#checkoutForm").hide();
                    $("#successScreen").fadeIn();

                    // Gắn link cho nút Quay về
                    $("#btnVeTrangChu").click(function() {
                        window.location.href = res.redirect;
                    });
                } else {
                    alert(res.message);
                    btnPay.text("Thanh Toán");
                    btnPay.css("opacity", "1");
                    btnPay.prop("disabled", false);
                }
            },
            error: function () {
                alert("Lỗi kết nối đến máy chủ thanh toán!");
                btnPay.text("Thanh Toán");
                btnPay.css("opacity", "1");
                btnPay.prop("disabled", false);
            }
        });
    }
</script>