@{
    ViewBag.Title = "dangnhap";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

<div class="title">
    <button class="close-btn" onclick="location.href='@Url.Action("Index","Trang_chu")'">
        <span>×</span>
    </button>

    <h2>Đăng nhập</h2>
</div>

<div class="content">
    <h2>Đăng nhập tài khoản</h2>

    @using (Html.BeginForm("dangnhap", "User", FormMethod.Post))
    {
        <table>

            <tr>
                <td class="canle_dk_noidung">Tên đăng nhập:</td>
                <td><input type="text" name="TenDN"></td>
            </tr>

            <tr>
                <td class="canle_dk_noidung">Mật khẩu:</td>
                <td><input type="password" name="MatKhau"></td>
            </tr>


        </table>
    <p style="color:red">@ViewBag.ThongBao</p>
        <div style="height: 30px; text-align: justify; margin-left: 21px; ">
            <input type="checkbox" name="RememberMe" style=" padding: 0px 0px 5px 5px; width: 40px; margin-top: 10px; " > <span>Lưu đăng nhập </span>
        </div>

        

        <button type="submit">Đăng nhập</button>
    }

    <p>
        Bạn chưa có tài khoản?
        <a href="@Url.Action("Index","User")">Đăng ký ngay</a>
    </p>

    <div style="display:flex; gap:10px;">
        <button class="email">Đăng nhập bằng email</button>
        <button class="email">Đăng nhập bằng gg</button>
    </div>

</div>