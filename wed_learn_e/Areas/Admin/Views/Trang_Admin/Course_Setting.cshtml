@model IEnumerable<wed_learn_e.Models.cap_do>
@{
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid py-4">
    <div class="flex flex-col md:flex-row gap-6">

        <div class="w-full md:w-1/3 lg:w-1/4">
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                <div class="p-4 bg-indigo-50 border-b border-gray-200 flex justify-between items-center">
                    <h3 class="font-bold text-indigo-900">Cấp độ học</h3>
                    <button onclick="openModalAddLevel()" class="bg-indigo-600 text-white p-2 rounded-lg hover:bg-indigo-700 transition">
                        <i class="fas fa-plus"></i>
                    </button>
                </div>
                <div class="divide-y divide-gray-100 max-h-[70vh] overflow-y-auto">
                    @foreach (var item in Model)
                    {
                        <div class="p-4 hover:bg-gray-50 cursor-pointer transition level-item" id="level-@item.id_cap_do"
                             onclick="loadFullData(@item.id_cap_do, '@item.ten_cap_do')">
                            <div class="flex justify-between items-start">
                                <span class="text-xs font-bold text-indigo-500 uppercase">#@item.id_cap_do</span>
                                <button onclick="event.stopPropagation(); deleteLevel(@item.id_cap_do)" class="text-gray-400 hover:text-red-500">
                                    <i class="fas fa-trash-alt text-xs"></i>
                                </button>
                            </div>
                            <h4 class="font-semibold text-gray-800">@item.ten_cap_do</h4>
                            <p class="text-xs text-gray-500 truncate">@item.mo_ta</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="w-full md:w-2/3 lg:w-3/4">
            <div id="empty-state" class="bg-white rounded-xl shadow-sm border-2 border-dashed border-gray-300 p-20 text-center">
                <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="fas fa-mouse-pointer text-gray-400 text-3xl"></i>
                </div>
                <h3 class="text-xl font-medium text-gray-600">Chọn một cấp độ để bắt đầu</h3>
                <p class="text-gray-400 mt-2">Toàn bộ bài học, game và test sẽ hiện ở đây.</p>
            </div>

            <div id="main-panel" class="hidden animate-fade-in">
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                    <div class="p-6 border-b border-gray-200 flex justify-between items-center bg-white sticky top-0 z-10">
                        <h2 class="text-2xl font-bold text-gray-800" id="current-level-name">Tên Cấp Độ</h2>
                        <div class="flex gap-2" id="group-btns-add"></div>
                    </div>

                    <div class="flex border-b border-gray-200 bg-gray-50 overflow-x-auto whitespace-nowrap">
                        <button onclick="switchTab('khoa-hoc')" class="tab-link px-5 py-3 text-sm font-bold border-b-2 border-transparent text-gray-500 hover:text-indigo-600" id="link-khoa-hoc">📂 Khóa Học</button>
                        <button onclick="switchTab('tu-vung')" class="tab-link px-5 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-indigo-600" id="link-tu-vung">📖 Từ Vựng</button>
                        <button onclick="switchTab('thanh-ngu')" class="tab-link px-5 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-indigo-600" id="link-thanh-ngu">💡Thành Ngữ</button>
                        <button onclick="switchTab('noi')" class="tab-link px-5 py-3 text-sm font-medium border-b-2 border-indigo-600 text-indigo-600" id="link-noi">🗣️ Luyện Nói</button>
                        <button onclick="switchTab('nghe')" class="tab-link px-5 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-indigo-600" id="link-nghe">🎧 Luyện Nghe</button>
                        <button onclick="switchTab('ngu-phap')" class="tab-link px-5 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-indigo-600" id="link-ngu-phap">📚 Ngữ Pháp</button>
                        <button onclick="switchTab('video')" class="tab-link px-5 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-indigo-600" id="link-video">🎬 Học Video</button>
                        <button onclick="switchTab('viet')" class="tab-link px-5 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-indigo-600" id="link-viet">✍️ Luyện Viết</button>
                        <button onclick="switchTab('game')" class="tab-link px-5 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-indigo-600" id="link-game">🏴‍☠️Mini Game</button>
                        <button onclick="switchTab('mini-test')" class="tab-link px-5 py-3 text-sm font-medium border-b-2 border-transparent text-pink-500 hover:text-pink-600 bg-pink-50" id="link-mini-test">📝 Mini Test (Hằng ngày)</button>
                    </div>

                    <div class="p-6">
                        <div id="content-khoa-hoc" class="tab-content hidden"><div id="list-khoa-hoc" class="grid grid-cols-1 md:grid-cols-2 gap-4"></div></div>
                        <div id="content-tu-vung" class="tab-content hidden overflow-x-auto"><table class="w-full text-left border-collapse bg-white"><thead><tr class="bg-gray-50 border-b border-gray-200"><th class="p-4 text-xs font-bold uppercase text-gray-500">Từ vựng (EN)</th><th class="p-4 text-xs font-bold uppercase text-gray-500">Nghĩa (VI)</th><th class="p-4 text-xs font-bold uppercase text-gray-500 text-right">Thao tác</th></tr></thead><tbody id="tbody-tu-vung" class="divide-y divide-gray-100"></tbody></table></div>
                        <div id="content-thanh-ngu" class="tab-content hidden overflow-x-auto"><table class="w-full text-left border-collapse bg-white"><thead><tr class="bg-gray-50 border-b border-gray-200"><th class="p-4 text-xs font-bold uppercase text-gray-500">Thành ngữ (EN)</th><th class="p-4 text-xs font-bold uppercase text-gray-500">Nghĩa (VI)</th><th class="p-4 text-xs font-bold uppercase text-gray-500 text-right">Thao tác</th></tr></thead><tbody id="tbody-thanh-ngu" class="divide-y divide-gray-100"></tbody></table></div>
                        <div id="content-noi" class="tab-content hidden overflow-x-auto"><table class="w-full text-left border-collapse bg-white"><thead><tr class="bg-gray-50 border-b"><th class="p-4 text-xs font-bold uppercase text-gray-500">Nội dung câu / Từ vựng</th><th class="p-4 text-xs font-bold uppercase text-gray-500 text-right">Thao tác</th></tr></thead><tbody id="tbody-noi" class="divide-y divide-gray-100"></tbody></table></div>
                        <div id="content-nghe" class="tab-content hidden"><div id="list-nghe" class="grid grid-cols-1 sm:grid-cols-2 gap-4"></div></div>
                        <div id="content-ngu-phap" class="tab-content hidden"><div id="list-ngu-phap" class="grid grid-cols-1 md:grid-cols-2 gap-4"></div></div>
                        <div id="content-game" class="tab-content hidden"><div id="list-game" class="grid grid-cols-1 sm:grid-cols-2 gap-4"></div></div>
                        <div id="content-viet" class="tab-content hidden"><div id="list-viet" class="space-y-4"></div></div>
                        <div id="content-video" class="tab-content hidden"><div id="list-video" class="grid grid-cols-1 sm:grid-cols-2 gap-4"></div></div>
                        <div id="content-mini-test" class="tab-content hidden"><div id="list-mini-test" class="space-y-4"></div></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="modalAddLevel" class="fixed inset-0 z-[9999] hidden bg-black/60 backdrop-blur-sm pointer-events-auto">
    <div class="flex items-center justify-center min-h-screen w-full p-4">
        <div class="bg-white w-full max-w-md rounded-2xl shadow-2xl overflow-hidden relative">
            <button type="button" onclick="closeModalLevel()" class="absolute top-4 right-4 text-gray-400 hover:text-red-500 z-50 p-2 transition-colors"><i class="fas fa-times text-xl"></i></button>
            <div class="p-6 border-b border-gray-100 bg-indigo-50/50"><h3 class="text-xl font-bold text-indigo-900">✨ Thêm Cấp Độ Mới</h3></div>
            <div class="p-6 space-y-4">
                <div><label class="block text-xs font-bold text-gray-500 uppercase mb-1">Tên cấp độ</label><input type="text" id="txtLevelName" placeholder="Ví dụ: A1 - Căn bản..." class="w-full border-2 border-gray-100 rounded-xl p-3 focus:border-indigo-500 outline-none"></div>
                <div><label class="block text-xs font-bold text-gray-500 uppercase mb-1">Mô tả ngắn</label><textarea id="txtLevelDesc" rows="3" class="w-full border-2 border-gray-100 rounded-xl p-3 focus:border-indigo-500 outline-none"></textarea></div>
            </div>
            <div class="p-6 border-t border-gray-50 flex gap-3"><button type="button" onclick="closeModalLevel()" class="flex-1 py-3 font-bold text-gray-500 hover:bg-gray-100 rounded-xl">Hủy</button><button type="button" onclick="saveLevel()" class="flex-1 py-3 font-bold text-white bg-indigo-600 hover:bg-indigo-700 rounded-xl shadow-lg">Lưu cấp độ</button></div>
        </div>
    </div>
</div>

<div id="modalAddContent" class="fixed inset-0 z-[9999] hidden bg-black/60 backdrop-blur-sm items-center justify-center pointer-events-auto">
    <div class="bg-white w-full max-w-lg rounded-2xl shadow-2xl overflow-hidden transform transition-all relative">
        <div class="p-6 border-b border-gray-100 bg-indigo-50/50 flex justify-between items-center"><h3 class="text-xl font-bold text-indigo-900" id="modalContentTitle">✨ Thêm nội dung</h3><button type="button" onclick="closeAddContentModal()" class="text-gray-400 hover:text-red-500 transition-colors"><i class="fas fa-times text-xl"></i></button></div>
        <div class="p-6 space-y-4">
            <div id="box-khoa-hoc"><label class="block text-xs font-bold text-gray-500 uppercase mb-1">Thuộc Khóa Học Nào?</label><select id="cboKhoaHoc" class="w-full border-2 border-gray-100 rounded-xl p-3 focus:border-indigo-500 outline-none"></select></div>
            <div><label id="lblData1" class="block text-xs font-bold text-gray-500 uppercase mb-1">Trường dữ liệu 1</label><input type="text" id="txtData1" class="w-full border-2 border-gray-100 rounded-xl p-3 focus:border-indigo-500 outline-none"></div>

            <div id="box-data2-textarea">
                <label id="lblData2" class="block text-xs font-bold text-gray-500 uppercase mb-1">Trường dữ liệu 2</label>
                <textarea id="txtData2" rows="2" class="w-full border-2 border-gray-100 rounded-xl p-3 focus:border-indigo-500 outline-none"></textarea>
            </div>
            <div id="box-data2-date" class="hidden">
                <label id="lblData2_Date" class="block text-xs font-bold text-pink-500 uppercase mb-1">Chọn ngày áp dụng</label>
                <input type="date" id="txtData2_Date" class="w-full border-2 border-pink-200 rounded-xl p-3 focus:border-pink-500 outline-none font-bold text-gray-700">
            </div>

            <div id="box-data3" class="hidden"><label id="lblData3" class="block text-xs font-bold text-gray-500 uppercase mb-1">Trường dữ liệu 3</label><input type="text" id="txtData3" class="w-full border-2 border-gray-100 rounded-xl p-3 focus:border-indigo-500 outline-none"></div>
            <div id="box-data4" class="hidden"><label id="lblData4" class="block text-xs font-bold text-gray-500 uppercase mb-1">Trường dữ liệu 4</label><input type="text" id="txtData4" class="w-full border-2 border-gray-100 rounded-xl p-3 focus:border-indigo-500 outline-none"></div>
        </div>
        <div class="p-6 border-t border-gray-50 flex gap-3"><button type="button" onclick="closeAddContentModal()" class="flex-1 py-3 font-bold text-gray-500 hover:bg-gray-100 rounded-xl">Hủy</button><button type="button" onclick="submitContentModal()" class="flex-1 py-3 font-bold text-white bg-indigo-600 hover:bg-indigo-700 rounded-xl shadow-lg">Lưu nội dung</button></div>
    </div>
</div>

<div id="modalCourseInfo" class="fixed inset-0 z-[9999] hidden bg-black/60 backdrop-blur-sm items-center justify-center p-4">
    <div class="bg-white w-full max-w-5xl rounded-2xl shadow-2xl relative flex flex-col h-[90vh]">
        <div class="p-5 border-b bg-indigo-50 flex justify-between items-center rounded-t-2xl"><h3 class="text-xl font-bold text-indigo-900"><i class="fas fa-file-alt mr-2"></i> Nội dung khóa: <span id="infoCourseName" class="text-indigo-600"></span></h3><button onclick="closeCourseInfo()"><i class="fas fa-times text-xl"></i></button></div>
        <div class="p-6 overflow-y-auto flex-1 flex flex-col gap-6">
            <div class="bg-gray-50 p-4 border border-gray-200 rounded-xl">
                <div class="flex justify-between items-center mb-3"><label class="font-bold text-gray-700 uppercase text-sm">Soạn thảo nội dung mới</label><button onclick="saveCourseInfo()" class="bg-indigo-600 text-white px-5 py-2 rounded-lg font-bold hover:bg-indigo-700 shadow-md"><i class="fas fa-save mr-1"></i> Lưu Bài</button></div>
                <textarea id="txtCourseRichText" name="txtCourseRichText"></textarea>
            </div>
            <div><h4 class="font-bold text-gray-700 border-b pb-2 mb-3">Danh sách bài đã thêm vào khóa này</h4><div id="listCourseInfos" class="space-y-4"></div></div>
        </div>
    </div>
</div>

<div id="modalQuestionNghe" class="fixed inset-0 z-[9999] hidden bg-black/60 backdrop-blur-sm items-center justify-center p-4"><div class="bg-white w-full max-w-5xl rounded-2xl shadow-2xl relative flex flex-col h-[90vh]"><div class="p-5 border-b bg-blue-50 flex justify-between items-center rounded-t-2xl"><h3 class="text-xl font-bold text-blue-900"><i class="fas fa-headphones mr-2"></i> Câu hỏi bài nghe: <span id="ngheTitleLabel" class="text-blue-600"></span></h3><button onclick="closeQuestionNghe()" class="text-gray-400 hover:text-red-500"><i class="fas fa-times text-xl"></i></button></div><div class="p-6 flex-1 flex flex-col md:flex-row gap-6 bg-gray-50 overflow-hidden"><div class="w-full md:w-1/3 bg-white p-5 rounded-xl border border-gray-200 shadow-sm h-full overflow-y-auto"><h4 class="font-bold text-gray-800 mb-4 border-b pb-2" id="formQuestionNgheTitle">Thêm Câu Hỏi Mới</h4><div class="space-y-3"><div><label class="text-xs font-bold text-gray-500">Nội dung câu hỏi</label><textarea id="txtQ_NoiDung" rows="2" class="w-full border rounded-lg p-2 mt-1"></textarea></div><div><label class="text-xs font-bold text-gray-500">Đáp án A</label><input type="text" id="txtQ_A" class="w-full border rounded-lg p-2 mt-1"></div><div><label class="text-xs font-bold text-gray-500">Đáp án B</label><input type="text" id="txtQ_B" class="w-full border rounded-lg p-2 mt-1"></div><div><label class="text-xs font-bold text-gray-500">Đáp án C</label><input type="text" id="txtQ_C" class="w-full border rounded-lg p-2 mt-1"></div><div><label class="text-xs font-bold text-gray-500">Đáp án D</label><input type="text" id="txtQ_D" class="w-full border rounded-lg p-2 mt-1"></div><div><label class="text-xs font-bold text-gray-500">Đáp án ĐÚNG (A, B, C, D)</label><select id="cboQ_Dung" class="w-full border rounded-lg p-2 mt-1 font-bold"><option value="A">A</option><option value="B">B</option><option value="C">C</option><option value="D">D</option></select></div><div class="flex gap-2 pt-2"><button onclick="resetFormCauHoiNghe()" class="flex-1 bg-gray-200 text-gray-700 py-2 rounded-lg font-bold">Hủy</button><button onclick="saveCauHoiNghe()" class="flex-1 bg-blue-600 text-white py-2 rounded-lg font-bold">Lưu Câu Hỏi</button></div></div></div><div class="w-full md:w-2/3 bg-white p-5 rounded-xl border border-gray-200 shadow-sm h-full overflow-y-auto"><h4 class="font-bold text-gray-800 mb-4 border-b pb-2 sticky top-0 bg-white z-10">Danh sách câu hỏi</h4><div id="listQuestionNghe" class="space-y-3"></div></div></div></div></div>

<div id="modalQuestionVideo" class="fixed inset-0 z-[9999] hidden bg-black/60 backdrop-blur-sm items-center justify-center p-4"><div class="bg-white w-full max-w-5xl rounded-2xl shadow-2xl relative flex flex-col h-[90vh]"><div class="p-5 border-b bg-red-50 flex justify-between items-center rounded-t-2xl"><h3 class="text-xl font-bold text-red-900"><i class="fas fa-play-circle mr-2"></i> Câu hỏi Video: <span id="videoTitleLabel" class="text-red-600"></span></h3><button onclick="closeQuestionVideo()" class="text-gray-400 hover:text-red-500"><i class="fas fa-times text-xl"></i></button></div><div class="p-6 flex-1 flex flex-col md:flex-row gap-6 bg-gray-50 overflow-hidden"><div class="w-full md:w-1/3 bg-white p-5 rounded-xl border border-gray-200 shadow-sm h-full overflow-y-auto"><h4 class="font-bold text-gray-800 mb-4 border-b pb-2" id="formQuestionVideoTitle">Thêm Câu Hỏi Mới</h4><div class="space-y-3"><div><label class="text-xs font-bold text-gray-500">Nội dung câu hỏi</label><textarea id="txtQV_NoiDung" rows="2" class="w-full border rounded-lg p-2 mt-1"></textarea></div><div><label class="text-xs font-bold text-gray-500">Đáp án A</label><input type="text" id="txtQV_A" class="w-full border rounded-lg p-2 mt-1"></div><div><label class="text-xs font-bold text-gray-500">Đáp án B</label><input type="text" id="txtQV_B" class="w-full border rounded-lg p-2 mt-1"></div><div><label class="text-xs font-bold text-gray-500">Đáp án C</label><input type="text" id="txtQV_C" class="w-full border rounded-lg p-2 mt-1"></div><div><label class="text-xs font-bold text-gray-500">Đáp án D</label><input type="text" id="txtQV_D" class="w-full border rounded-lg p-2 mt-1"></div><div><label class="text-xs font-bold text-gray-500">Đáp án ĐÚNG</label><select id="cboQV_Dung" class="w-full border rounded-lg p-2 mt-1 font-bold"><option value="A">A</option><option value="B">B</option><option value="C">C</option><option value="D">D</option></select></div><div class="flex gap-2 pt-2"><button onclick="resetFormCauHoiVideo()" class="flex-1 bg-gray-200 text-gray-700 py-2 rounded-lg font-bold">Hủy</button><button onclick="saveCauHoiVideo()" class="flex-1 bg-red-600 text-white py-2 rounded-lg font-bold">Lưu Câu Hỏi</button></div></div></div><div class="w-full md:w-2/3 bg-white p-5 rounded-xl border border-gray-200 shadow-sm h-full overflow-y-auto"><h4 class="font-bold text-gray-800 mb-4 border-b pb-2 sticky top-0 bg-white z-10">Danh sách câu hỏi trong Video</h4><div id="listQuestionVideo" class="space-y-3"></div></div></div></div></div>

<div id="modalQuestionViet" class="fixed inset-0 z-[9999] hidden bg-black/60 backdrop-blur-sm items-center justify-center p-4"><div class="bg-white w-full max-w-4xl rounded-2xl shadow-2xl relative flex flex-col h-[80vh]"><div class="p-5 border-b bg-purple-50 flex justify-between items-center rounded-t-2xl"><h3 class="text-xl font-bold text-purple-900"><i class="fas fa-pen mr-2"></i> Câu hỏi Bài Viết: <span id="vietTitleLabel" class="text-purple-600"></span></h3><button onclick="closeQuestionViet()" class="text-gray-400 hover:text-red-500"><i class="fas fa-times text-xl"></i></button></div><div class="p-6 flex-1 flex flex-col md:flex-row gap-6 bg-gray-50 overflow-hidden"><div class="w-full md:w-5/12 bg-white p-5 rounded-xl border border-gray-200 shadow-sm h-full overflow-y-auto"><h4 class="font-bold text-gray-800 mb-4 border-b pb-2" id="formQuestionVietTitle">Thêm Câu Hỏi Mới</h4><div class="space-y-4"><div><label class="text-xs font-bold text-gray-500">Câu Tiếng Việt (Đề bài)</label><textarea id="txtQViet_VN" rows="3" class="w-full border rounded-lg p-3 mt-1"></textarea></div><div><label class="text-xs font-bold text-gray-500">Đáp án Tiếng Anh</label><textarea id="txtQViet_EN" rows="3" class="w-full border rounded-lg p-3 mt-1"></textarea></div><div class="flex gap-2 pt-2"><button onclick="resetFormCauHoiViet()" class="flex-1 bg-gray-200 text-gray-700 py-2 rounded-lg font-bold">Hủy</button><button onclick="saveCauHoiViet()" class="flex-1 bg-purple-600 text-white py-2 rounded-lg font-bold">Lưu Câu Hỏi</button></div></div></div><div class="w-full md:w-7/12 bg-white p-5 rounded-xl border border-gray-200 shadow-sm h-full overflow-y-auto"><h4 class="font-bold text-gray-800 mb-4 border-b pb-2 sticky top-0 bg-white z-10">Danh sách câu hỏi luyện viết</h4><div id="listQuestionViet" class="space-y-3"></div></div></div></div></div>

<div id="modalQuestionGame" class="fixed inset-0 z-[9999] hidden bg-black/60 backdrop-blur-sm items-center justify-center p-4"><div class="bg-white w-full max-w-6xl rounded-2xl shadow-2xl relative flex flex-col h-[95vh]"><div class="p-5 border-b bg-yellow-50 flex justify-between items-center rounded-t-2xl"><h3 class="text-xl font-bold text-yellow-900"><i class="fas fa-gamepad mr-2"></i> Câu hỏi Game: <span id="gameTitleLabel" class="text-yellow-700"></span></h3><button onclick="closeQuestionGame()" class="text-gray-400 hover:text-red-500"><i class="fas fa-times text-xl"></i></button></div><div class="p-6 flex-1 flex flex-col md:flex-row gap-6 bg-gray-50 overflow-hidden"><div class="w-full md:w-4/12 bg-white p-5 rounded-xl border border-gray-200 shadow-sm h-full overflow-y-auto"><h4 class="font-bold text-gray-800 mb-4 border-b pb-2" id="formQuestionGameTitle">Thêm Câu Hỏi Mới</h4><div class="space-y-3"><div class="grid grid-cols-2 gap-3"><div><label class="text-xs font-bold text-gray-500">Thứ tự câu</label><input type="number" id="txtQG_ThuTu" value="1" class="w-full border rounded-lg p-2 mt-1"></div><div><label class="text-xs font-bold text-gray-500">Loại câu hỏi</label><input type="text" id="txtQG_Loai" placeholder="trac_nghiem" value="trac_nghiem" class="w-full border rounded-lg p-2 mt-1"></div></div><div><label class="text-xs font-bold text-gray-500">Nội dung câu hỏi</label><textarea id="txtQG_NoiDung" rows="2" class="w-full border rounded-lg p-2 mt-1"></textarea></div><div class="grid grid-cols-2 gap-3"><div><label class="text-xs font-bold text-gray-500">Đáp án A</label><input type="text" id="txtQG_A" class="w-full border rounded-lg p-2 mt-1"></div><div><label class="text-xs font-bold text-gray-500">Đáp án B</label><input type="text" id="txtQG_B" class="w-full border rounded-lg p-2 mt-1"></div><div><label class="text-xs font-bold text-gray-500">Đáp án C</label><input type="text" id="txtQG_C" class="w-full border rounded-lg p-2 mt-1"></div><div><label class="text-xs font-bold text-gray-500">Đáp án D</label><input type="text" id="txtQG_D" class="w-full border rounded-lg p-2 mt-1"></div></div><div class="grid grid-cols-2 gap-3"><div><div id="box-QG-SelectDung"><label class="text-xs font-bold text-gray-500">Đ.Án Đúng</label><select id="cboQG_Dung" class="w-full border rounded-lg p-2 mt-1 font-bold"><option value="A">A</option><option value="B">B</option><option value="C">C</option><option value="D">D</option></select></div><div id="box-QG-TextDung" class="hidden"><label class="text-xs font-bold text-gray-500">Đ.Án Đúng (Nhập)</label><input type="text" id="txtQG_DungText" class="w-full border rounded-lg p-2 mt-1 font-bold"></div></div><div><label class="text-xs font-bold text-gray-500">Mảnh ghép</label><input type="text" id="txtQG_ManhGhep" placeholder="Gợi ý..." class="w-full border rounded-lg p-2 mt-1"></div></div><div class="flex gap-2 pt-2"><button onclick="resetFormCauHoiGame()" class="flex-1 bg-gray-200 text-gray-700 py-2 rounded-lg font-bold">Hủy</button><button onclick="saveCauHoiGame()" class="flex-1 bg-yellow-500 hover:bg-yellow-600 text-white py-2 rounded-lg font-bold shadow-md">Lưu Câu</button></div></div></div><div class="w-full md:w-8/12 bg-white p-5 rounded-xl border border-gray-200 shadow-sm h-full overflow-y-auto"><h4 class="font-bold text-gray-800 mb-4 border-b pb-2 sticky top-0 bg-white z-10">Danh sách câu hỏi Khó Báu</h4><div id="listQuestionGame" class="space-y-3"></div></div></div></div></div>

<div id="modalQuestionMiniTest" class="fixed inset-0 z-[9999] hidden bg-black/60 backdrop-blur-sm items-center justify-center p-4"><div class="bg-white w-full max-w-4xl rounded-2xl shadow-2xl relative flex flex-col h-[80vh]"><div class="p-5 border-b bg-pink-50 flex justify-between items-center rounded-t-2xl"><h3 class="text-xl font-bold text-pink-900"><i class="fas fa-list-ol mr-2"></i> Câu hỏi Mini Test: <span id="miniTestTitleLabel" class="text-pink-600"></span></h3><button onclick="closeQuestionMiniTest()" class="text-gray-400 hover:text-red-500"><i class="fas fa-times text-xl"></i></button></div><div class="p-6 flex-1 flex flex-col md:flex-row gap-6 bg-gray-50 overflow-hidden"><div class="w-full md:w-5/12 bg-white p-5 rounded-xl border border-gray-200 shadow-sm h-full overflow-y-auto"><h4 class="font-bold text-gray-800 mb-4 border-b pb-2" id="formQuestionMiniTestTitle">Thêm Câu Hỏi Sắp Xếp</h4><div class="space-y-4"><div><label class="text-xs font-bold text-gray-500">Câu Tiếng Việt (Nghĩa)</label><textarea id="txtQMT_VN" rows="3" class="w-full border rounded-lg p-3 mt-1"></textarea></div><div><label class="text-xs font-bold text-gray-500">Câu Tiếng Anh đúng (Đáp án)</label><textarea id="txtQMT_EN" rows="3" class="w-full border border-pink-200 rounded-lg p-3 mt-1 bg-pink-50 font-bold text-pink-700"></textarea><p class="text-xs text-gray-400 mt-1 italic">*Hệ thống sẽ tự trộn các từ để sinh viên xếp lại.</p></div><div class="flex gap-2 pt-2"><button onclick="resetFormCauHoiMiniTest()" class="flex-1 bg-gray-200 text-gray-700 py-2 rounded-lg font-bold">Hủy</button><button onclick="saveCauHoiMiniTest()" class="flex-1 bg-pink-600 hover:bg-pink-700 text-white py-2 rounded-lg font-bold">Lưu Câu Hỏi</button></div></div></div><div class="w-full md:w-7/12 bg-white p-5 rounded-xl border border-gray-200 shadow-sm h-full overflow-y-auto"><h4 class="font-bold text-gray-800 mb-4 border-b pb-2 sticky top-0 bg-white z-10">Danh sách câu hỏi Mini Test</h4><div id="listQuestionMiniTest" class="space-y-3"></div></div></div></div></div>


<script src="@Url.Content("~/ckeditor/ckeditor.js")"></script>

@section scripts {
    <script>
        // 0. HÀM BẢO VỆ TỐI THƯỢNG (Chống lỗi nháy kép, xuống dòng làm liệt nút)
        function safeStr(str) {
            if (!str) return "";
            return str.toString().replace(/\\/g, "\\\\").replace(/'/g, "\\'").replace(/"/g, "&quot;").replace(/\n/g, "\\n").replace(/\r/g, "");
        }

        // 1. BIẾN TOÀN CỤC
        let currentSelectedLevelId = null;
        let activeTabType = 'tu-vung';
        let currentModalAction = '';
        let currentEditingItemId = null;
        let courseInfoData = {};

        // 2. KHỞI TẠO CKEDITOR
        $(document).ready(function () {
            if (typeof CKEDITOR !== 'undefined') {
                CKEDITOR.replace('txtCourseRichText', { height: 250 });
            }
        });

        // 3. MENU CHUYỂN TAB
        function switchTab(tabName) {
            activeTabType = tabName;
            $(".tab-content").addClass("hidden");
            $("#content-" + tabName).removeClass("hidden");
            $(".tab-link").removeClass("active border-indigo-600 text-indigo-600 border-pink-500 text-pink-600").addClass("border-transparent text-gray-500");

            if (tabName === 'mini-test') {
                $("#link-" + tabName).addClass("active border-pink-500 text-pink-600").removeClass("border-transparent text-gray-500");
            } else {
                $("#link-" + tabName).addClass("active border-indigo-600 text-indigo-600").removeClass("border-transparent text-gray-500");
            }

            let tenNut = "", iconNut = "fa-plus", mauNut = "bg-green-600 hover:bg-green-700";
            if (tabName == 'khoa-hoc') { tenNut = "Tạo Khóa Học Mới"; iconNut = "fa-folder-plus"; }
            else if (tabName == 'tu-vung') { tenNut = "Thêm Từ Vựng"; iconNut = "fa-language"; }
            else if (tabName == 'thanh-ngu') { tenNut = "Thêm Thành Ngữ"; iconNut = "fa-lightbulb"; }
            else if (tabName == 'noi') { tenNut = "Thêm Câu Luyện Nói"; iconNut = "fa-microphone"; }
            else if (tabName == 'nghe') { tenNut = "Thêm Bài Nghe"; iconNut = "fa-headphones"; }
            else if (tabName == 'ngu-phap') { tenNut = "Thêm Bài Ngữ Pháp"; iconNut = "fa-spell-check"; }
            else if (tabName == 'video') { tenNut = "Thêm Video"; iconNut = "fa-video"; }
            else if (tabName == 'viet') { tenNut = "Thêm Bài Luyện Viết"; iconNut = "fa-pen"; }
            else if (tabName == 'game') { tenNut = "Thêm Mini Game"; iconNut = "fa-gamepad"; }
            else if (tabName == 'mini-test') { tenNut = "Tạo Mini Test Hằng Ngày"; iconNut = "fa-calendar-check"; mauNut = "bg-pink-600 hover:bg-pink-700"; }
            else { tenNut = "Thêm Nội Dung"; }

            let btnChinh = `<button type="button" onclick="openAddContentModal()" class="${mauNut} text-white px-5 py-2 rounded-xl font-bold shadow-md transition flex items-center"><i class="fas ${iconNut} mr-2"></i> ${tenNut}</button>`;
            let btnPhu = tabName == 'khoa-hoc' ? '' : `<button type="button" onclick="openAddContentModal('khoa-hoc')" class="bg-indigo-600 text-white px-5 py-2 rounded-xl font-bold shadow-indigo-200 shadow-lg hover:bg-indigo-700 transition flex items-center"><i class="fas fa-folder-plus mr-2"></i> Tạo Khóa Học</button>`;
            $("#group-btns-add").html(btnChinh + btnPhu);
        }

        // 4. TẢI DỮ LIỆU & RENDER
        function loadFullData(id, name) {
            currentSelectedLevelId = id;
            $(".level-item").removeClass("bg-indigo-100 border-l-4 border-indigo-600");
            $("#level-" + id).addClass("bg-indigo-100 border-l-4 border-indigo-600");
            $("#empty-state").addClass("hidden");
            $("#main-panel").removeClass("hidden");
            $("#current-level-name").text("Đang quản lý: " + name);

            $.get("/Admin/Trang_Admin/GetContentByLevel", { id: id }, function (res) {
                if (res.success) {
                    renderListKhoaHoc(res.data.khoa_hoc);
                    renderTableTuVung(res.data.tu_vung);
                    renderTableThanhNgu(res.data.thanh_ngu);
                    renderTableNoi(res.data.noi);
                    renderListNghe(res.data.nghe);
                    renderListVideo(res.data.video);
                    renderListViet(res.data.viet);
                    renderListNguPhap(res.data.ngu_phap);
                    renderListGame(res.data.game);
                    renderListMiniTest(res.data.mini_test);
                    switchTab(activeTabType);
                } else alert("Lỗi server: " + res.message);
            }).fail(function () { alert("Không thể kết nối đến Server."); });
        }

        // --- CÁC HÀM RENDER GIAO DIỆN TỪNG TAB ---
        function renderListKhoaHoc(data) {
            let dataDaLoc = data ? data.slice(9) : [];
            let html = (!dataDaLoc || dataDaLoc.length === 0) ? "<div class='col-span-full text-center py-10 text-gray-400'>Không có khóa học nào từ vị trí thứ 10 trở đi.</div>" : dataDaLoc.map(item => `
                    <div class="bg-indigo-50/30 border border-indigo-100 rounded-2xl p-4 hover:shadow-md transition flex justify-between items-center group cursor-pointer" onclick="openCourseInfo(${item.id_khoa_hoc}, '${safeStr(item.ten_khoa_hoc)}')">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-xl bg-indigo-100 text-indigo-600 flex items-center justify-center text-xl shadow-sm"><i class="fas fa-folder-open"></i></div>
                            <div><h5 class="font-bold text-indigo-900">${item.ten_khoa_hoc}</h5><p class="text-xs text-gray-500 mt-1"><i class="fas fa-edit"></i> Bấm vào để soạn bài học</p></div>
                        </div>
                        <div class="flex gap-2 opacity-0 group-hover:opacity-100 transition">
                            <button onclick="event.stopPropagation(); editKhoaHoc(${item.id_khoa_hoc}, '${safeStr(item.ten_khoa_hoc)}', '${safeStr(item.mo_ta)}')" class="text-blue-500 bg-white p-2 rounded-lg shadow-sm hover:text-blue-700"><i class="fas fa-edit"></i></button>
                            <button onclick="event.stopPropagation(); deleteItem('khoa-hoc', ${item.id_khoa_hoc})" class="text-red-400 bg-white p-2 rounded-lg shadow-sm hover:text-red-600"><i class="fas fa-trash-alt"></i></button>
                        </div>
                    </div>`).join('');
            $("#list-khoa-hoc").html(html);
        }
        function renderTableTuVung(data) {
            let html = (!data || data.length === 0) ? '<tr><td colspan="3" class="text-center py-10 text-gray-400 italic">Chưa có từ vựng nào.</td></tr>' : data.map(item => `
                    <tr class="hover:bg-gray-50 transition border-b border-gray-100"><td class="p-4 font-bold text-indigo-600">${item.tu_tieng_anh}</td><td class="p-4 text-gray-600">${item.nghia_tieng_viet}</td><td class="p-4 text-right"><button onclick="editTuVung(${item.id_tu_vung}, '${safeStr(item.tu_tieng_anh)}', '${safeStr(item.nghia_tieng_viet)}', '${safeStr(item.vi_du)}')" class="text-blue-500 hover:text-blue-700 transition mr-3"><i class="fas fa-edit"></i></button><button onclick="deleteItem('tu-vung', ${item.id_tu_vung})" class="text-gray-400 hover:text-red-500 transition"><i class="fas fa-trash-alt"></i></button></td></tr>`).join('');
            $("#tbody-tu-vung").html(html);
        }
        function renderTableThanhNgu(data) {
            let html = (!data || data.length === 0) ? '<tr><td colspan="3" class="text-center py-10 text-gray-400 italic">Chưa có thành ngữ nào.</td></tr>' : data.map(item => `
                    <tr class="hover:bg-gray-50 transition border-b border-gray-100"><td class="p-4 font-bold text-indigo-600">${item.thanh_ngu}</td><td class="p-4 text-gray-600">${item.nghia}</td><td class="p-4 text-right"><button onclick="editThanhNgu(${item.id_thanh_ngu}, '${safeStr(item.thanh_ngu)}', '${safeStr(item.nghia)}', '${safeStr(item.vi_du)}')" class="text-blue-500 hover:text-blue-700 transition mr-3"><i class="fas fa-edit"></i></button><button onclick="deleteItem('thanh-ngu', ${item.id_thanh_ngu})" class="text-gray-400 hover:text-red-500 transition"><i class="fas fa-trash-alt"></i></button></td></tr>`).join('');
            $("#tbody-thanh-ngu").html(html);
        }
        function renderTableNoi(data) {
            let html = (!data || data.length === 0) ? '<tr><td colspan="3" class="text-center py-10 text-gray-400">Trống.</td></tr>' : data.map(item => `
                    <tr class="border-b hover:bg-gray-50 transition"><td class="py-3 px-2 font-medium">${item.noi_dung_goc}</td><td class="py-3 px-2 text-gray-600">${item.nghia_tieng_viet}</td><td class="py-3 px-2 text-right"><button onclick="editNoi(${item.id_bai_noi}, '${safeStr(item.noi_dung_goc)}', '${safeStr(item.nghia_tieng_viet)}')" class="text-blue-500 hover:text-blue-700 p-2 mr-2"><i class="fas fa-edit"></i></button><button onclick="deleteItem('noi', ${item.id_bai_noi})" class="text-red-500 hover:text-red-700 p-2"><i class="fas fa-trash"></i></button></td></tr>`).join('');
            $("#tbody-noi").html(html);
        }
        function renderListNghe(data) {
            let html = (!data || data.length === 0) ? "<div class='col-span-full text-center py-10 text-gray-400'>Chưa có bài nghe nào.</div>" : data.map(i => `
                    <div class="bg-indigo-50/30 border border-indigo-100 rounded-2xl p-4 hover:shadow-md transition flex justify-between items-center group cursor-pointer" onclick="openQuestionNghe(${i.id_bai_nghe}, '${safeStr(i.tieu_de)}')">
                        <div class="flex items-center gap-4"><div class="w-12 h-12 rounded-xl bg-blue-100 text-blue-600 flex items-center justify-center text-xl shadow-sm"><i class="fas fa-headphones"></i></div><div><h5 class="font-bold text-indigo-900">${i.tieu_de}</h5><p class="text-xs text-gray-500 mt-1"><i class="fas fa-list-ol"></i> Quản lý câu hỏi</p></div></div>
                        <div class="flex gap-2 opacity-0 group-hover:opacity-100 transition"><button onclick="event.stopPropagation(); editNghe(${i.id_bai_nghe}, '${safeStr(i.tieu_de)}', '${safeStr(i.mo_ta)}', '${safeStr(i.file_am_thanh)}')" class="text-blue-500 bg-white p-2 rounded-lg shadow-sm hover:text-blue-700"><i class="fas fa-edit"></i></button><button onclick="event.stopPropagation(); deleteItem('nghe', ${i.id_bai_nghe})" class="text-red-400 bg-white p-2 rounded-lg shadow-sm hover:text-red-600"><i class="fas fa-trash-alt"></i></button></div>
                    </div>`).join('');
            $("#list-nghe").html(html);
        }
        function renderListVideo(data) {
            let html = (!data || data.length === 0) ? "<div class='col-span-full text-center py-10 text-gray-400 italic'>Chưa có video.</div>" : data.map(v => `
                    <div class="bg-indigo-50/30 border border-indigo-100 rounded-2xl p-4 hover:shadow-md transition flex justify-between items-center group cursor-pointer" onclick="openQuestionVideo(${v.id_video}, '${safeStr(v.tieu_de)}')">
                        <div class="flex items-center gap-4"><div class="w-12 h-12 rounded-xl bg-red-100 text-red-600 flex items-center justify-center text-xl shadow-sm"><i class="fas fa-play-circle"></i></div><div><h5 class="font-bold text-indigo-900">${v.tieu_de}</h5><p class="text-xs text-gray-500 mt-1"><i class="fas fa-list-ol"></i> Quản lý câu hỏi</p></div></div>
                        <div class="flex gap-2 opacity-0 group-hover:opacity-100 transition"><button onclick="event.stopPropagation(); editVideo(${v.id_video}, '${safeStr(v.tieu_de)}', '${safeStr(v.duong_dan_video)}', ${v.thoi_luong_phut || 0})" class="text-blue-500 bg-white p-2 rounded-lg shadow-sm hover:text-blue-700"><i class="fas fa-edit"></i></button><button onclick="event.stopPropagation(); deleteItem('video', ${v.id_video})" class="text-red-400 bg-white p-2 rounded-lg shadow-sm hover:text-red-600"><i class="fas fa-trash-alt"></i></button></div>
                    </div>`).join('');
            $("#list-video").html(html);
        }
        function renderListViet(data) {
            let html = (!data || data.length === 0) ? "<div class='col-span-full text-center py-10 text-gray-400'>Chưa có bài luyện viết.</div>" : data.map(item => `
                    <div class="bg-indigo-50/30 border border-indigo-100 rounded-2xl p-4 hover:shadow-md transition flex justify-between items-center group cursor-pointer" onclick="openQuestionViet(${item.id_bai_viet}, '${safeStr(item.tieu_de)}')">
                        <div class="flex items-center gap-4"><div class="w-12 h-12 rounded-xl bg-purple-100 text-purple-600 flex items-center justify-center text-xl shadow-sm"><i class="fas fa-pen"></i></div><div><h5 class="font-bold text-indigo-900">${item.tieu_de}</h5><p class="text-xs text-gray-500 mt-1"><i class="fas fa-list-ol"></i> Quản lý câu hỏi</p></div></div>
                        <div class="flex gap-2 opacity-0 group-hover:opacity-100 transition"><button onclick="event.stopPropagation(); editViet(${item.id_bai_viet}, '${safeStr(item.tieu_de)}', '${safeStr(item.mo_ta)}')" class="text-blue-500 bg-white p-2 rounded-lg shadow-sm hover:text-blue-700"><i class="fas fa-edit"></i></button><button onclick="event.stopPropagation(); deleteItem('viet', ${item.id_bai_viet})" class="text-red-400 bg-white p-2 rounded-lg shadow-sm hover:text-red-600"><i class="fas fa-trash-alt"></i></button></div>
                    </div>`).join('');
            $("#list-viet").html(html);
        }
        function renderListNguPhap(data) {
            let html = (!data || data.length === 0) ? "<div class='col-span-full text-center py-10 text-gray-400'>Chưa có bài ngữ pháp nào.</div>" : data.map(item => `<div class="bg-indigo-50/50 border border-indigo-100 rounded-2xl p-5 hover:shadow-md transition"><div class="flex justify-between mb-3"><h5 class="font-bold text-indigo-900 text-lg">${item.tieu_de}</h5><button onclick="deleteItem('ngu-phap', ${item.id_ngu_phap})" class="text-red-400 hover:text-red-600"><i class="fas fa-trash-alt"></i></button></div><div class="space-y-2 text-sm text-gray-700"><p><strong>💡 Cách dùng:</strong> ${item.cach_dung}</p><p class="bg-white p-2 rounded-lg border font-mono"><strong>🧪 CT:</strong> ${item.cong_thuc}</p><p class="italic text-gray-500">"${item.vi_du}"</p></div></div>`).join('');
            $("#list-ngu-phap").html(html);
        }
        function renderListGame(data) {
            let html = (!data || data.length === 0) ? "<div class='col-span-full text-center py-10 text-gray-400'>Chưa có game nào.</div>" : data.map(item => `
                    <div class="bg-indigo-50/30 border border-indigo-100 rounded-2xl p-4 hover:shadow-md transition flex justify-between items-center group cursor-pointer" onclick="openQuestionGame(${item.id_game}, '${safeStr(item.tieu_de)}')">
