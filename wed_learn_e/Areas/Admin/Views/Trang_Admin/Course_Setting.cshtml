        // 5. QUẢN LÝ MỞ FORM THÊM NỘI DUNG (VẠN NĂNG)
        function openAddContentModal(overrideType = null) {
            if (!currentSelectedLevelId) { alert("Vui lòng chọn Cấp độ ở menu bên trái trước!"); return; }
            currentEditingItemId = null; currentModalAction = overrideType || activeTabType;

            $("#txtData1, #txtData2, #txtData3, #txtData4, #txtData2_Date").val("");
            $("#box-data3, #box-data4").addClass("hidden");

            // Xử lý chuyển đổi Input thường thành Date Picker cho Mini Test
            if (currentModalAction == "mini-test") {
                $("#box-data2-textarea").addClass("hidden");
                $("#box-data2-date").removeClass("hidden");
            } else {
                $("#box-data2-textarea").removeClass("hidden");
                $("#box-data2-date").addClass("hidden");
            }

            if (currentModalAction == "khoa-hoc") { $("#modalContentTitle").html("✨ Tạo Khóa Học Mới"); $("#lblData1").text("Tên khóa học"); $("#lblData2").text("Mô tả tóm tắt"); $("#box-khoa-hoc").addClass("hidden"); }
            else if (currentModalAction == "tu-vung") { $("#modalContentTitle").html("✨ Thêm Từ Vựng Mới"); $("#lblData1").text("Từ Tiếng Anh (Word)"); $("#lblData2").text("Nghĩa Tiếng Việt (Meaning)"); $("#lblData3").text("Câu Ví Dụ (Example)"); $("#box-data3").removeClass("hidden"); $("#box-khoa-hoc").addClass("hidden"); }
            else if (currentModalAction == "thanh-ngu") { $("#modalContentTitle").html("✨ Thêm Thành Ngữ Mới"); $("#lblData1").text("Thành Ngữ (Idiom)"); $("#lblData2").text("Nghĩa Tiếng Việt"); $("#lblData3").text("Câu Ví Dụ (Example)"); $("#box-data3").removeClass("hidden"); $("#box-khoa-hoc").addClass("hidden"); }
            else if (currentModalAction == "noi") { $("#modalContentTitle").html("✨ Thêm Câu Luyện Nói"); $("#lblData1").text("Câu Tiếng Anh"); $("#lblData2").text("Nghĩa Tiếng Việt"); $("#box-khoa-hoc").addClass("hidden"); }
            else if (currentModalAction == "video") { $("#modalContentTitle").html("✨ Thêm Video Bài Giảng"); $("#lblData1").text("Tiêu đề Video"); $("#lblData2").text("Đường dẫn (Link YouTube)"); $("#lblData3").text("Thời lượng (Phút)"); $("#box-data3").removeClass("hidden"); $("#box-khoa-hoc").addClass("hidden"); }
            else if (currentModalAction == "viet") { $("#modalContentTitle").html("✨ Thêm Bài Luyện Viết"); $("#lblData1").text("Tiêu đề bài viết"); $("#lblData2").text("Gợi ý / Mô tả yêu cầu"); $("#box-khoa-hoc").addClass("hidden"); }
            else if (currentModalAction == "ngu-phap") { $("#modalContentTitle").html("✨ Thêm Bài Ngữ Pháp"); $("#lblData1").text("Tiêu đề ngữ pháp"); $("#lblData2").text("Cách dùng"); $("#lblData3").text("Công thức"); $("#lblData4").text("Ví dụ"); $("#box-data3, #box-data4").removeClass("hidden"); $("#box-khoa-hoc").addClass("hidden"); }
            else if (currentModalAction == "game") { $("#modalContentTitle").html("✨ Thêm Mini Game"); $("#lblData1").text("Tiêu đề Game"); $("#lblData2").text("Mô tả / Hướng dẫn"); $("#lblData3").text("Từ khóa cuối cùng (Đáp án chung)"); $("#box-data3").removeClass("hidden"); $("#box-khoa-hoc").addClass("hidden"); }
            else if (currentModalAction == "nghe") { $("#modalContentTitle").html("✨ Thêm Bài Nghe Mới"); $("#lblData1").text("Tiêu đề bài nghe"); $("#lblData2").text("Mô tả ngắn"); $("#lblData3").text("Tên File / Link Audio"); $("#box-data3").removeClass("hidden"); $("#box-khoa-hoc").addClass("hidden"); }
            else if (currentModalAction == "mini-test") { $("#modalContentTitle").html("✨ Tạo Lịch Mini Test Mới"); $("#lblData1").text("Tiêu đề Bài Test (VD: Test Ngày 1)"); $("#box-khoa-hoc").addClass("hidden"); }
            else { alert("Tính năng Thêm đang cập nhật cho mục này!"); return; }

            if (!$("#box-khoa-hoc").hasClass("hidden")) {
                $.get("/Admin/Trang_Admin/GetDanhSachKhoaHoc", { id_cap_do: currentSelectedLevelId }, function (res) {
                    if (res.success) { let opts = res.data.map(k => `<option value="${k.id_khoa_hoc}">${k.ten_khoa_hoc}</option>`).join(''); $("#cboKhoaHoc").html(opts || "<option value=''>-- Chưa có khóa học --</option>"); }
                });
            }
            $("#modalAddContent").removeClass("hidden").addClass("flex");
        }
        function closeAddContentModal() { $("#modalAddContent").addClass("hidden").removeClass("flex"); }
        function submitContentModal() {
            // Lấy giá trị của data2 (Nếu là mini-test thì lấy từ Date Picker)
            let valData2 = (currentModalAction === 'mini-test') ? $("#txtData2_Date").val() : $("#txtData2").val();

            let dataObj = {
                type: currentModalAction, id_cap_do: currentSelectedLevelId, id_khoa_hoc: $("#cboKhoaHoc").val() || 0,
                id_item: currentEditingItemId, data1: $("#txtData1").val(), data2: valData2, data3: $("#txtData3").val(), data4: $("#txtData4").val()
            };
            $.post("/Admin/Trang_Admin/LuuNoiDungChiTiet", dataObj, function (res) {
                if (res.success) { closeAddContentModal(); loadFullData(currentSelectedLevelId, $("#current-level-name").text().replace("Đang quản lý: ", "")); setTimeout(() => switchTab((currentModalAction === 'khoa-hoc') ? activeTabType : currentModalAction), 100); }
                else alert(res.message);
            });
        }

