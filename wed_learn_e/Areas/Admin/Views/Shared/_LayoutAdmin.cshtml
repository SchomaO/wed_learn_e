

@using wed_learn_e.Models;
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@(ViewBag.Title ?? "ADMIN.IO")</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-50 text-gray-800">

    <div class="flex h-screen overflow-hidden">

        <aside class="w-64 bg-indigo-900 text-white flex-shrink-0 hidden md:flex flex-col">
            <div class="p-6 text-2xl font-bold tracking-wider flex items-center gap-3">
                <div class="w-8 h-8 bg-indigo-500 rounded-lg flex items-center justify-center">
                    <i class="fas fa-bolt text-sm"></i>
                </div>
                <span>ADMIN.IO</span>
            </div>

            <nav class="flex-1 px-4 space-y-2 mt-4">
                @{
                    // Lấy tên Action hiện tại từ RouteData
                    string currentAction = ViewContext.RouteData.Values["action"].ToString();
                }

                <a href="@Url.Action("Course_Setting", "Trang_Admin", new { area = "Admin" })"
                   class="flex items-center gap-3 p-3 rounded-lg transition shadow-sm @(currentAction == "Course_Setting" ? "bg-indigo-700 font-medium" : "hover:bg-indigo-800")">
                    <i class="fas fa-home w-5"></i> Course Management
                </a>

                <a href="@Url.Action("Index", "Trang_Admin", new { area = "Admin" })"
                   class="flex items-center gap-3 p-3 rounded-lg transition shadow-sm @(currentAction == "Index" ? "bg-indigo-700 font-medium" : "hover:bg-indigo-800")">
                    <i class="fas fa-users w-5"></i> Users Management
                </a>
                <a href="@Url.Action("QuanLyBinhLuan", "Trang_Admin", new { area = "Admin" })"
                   class="flex items-center gap-3 p-3 rounded-lg transition shadow-sm @(currentAction == "QuanLyBinhLuan" ? "bg-indigo-700 font-medium" : "hover:bg-indigo-800")">
                    <i class="fas fa-comments w-5"></i> Comments & Support
                </a>
                <a href="@Url.Action("Analytics", "Trang_Admin", new { area = "Admin" })"
                   class="flex items-center gap-3 p-3 rounded-lg transition shadow-sm @(currentAction == "Analytics" ? "bg-indigo-700 font-medium" : "hover:bg-indigo-800")">
                    <i class="fas fa-chart-line w-5"></i> Analytics
                </a>
                <a href="@Url.Action("QuanLyGiaoDien", "Trang_Admin", new { area = "Admin" })"
                   class="flex items-center gap-3 p-3 rounded-lg transition shadow-sm @(currentAction == "Course_Setting" ? "bg-indigo-700 font-medium" : "hover:bg-indigo-800")">
                    <i class="fas fa-info-circle"></i> Feature & Footer Management
                </a>
                <a href="@Url.Action("QuanLyBaiTest", "Trang_Admin", new { area = "Admin" })"
                   class="flex items-center gap-3 p-3 rounded-lg transition shadow-sm @(currentAction == "QuanLyBaiTest" ? "bg-indigo-700 font-medium" : "hover:bg-indigo-800")">
                    <i class="fas fa-file-signature w-5"></i> Test Management
                </a>
                <a href="@Url.Action("CaiDat", "Trang_Admin", new { area = "Admin" })" class="flex items-center gap-3 p-3 rounded-lg hover:bg-indigo-800 transition">
                    <i class="fas fa-cog w-5"></i> Settings
                </a>
            </nav>

            <div class="p-4 border-t border-indigo-800 relative">
                @* Phần hiển thị mặc định - Khi bấm vào sẽ mở Menu *@
                <button onclick="toggleAdminMenu()" class="w-full flex items-center gap-3 p-2 rounded-xl hover:bg-indigo-800 transition focus:outline-none" id="adminBtn">
                    <img src="https://ui-avatars.com/api/?name=@(Session["HoTen"] ?? "Admin")&background=6366f1&color=fff"
                         class="w-10 h-10 rounded-full border-2 border-indigo-400">
                    <div class="text-left flex-1">
                        <p class="text-sm font-semibold truncate w-32">@(Session["Admin_HoTen"] ?? "Admin Account")</p>
                        <p class="text-[10px] text-indigo-300">Super Admin</p>
                    </div>
                    <i class="fas fa-chevron-up text-xs text-indigo-400 transition-transform duration-300" id="chevronIcon"></i>
                </button>

                @* Menu mở rộng - Mặc định sẽ ẩn (hidden) *@
            <div id="adminMenu" class="hidden absolute bottom-20 left-4 right-4 bg-indigo-950 border border-indigo-700 rounded-xl shadow-2xl p-3 z-50 animate-fade-in-up w-64">
                <div class="space-y-1">
                    <div class="px-2 py-2 border-b border-indigo-800 mb-2">
                        <p class="text-[10px] uppercase tracking-wider text-indigo-400 font-bold">Tài khoản</p>
                        <p class="text-xs text-white truncate">admin@wed_learn_e.com</p>
                    </div>

                    <div class="relative">
                        <a href="javascript:void(0)" onclick="toggleProfile()" class="flex items-center gap-3 p-2 text-sm text-indigo-200 hover:bg-indigo-800 hover:text-white rounded-lg transition">
                            <i class="fas fa-user-circle w-4"></i> Hồ sơ cá nhân
                        </a>

                        <div id="userProfile" class="hidden absolute left-full top-0 ml-2 w-64 bg-[#1a1c3d] border border-indigo-500/50 rounded-xl shadow-2xl z-50 animate-fade-in">
                            <div class="p-4">
                                <div class="flex items-center gap-3 mb-3 border-b border-indigo-800 pb-3">
                                    <div class="w-12 h-12 rounded-full bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-white font-bold text-lg shadow-lg">
                                        @if (Session["Admin_HoTen"] != null)
                                        {@Session["Admin_HoTen"].ToString().Substring(0, 1)}
                                    </div>
                                    <div>
                                        <p class="text-white text-sm font-bold">@Session["Admin_HoTen"]</p>
                                        <p class="text-emerald-400 text-[10px] flex items-center gap-1">
                                            <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full"></span> Online
                                        </p>
                                    </div>
                                </div>

                                <div class="space-y-2">
                                    <div class="flex flex-col">
                                        <span class="text-indigo-400 text-[10px] uppercase font-bold">Quyền hạn</span>
                                        <span class="text-amber-400 text-xs font-semibold">@Session["Admin_VaiTro"]</span>
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="text-indigo-400 text-[10px] uppercase font-bold">Mã nhân viên</span>
                                        <span class="text-indigo-100 text-xs">#@Session["Admin_ID"]</span>
                                    </div>
                                </div>

                                <button onclick="toggleProfile()" class="mt-4 w-full py-1.5 bg-indigo-800 hover:bg-indigo-700 text-white text-[11px] rounded-lg transition">
                                    Đóng cửa sổ
                                </button>
                            </div>
                        </div>
                    </div>
                    <button onclick="toggleChangePass()" class="w-full flex items-center justify-between p-2 text-sm text-indigo-200 hover:bg-indigo-800 hover:text-white rounded-lg transition">
                        <div class="flex items-center gap-3">
                            <i class="fas fa-key w-4"></i> Đổi mật khẩu
                        </div>
                        <i id="passChevron" class="fas fa-chevron-right text-[10px] transition-transform duration-300"></i>
                    </button>

                    <div id="changePassForm" class="hidden overflow-hidden bg-indigo-900/30 rounded-lg mt-1 p-2 border border-indigo-800/50 space-y-2">
                        @using (Html.BeginForm("DoiMatKhauAdmin", "Trang_Admin", new { area = "Admin" }, FormMethod.Post))
                        {
                            <input type="password" name="oldPass" placeholder="Mật khẩu hiện tại" required
                                   class="w-full bg-indigo-950 border border-indigo-700 rounded p-2 text-xs text-white focus:outline-none mb-2">

                            <input type="password" name="newPass" placeholder="Mật khẩu mới" required
                                   class="w-full bg-indigo-950 border border-indigo-700 rounded p-2 text-xs text-white focus:outline-none mb-2">

                            <input type="password" name="confirmPass" placeholder="Nhập lại mật khẩu" required
                                   class="w-full bg-indigo-950 border border-indigo-700 rounded p-2 text-xs text-white focus:outline-none mb-2">

                            <button type="submit" class="w-full py-1.5 bg-emerald-600 hover:bg-emerald-500 text-white text-[11px] font-bold rounded transition">
                                XÁC NHẬN THAY ĐỔI
                            </button>
                        }
                    </div>

                    <div class="pt-2 mt-2 border-t border-indigo-800">
                        <a href="@Url.Action("DangXuat", "User", new { area = "" })"
                           class="flex items-center gap-3 p-2 text-sm text-red-400 hover:bg-red-900/30 rounded-lg transition font-medium">
                            <i class="fas fa-power-off w-4"></i> Đăng xuất
                        </a>
                    </div>
                </div>
            </div>
            </div>

            @* Script điều khiển việc đóng mở *@
            <script>
                function toggleAdminMenu() {
                    const menu = document.getElementById('adminMenu');
                    const icon = document.getElementById('chevronIcon');

                    // Đảo trạng thái ẩn/hiện
                    menu.classList.toggle('hidden');

                    // Xoay icon mũi tên cho sinh động
                    icon.style.transform = menu.classList.contains('hidden') ? 'rotate(0deg)' : 'rotate(180deg)';
                }

                // Đóng menu nếu bấm ra ngoài vùng admin
                window.onclick = function (event) {
                    if (!event.target.closest('#adminBtn') && !event.target.closest('#adminMenu')) {
                        document.getElementById('adminMenu').classList.add('hidden');
                        document.getElementById('chevronIcon').style.transform = 'rotate(0deg)';
                    }
                }
            </script>

            @* Thêm một chút CSS cho hiệu ứng mượt *@
        <style>
                .animate-fade-in-up {
                    animation: fadeInUp 0.2s ease-out;
                }

                @@keyframes fadeInUp {
                    from {
                        opacity: 0;
                        transform: translateY(10px);
                    }

                    to {
                        opacity: 1;
                        transform: translateY(0);
                    }
                }
                @@keyframes fadeIn {
                    from { opacity: 0; transform: translateX(-10px); }
                    to { opacity: 1; transform: translateX(0); }
                }
                .animate-fade-in {
                    animation: fadeIn 0.3s ease-out;
                }
        </style>
        </aside>

        <div class="flex-1 flex flex-col overflow-y-auto">

            <header class="h-24 bg-white/80 backdrop-blur-md border-b border-gray-200 flex items-center justify-between px-10 sticky top-0 z-10 shadow-sm">
                <div class="flex items-center gap-4">
                    <button class="md:hidden text-gray-600"><i class="fas fa-bars"></i></button>

                    <h1 class="text-3xl font-black text-indigo-900 uppercase tracking-tighter">
                        @(ViewBag.Title ?? "Hệ Thống Quản Trị")
                    </h1>
                </div>

                <div class="flex items-center gap-4">
                    <div class="relative flex items-center justify-center group p-3">

                        <div class="absolute inset-0 bg-amber-100 rounded-2xl rotate-45 scale-0 group-hover:scale-110 group-hover:rotate-12 transition-all duration-500 opacity-60"></div>

                        <div class="relative flex flex-col items-center">
                            <div class="flex gap-4 -mb-1">
                                <div class="w-3 h-2 bg-amber-400 rounded-t-full group-hover:-rotate-12 transition-transform"></div>
                                <div class="w-3 h-2 bg-amber-400 rounded-t-full group-hover:rotate-12 transition-transform"></div>
                            </div>

                            <div class="relative w-12 h-10 bg-amber-400 rounded-b-2xl rounded-t-lg flex items-center justify-center shadow-sm group-hover:bg-amber-300 transition-colors">
                                <div class="flex gap-2">
                                    <div class="w-1 h-1 bg-amber-900 rounded-full animate-bounce"></div>
                                    <div class="w-1 h-1 bg-amber-900 rounded-full animate-bounce"></div>
                                </div>
                                <div class="absolute bottom-2 w-3 h-1 border-b-2 border-amber-900 rounded-full"></div>
                            </div>

                            <div class="absolute -right-2 bottom-2 w-4 h-6 border-r-4 border-b-4 border-amber-400 rounded-br-xl rotate-12 group-hover:rotate-45 transition-transform origin-bottom-left"></div>
                        </div>

                        <div class="absolute top-full mt-3 opacity-0 group-hover:opacity-100 transition-all transform translate-y-2 group-hover:translate-y-0">
                            <div class="bg-white text-amber-600 text-[11px] font-black px-4 py-2 rounded-xl shadow-lg border border-amber-100 whitespace-nowrap relative">
                                Hôm nay bạn thế nào? 🐾
                                <div class="absolute -top-1 left-1/2 -translate-x-1/2 w-2 h-2 bg-white border-t border-l border-amber-100 rotate-45"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </header>

            <main class="p-8">
                @RenderBody()

            </main>
        </div>
    </div>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("scripts", required: false)
</body>
</html>
<script>
    function toggleChangePass() {
        const form = document.getElementById('changePassForm');
        const icon = document.getElementById('passChevron');

        // Kiểm tra xem form đang ẩn hay hiện
        const isHidden = form.classList.contains('hidden');

        if (isHidden) {
            form.classList.remove('hidden');
            icon.style.transform = 'rotate(90deg)'; // Xoay mũi tên xuống (nếu ban đầu là chevron-right)
        } else {
            form.classList.add('hidden');
            icon.style.transform = 'rotate(0deg)'; // Quay về vị trí cũ
        }
    }
    function toggleProfile() {
        const profileBox = document.getElementById('userProfile');
        // Ẩn/Hiện khung hồ sơ
        if (profileBox.classList.contains('hidden')) {
            profileBox.classList.remove('hidden');
        } else {
            profileBox.classList.add('hidden');
        }
    }

    // Thêm tính năng: Click ra ngoài khung thì tự đóng
    window.addEventListener('click', function (e) {
        const profileBox = document.getElementById('userProfile');
        const btnProfile = profileBox.previousElementSibling; // Nút Hồ sơ cá nhân

        if (!profileBox.contains(e.target) && !btnProfile.contains(e.target)) {
            profileBox.classList.add('hidden');
        }
    });
</script>