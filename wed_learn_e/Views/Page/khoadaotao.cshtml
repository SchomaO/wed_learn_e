@model List<wed_learn_e.Models.cap_do>

@{
    ViewBag.Title = "Khóa Đào Tạo";
    Layout = "~/Views/Shared/_Layoutcauhoi.cshtml";
}

<style>
    body {
        margin: 0;
        font-family: Arial;
        background: #e9f5ff;
    }

    /* tiêu đề */
    .title {
        text-align: center;
        padding: 40px;
        font-size: 32px;
        font-weight: bold;
        color: #0d6efd;
    }

    /* container */
    .course-container {
        width: 90%;
        margin: auto;
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(250px,1fr));
        gap: 25px;
        padding-bottom: 50px;
    }

    /* box */
    .course-box {
        background: white;
        border-radius: 12px;
        padding: 25px;
        text-align: center;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        transition: 0.3s;
        /* Căn bằng nút bấm ở dưới cùng */
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

        .course-box:hover {
            transform: translateY(-6px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }

    /* icon */
    .course-icon {
        font-size: 40px;
        margin-bottom: 15px;
    }

    /* title */
    .course-title {
        font-size: 20px;
        font-weight: bold;
        margin-bottom: 10px;
        color: #007bff;
    }

    /* description */
    .course-desc {
        font-size: 14px;
        color: #555;
        margin-bottom: 20px;
        /* Đẩy nút xuống dưới */
        flex-grow: 1;
    }

    /* button */
    .btn-course {
        background: #0d6efd;
        color: white;
        padding: 10px 18px;
        border-radius: 6px;
        text-decoration: none;
        /* Giữ kích thước nút vừa phải */
        align-self: center;
    }

        .btn-course:hover {
            background: #0b5ed7;
        }

    .extra-title {
        text-align: center;
        margin-top: 40px;
        margin-bottom: 20px;
        font-size: 28px;
        font-weight: bold;
        color: #0b5ed7;
        position: relative;
    }

        .extra-title:after {
            content: "";
            width: 120px;
            height: 3px;
            background: #0d6efd;
            display: block;
            margin: 10px auto;
            border-radius: 3px;
        }

    .cat-mascot {
        position: fixed;
        bottom: 20px;
        right: 20px;
        font-size: 55px;
        animation: floatCat 10s infinite ease-in-out;
    }

    .cat-text {
        position: absolute;
        bottom: 70px;
        right: 0;
        background: white;
        padding: 6px 10px;
        border-radius: 10px;
        font-size: 14px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    }

    @@keyframes floatCat {
        0% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-8px);
        }

        100% {
            transform: translateY(0);
        }
    }
</style>

<div class="extra-title">
    Khóa Đào Tạo Tiếng Anh
</div>

<div class="course-container">
    @{
        // Mảng chứa các màu nền và icon theo thứ tự
        string[] colors = { "#ffffff", "#f0f8ff", "#e6f4ff", "#f5fbff", "#eef7ff", "#f2f9ff" };
        string[] icons = { "📘", "📗", "📙", "📕", "🎓", "🏆" };
    }

    @for (int i = 0; i < Model.Count; i++)
    {
        var item = Model[i];<div class="course-box" style="background: @(colors[i % colors.Length])">
            <div class="course-icon">@(icons[i % icons.Length])</div>

            <div class="course-title">@item.ten_cap_do</div>
            <div class="course-desc">@item.mo_ta</div>

            <a class="btn-course" href="@Url.Action("thong_tin_khoa_hoc", "Page", new { id = item.id_cap_do })">
                Chọn khóa học
            </a>
        </div>
    }
</div>

<div class="cat-mascot">
    <img src="https://cdn-icons-png.flaticon.com/512/763/763704.png" width="50">
    <div class="cat-text" id="catText">Let's learn English!</div>
</div>

<script>
    var texts = [
        "Let's learn English!",
        "Practice makes perfect!",
        "Keep studying!",
        "You can do it!",
        "New words today?"
    ];

    function changeText() {
        var random = Math.floor(Math.random() * texts.length);
        document.getElementById("catText").innerText = texts[random];
    }

    setInterval(changeText, 10000);
</script>