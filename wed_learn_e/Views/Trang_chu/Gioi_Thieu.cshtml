<div class="gioi_thieu_cac_uu_dai">
    @foreach (var f in ViewBag.ListFeature as List<wed_learn_e.Models.feature_trang_chu>)
    {   
        if (f.anh_ben_trai == false)
        {
            <div class="feature-row">
                <div class="feature-content right-align">
                    <h2>@Html.Raw(f.tieu_de)</h2>
                    <p>@Html.Raw(f.noi_dung)</p>
                </div>
                <div class="feature-image">
                    <img src="@f.hinh_anh" alt="Giao diện">
                </div>
            </div>
        }
        else
        {
            <div class="feature-row reverse">
                <div class="feature-content left-align">
                    <h2>@Html.Raw(f.tieu_de)</h2>
                    <p>@Html.Raw(f.noi_dung)</p>
                </div>
                <div class="feature-image">
                    <img src="@f.hinh_anh" alt="Giao diện">
                </div>
            </div>
        }
    }
</div>