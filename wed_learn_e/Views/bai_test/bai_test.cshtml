
@{
    Layout = "~/Views/Shared/_Layoutcauhoi.cshtml";
}
<title>Bài Test</title>

<style>

    body {
        background: linear-gradient(177deg, #dcdcdc, #ffffff, #bfe7ff, #d6f4ff, #006c97);
        font-family: Arial;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding-top: 90px; /* khoảng trống cho navbar */
        margin: 0;
        min-height: 100vh;
    }

    /* layout */

    .container {
        display: flex;
        gap: 30px;
    }

    /* hộp câu hỏi */

    .quiz-box {
        background: white;
        width: 520px;
        padding: 30px;
        border-radius: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }

    .question {
        font-size: 22px;
        font-weight: bold;
        margin-bottom: 25px;
        color: #2b4a5a;
    }

    /* đáp án */

    .answers {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

        .answers input {
            display: none;
        }

    .answer {
        background: #eef8ff;
        padding: 15px;
        border-radius: 12px;
        cursor: pointer;
        transition: 0.3s;
        border: 2px solid transparent;
    }

        .answer:hover {
            background: #dff3ff;
            transform: scale(1.02);
        }

    /* khi chọn */

    .answers input:checked + .answer {
        background: #bfe9ff;
        border: 2px solid #6ec8ff;
    }

    /* mục lục */

    .question-list {
        background: white;
        width: 220px;
        padding: 20px;
        border-radius: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }

        .question-list h3 {
            text-align: center;
            margin-bottom: 15px;
            color: #2b4a5a;
        }

    .grid {
        display: grid;
        grid-template-columns: repeat(5,1fr);
        gap: 10px;
    }

    .q-number {
        background: #eef8ff;
        height: 40px;
        border-radius: 10px;
        display: flex;
        justify-content: center;
        align-items: center;
        cursor: pointer;
        transition: 0.2s;
    }

        .q-number:hover {
            background: #dff3ff;
        }
    .nav-question {
        display: flex;
        justify-content: space-between;
        margin-top: 25px;
    }

    .btn-nav {
        text-decoration: none;
        background: #bfe9ff;
        padding: 10px 18px;
        border-radius: 10px;
        color: #1b4d63;
        font-weight: bold;
        transition: 0.2s;
    }

        .btn-nav:hover {
            background: #9edcff;
        }
    .done {
        background: #6ec8ff !important;
        color: white;
    }
</style>


<div class="container">

    <!-- câu hỏi -->
    @using (Html.BeginForm("bai_test", "bai_test", FormMethod.Post))
    {
        <input type="hidden" name="index" value="@ViewBag.Index" />
    
        <div class="quiz-box">

            <div class="question">
                Question: @(ViewBag.Index + 1)
                @Model.noi_dung_cau_hoi
            </div>

            <div class="answers">

                <label>
                    <input type="radio" name="answer" value="A"
                           @(Session["answer_" + ViewBag.Index]?.ToString() == "A" ? "checked" : "")>
                    <div class="answer">A. @Model.dap_an_a</div>
                </label>

                <label>
                    <input type="radio" name="answer" value="B"
                           @(Session["answer_" + ViewBag.Index]?.ToString() == "B" ? "checked" : "")>
                    <div class="answer">B. @Model.dap_an_b</div>
                </label>

                <label>
                    <input type="radio" name="answer" value="C"
                           @(Session["answer_" + ViewBag.Index]?.ToString() == "C" ? "checked" : "")>
                    <div class="answer">C. @Model.dap_an_c</div>
                </label>

                <label>
                    <input type="radio" name="answer" value="D"
                           @(Session["answer_" + ViewBag.Index]?.ToString() == "D" ? "checked" : "")>
                    <div class="answer">D. @Model.dap_an_d</div>
                </label>

            </div>

            <div class="nav-question">

                <button type="submit" name="action" value="prev" class="btn-nav">← Câu trước</button>

                <button type="submit" name="action" value="next" class="btn-nav">Câu sau →</button>

            </div>

        </div>
    }

    <!-- mục lục -->

    <div class="question-list">

        <div class="grid">
            @for (int j = 0; j < ViewBag.Total; j++)
            {
                <a href="@Url.Action("bai_test","bai_test", new { index = j })"
                   class="q-number @(Session["q" + j] != null ? "done" : "")">
                    @(j + 1)
                </a>

            }
        </div>
    </div>


</div>

    <div class="submit-box">

            <button class="submit-btn"onclick="location.href='@Url.Action("end_bai_test","bai_test")'" >Nộp bài</button>


    </div>


    <style>
        .submit-box {
            background: white;
            width: 220px;
            margin-top: 30px;
            border-radius: 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            display: flex;
            justify-content: right;
            align-items: center;
        }

        .submit-btn {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 10px;
            background: linear-gradient(135deg,#6ec8ff,#4bbcff);
            color: white;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.25s;
        }

            .submit-btn:hover {
                transform: scale(1.05);
                box-shadow: 0 6px 15px rgba(0,0,0,0.15);
            }
    </style>