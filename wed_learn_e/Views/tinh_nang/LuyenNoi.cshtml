@model wed_learn_e.Models.bai_luyen_noi

@{
    ViewBag.Title = "Thực hành Luyện Nói";
    Layout = "~/Views/Shared/_Layoutcauhoi.cshtml";
    var danhSach = ViewBag.DanhSachBaiNoi as List<wed_learn_e.Models.bai_luyen_noi>;
}

<style>
    body {
        background: #f4f9ff;
        font-family: Arial, sans-serif;
        margin: 0;
    }

    .speak-container {
        display: flex;
        max-width: 1000px;
        margin: 40px auto;
        gap: 20px;
        padding: 0 20px;
    }

    /* Cột danh sách (Bên trái) */
    .list-sidebar {
        width: 300px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        padding: 20px;
        height: fit-content;
        max-height: 600px;
        overflow-y: auto;
    }

    .list-title {
        font-size: 18px;
        font-weight: bold;
        color: #1a73e8;
        margin-bottom: 15px;
        border-bottom: 2px solid #eef7ff;
        padding-bottom: 10px;
    }

    .list-item {
        display: block;
        padding: 12px;
        margin-bottom: 10px;
        border-radius: 8px;
        background: #f9f9f9;
        text-decoration: none;
        color: #333;
        transition: 0.2s;
        border-left: 4px solid transparent;
    }

        .list-item:hover {
            background: #eef7ff;
            border-left-color: #1a73e8;
        }

        .list-item.active {
            background: #e6f4ff;
            border-left-color: #0d6efd;
            font-weight: bold;
            color: #0d6efd;
        }

    /* Khu vực luyện nói (Bên phải) */
    .practice-area {
        flex-grow: 1;
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        padding: 40px;
        text-align: center;
    }

    .badge {
        background: #e6f4ff;
        color: #0d6efd;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 14px;
        font-weight: bold;
        display: inline-block;
        margin-bottom: 20px;
    }

    .target-text {
        font-size: 32px;
        font-weight: bold;
        color: #333;
        margin-bottom: 10px;
    }

    .target-pronounce {
        font-size: 18px;
        color: #e65100;
        margin-bottom: 10px;
        font-style: italic;
    }

    .target-meaning {
        font-size: 16px;
        color: #666;
        margin-bottom: 30px;
    }

    /* Nút bấm */
    .controls {
        display: flex;
        justify-content: center;
        gap: 20px;
        margin-bottom: 30px;
    }

    .btn-action {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        border: none;
        font-size: 24px;
        cursor: pointer;
        transition: 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .btn-listen {
        background: #fff;
        color: #1a73e8;
        border: 2px solid #1a73e8;
    }

        .btn-listen:hover {
            background: #eef7ff;
        }

    .btn-mic {
        background: #dc3545;
        color: white;
    }

        .btn-mic:hover {
            background: #c82333;
            transform: scale(1.1);
        }

    /* Hiệu ứng khi đang ghi âm */
    .recording {
        animation: pulse 1.5s infinite;
        background: #ff0000 !important;
    }

    @@keyframes pulse {
        0% {
            box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.7);
        }

        70% {
            box-shadow: 0 0 0 15px rgba(220, 53, 69, 0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(220, 53, 69, 0);
        }
    }

    /* Kết quả trả về */
    .result-box {
        margin-top: 20px;
        padding: 20px;
        border-radius: 10px;
        font-size: 18px;
        display: none;
    }

    .result-correct {
        background: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
        display: block;
    }

    .result-wrong {
        background: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
        display: block;
    }

    .your-speech {
        font-weight: bold;
        color: #000;
        margin-top: 10px;
        font-size: 20px;
    }
</style>

<div class="speak-container">

    <div class="list-sidebar">
        <div class="list-title">Danh sách bài tập</div>
        @foreach (var item in danhSach)
        {
            <a href="@Url.Action("LuyenNoi", "tinh_nang", new { id_cap_do = ViewBag.IdCapDo, id_bai_noi = item.id_bai_noi })"
               class="list-item @(Model.id_bai_noi == item.id_bai_noi ? "active" : "")">
                @(item.loai_bai_noi == "tu_vung" ? "📝" : "🗣") @item.noi_dung_goc
            </a>
        }
    </div>

    <div class="practice-area">
        <div class="badge">@(Model.loai_bai_noi == "tu_vung" ? "Luyện Đọc Từ Vựng" : "Luyện Đọc Câu")</div>

        <div class="target-text" id="targetText">@Model.noi_dung_goc</div>
        <div class="target-pronounce">@Model.phien_am</div>
        <div class="target-meaning">@Model.nghia_tieng_viet</div>

        <div class="controls">
            <button class="btn-action btn-listen" id="btnListen" title="Nghe mẫu">🔊</button>

            <button class="btn-action btn-mic" id="btnMic" title="Bấm để nói">🎤</button>
        </div>

        <p id="statusText" style="color: #888;">Bấm vào biểu tượng Micro và đọc to đoạn văn bản trên.</p>

        <div id="resultBox" class="result-box">
            <div id="resultMessage"></div>
            <div>Bạn vừa đọc là: <span id="yourSpeech" class="your-speech">...</span></div>
        </div>
    </div>
</div>

<script>
    // 1. CHỨC NĂNG NGHE MẪU (Text-to-Speech)
    document.getElementById("btnListen").addEventListener("click", function () {
        var textToRead = document.getElementById("targetText").innerText;
        var utterance = new SpeechSynthesisUtterance(textToRead);
        utterance.lang = 'en-US'; // Giọng Mỹ chuẩn
        utterance.rate = 0.9; // Tốc độ đọc hơi chậm lại chút cho dễ nghe
        window.speechSynthesis.speak(utterance);
    });

    // 2. CHỨC NĂNG NHẬN DIỆN GIỌNG NÓI HỌC VIÊN (Speech-to-Text)
    var btnMic = document.getElementById("btnMic");
    var statusText = document.getElementById("statusText");
    var resultBox = document.getElementById("resultBox");
    var resultMessage = document.getElementById("resultMessage");
    var yourSpeech = document.getElementById("yourSpeech");

    // Kiểm tra trình duyệt có hỗ trợ Web Speech API không (Google Chrome hỗ trợ rất tốt)
    window.SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

    if (window.SpeechRecognition) {
        var recognition = new SpeechRecognition();
        recognition.lang = 'en-US'; // Bắt buộc nhận diện tiếng Anh
        recognition.interimResults = false;
        recognition.maxAlternatives = 1;

        // Bắt đầu ghi âm khi bấm nút Mic
        btnMic.addEventListener("click", function () {
            recognition.start();
            btnMic.classList.add("recording");
            statusText.innerText = "Đang nghe... Hãy đọc đi!";
            resultBox.className = "result-box"; // Ẩn kết quả cũ
        });

        // Xử lý khi có kết quả trả về
        recognition.onresult = function (event) {
            var speechResult = event.results[0][0].transcript;
            var targetText = document.getElementById("targetText").innerText;

            // Xử lý chuỗi (Chuyển hết thành chữ thường và xóa dấu câu để so sánh chính xác)
            var cleanSpeech = speechResult.toLowerCase().replace(/[.,?!]/g, "").trim();
            var cleanTarget = targetText.toLowerCase().replace(/[.,?!]/g, "").trim();

            yourSpeech.innerText = speechResult; // Hiển thị nguyên gốc những gì học viên đọc

            if (cleanSpeech === cleanTarget) {
                // Đọc ĐÚNG
                resultBox.className = "result-box result-correct";
                resultMessage.innerHTML = "🎉 <b>Tuyệt vời!</b> Bạn phát âm rất chuẩn!";

                // (Tùy chọn) Chỗ này bạn có thể gọi AJAX gửi dữ liệu về Server để lưu điểm
            } else {
                // Đọc SAI
                resultBox.className = "result-box result-wrong";
                resultMessage.innerHTML = "❌ <b>Chưa chính xác.</b> Bạn hãy thử nghe mẫu và đọc lại nhé.";
            }
        };

        // Xử lý khi kết thúc thu âm
        recognition.onspeechend = function () {
            recognition.stop();
            btnMic.classList.remove("recording");
            statusText.innerText = "Bấm vào biểu tượng Micro và đọc to đoạn văn bản trên.";
        };

        // Xử lý nếu gặp lỗi (chưa cấp quyền Mic...)
        recognition.onerror = function (event) {
            btnMic.classList.remove("recording");
            statusText.innerText = "Có lỗi xảy ra: " + event.error + ". Hãy đảm bảo bạn đã cấp quyền sử dụng Micro cho trình duyệt.";
        };

    } else {
        statusText.innerText = "Trình duyệt của bạn không hỗ trợ nhận diện giọng nói. Vui lòng sử dụng Google Chrome.";
        btnMic.style.display = "none";
    }
</script>