
@{
    ViewBag.Title = "Trang chủ";
    Layout = null;
}
@using PagedList
@using PagedList.Mvc
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title</title>
    <style>

        body {
            margin: 0;
            font-family: Arial;
            background: white;
        }


        /* HEADER */

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: linear-gradient(360deg, #e5e5e5, #f4b400);
            padding: 20px 60px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.1);
            border-bottom-left-radius: 50px;
            border-bottom-right-radius: 50px;
        }

        .logo {
            font-size: 24px;
            font-weight: bold;
            color: white;
            cursor: pointer;
        }

        .logo {
            position: relative; /* Làm gốc tọa độ cho 2 ảnh bên trong */
            width: 80px; /* Khai báo chiều rộng cụ thể */
            height: 80px; /* Khai báo chiều cao (tùy chỉnh theo ảnh của bạn) */
        }

            .logo img {
                position: absolute; /* Chồng 2 ảnh lên nhau */
                top: 0;
                left: 0;
                width: 160px;
                transition: opacity 0.6s ease; /* Thời gian chuyển từ từ (0.6 giây) */
            }

            /* Ảnh 2 mặc định sẽ bị ẩn đi */
            .logo .img-2 {
                opacity: 0;
                z-index: 2; /* Nằm trên ảnh 1 */
            }

            /* Ảnh 1 mặc định hiện ra */
            .logo .img-1 {
                opacity: 1;
                z-index: 1;
            }

            /* Khi rà chuột vào khu vực .logo */
            .logo:hover .img-2 {
                opacity: 1; /* Hiện ảnh 2 lên */
            }

            .logo:hover .img-1 {
                opacity: 0; /* Ẩn ảnh 1 đi */
            }

        .login {
            color: white;
            display: flex;
            align-items: center; /* Căn giữa tất cả theo chiều dọc */
            gap: 15px; /* Tạo khoảng cách đều giữa cụm Avatar và nút Đăng xuất */
        }

            .login button {
                /* Đã bỏ margin-left vì dùng gap ở trên rồi */
                padding: 8px 18px;
                border: none;
                border-radius: 20px;
                background: white;
                color: #4f83cc;
                font-weight: bold;
                cursor: pointer;
                transition: 0.3s; /* Thêm tí mượt mà khi hover */
            }

                .login button:hover {
                    background: #2dafff;
                    color: white; /* Sửa màu chữ khi hover cho đẹp hơn */
                }


        /* HERO */

        .hero {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 80px;
        }


        /* LEFT IMAGE */

        .hero-left img {
            width: 420px;
        }


        /* RIGHT TEXT */

        .hero-right {
            margin-left: 80px;
        }

        .title {
            color: #f4b400;
        }

        .hero-right h1 {
            color: #4f83cc;
            font-size: 36px;
        }


        .start-btn {
            margin-top: 30px;
            padding: 15px 35px;
            border: none;
            border-radius: 10px;
            background: #4786e3;
            color: white;
            font-size: 18px;
            cursor: pointer;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
        }

            .start-btn:hover {
                background: #2dafff;
            }

        a {
            text-decoration: none;
            color: white;
            border-bottom: 5px solid transparent;
        }

        .footer {
            background: #4786e3;
            padding: 50px 0;
            color: white;
        }

        .footer-container {
            width: 80%;
            margin: auto;
            display: flex;
            justify-content: space-between;
        }

        .footer-col {
            width: 30%;
        }

            .footer-col h2,
            .footer-col h3 {
                margin-bottom: 15px;
            }

            .footer-col p {
                margin: 8px 0;
            }

            .footer-col a {
                color: white;
            }

        .gioi_thieu_khoa_hoc {
            width: 70%;
            margin: 40px auto;
            background: #ffffff;
            padding: 30px 35px;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            font-family: Arial, sans-serif;
            line-height: 1.7;
            background: beige;
        }

            .gioi_thieu_khoa_hoc p {
                font-size: 17px;
                color: #333;
                text-align: justify;
            }

                .gioi_thieu_khoa_hoc p::first-line {
                    font-weight: bold;
                    font-size: 20px;
                    color: #2c7be5;
                }

        /* --- PHẦN 1: TÍNH NĂNG (ZIGZAG GIỐNG ẢNH MẪU) --- */
        .gioi_thieu_cac_uu_dai {
            width: 100%;
            background: white;
            padding: 40px 0;
        }

        .feature-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 40px 12%;
            gap: 60px;
        }

            /* Đảo ngược vị trí cho khối thứ 2 */
            .feature-row.reverse {
                flex-direction: row-reverse;
            }

        .feature-content {
            flex: 1;
        }

            /* Ép chữ căn lề phải cho khối 1 giống hệt trong ảnh */
            .feature-content.right-align {
                text-align: right;
            }

            .feature-content.left-align {
                text-align: left;
            }

            .feature-content h2 {
                color: #4786e3; /* Màu xanh giống header của bạn */
                font-size: 26px;
                margin-bottom: 20px;
                line-height: 1.4;
            }

            .feature-content p {
                font-size: 16px;
                color: #333;
                line-height: 1.6;
            }

        .feature-image {
            flex: 1.2; /* Cho ảnh to hơn chữ một tí */
            text-align: center;
        }

            .feature-image img {
                width: 100%;
                max-width: 500px;
                height: auto;
                border-radius: 10px;
                box-shadow: 0 10px 25px rgba(0,0,0,0.1); /* Đổ bóng cho ảnh app nổi lên */
            }


        /* --- PHẦN 2: BÌNH LUẬN CỦA HỌC VIÊN --- */
        .testimonials-section {
            background: #f8f9fa; /* Nền xám rất nhạt để phân biệt với phần 1 */
            padding: 70px 10%;
            text-align: center;
        }

            .testimonials-section h2 {
                color: #4786e3;
                font-size: 30px;
                margin-bottom: 50px;
            }

        .testimonial-grid {
            display: flex;
            gap: 30px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .testimonial-card {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            width: 320px;
            text-align: left;
            position: relative;
        }

            /* Dấu ngoặc kép trang trí */
            .testimonial-card::before {
                content: "❝";
                font-size: 50px;
                color: #e5e5e5;
                position: absolute;
                top: 10px;
                right: 20px;
            }

        .user-info {
            display: flex;
            align-items: center;
            margin-bottom: 15px;
        }

            .user-info img {
                width: 60px;
                height: 60px;
                border-radius: 50%;
                margin-right: 15px;
                object-fit: cover;
            }

        .user-name {
            font-weight: bold;
            color: #333;
            font-size: 16px;
        }

        .user-role {
            font-size: 14px;
            color: #f4b400; /* Màu vàng giống header của bạn */
            font-weight: bold;
        }

        .comment {
            color: #555;
            font-size: 15px;
            font-style: italic;
            line-height: 1.6;
        }

        .user {
            color: white;
            font-weight: bold;
        }

            .user:hover {
                color: #2dafff;
            }
        /* --- CSS CHO THANH PHÂN TRANG (PAGINATION) --- */
        .pagination {
            display: inline-flex;
            padding-left: 0;
            list-style: none;
            justify-content: center;
            margin-top: 20px;
        }

            .pagination li {
                margin: 0 5px;
            }

                .pagination li a, .pagination li span {
                    display: block;
                    padding: 10px 18px;
                    color: #4786e3;
                    text-decoration: none;
                    background-color: #fff;
                    border: 1px solid #ddd;
                    border-radius: 8px;
                    font-weight: bold;
                    font-size: 16px;
                    transition: 0.3s;
                }

                    .pagination li a:hover {
                        background-color: #f8f9fa;
                        color: #0b5ed7;
                        border-color: #4786e3;
                    }

            /* Nút của trang hiện tại đang đứng */
            .pagination .active span {
                background-color: #4786e3;
                color: white;
                border-color: #4786e3;
            }

            /* Nút bị mờ (Ví dụ: Đang ở trang 1 thì nút "Lùi lại" bị mờ) */
            .pagination .disabled span {
                color: #ccc;
                cursor: not-allowed;
                background-color: #f9f9f9;
            }
        /* CSS cho khối Avatar và Tên trên thanh Nav */
        .user-profile-nav {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 5px 10px !important;
            color: white; /* Đảm bảo tên màu trắng */
            text-decoration: none; /* Bỏ gạch chân */
        }

            .user-profile-nav img {
                width: 35px;
                height: 35px;
                border-radius: 50%;
                object-fit: cover;
                border: 2px solid white; /* Thêm viền trắng mỏng cho ảnh nổi bật */
                box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            }

        .user-profile-name {
            font-size: 15px;
        }

        .dk:hover {
            color: #2295d682;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <!-- HEADER -->
    <header>
        <div class="logo">
            <img src="@Url.Content("~/Img/Gemini_Generated_Image_khrd5ikhrd5ikhrd-removebg-preview.png")"
                 class="img-1" alt="">
            <img src="@Url.Content("~/Img/Gemini_Generated_Image_pj8wj4pj8wj4pj8w-removebg-preview.png")"
                 class="img-2" alt="" onclick="location.href='@Url.Action("Index","Trang_chu")'">
        </div>
        @if (Session["TenDN"] != null)
        {
            <div class="login">
                <a href="@Url.Action("TrangCaNhan", "User")" class="user-profile-nav">
                    <img src="@(Session["Avatar"] == null ? "https://ui-avatars.com/api/?name=" + Session["HoTen"]?.ToString().Replace(" ", "+") + "&background=random" : Url.Content("~/Images/Avatars/" + Session["Avatar"]))" alt="Avatar">

                    <span class="user-profile-name">@Session["HoTen"]</span>
                </a>
                <button onclick="location.href='@Url.Action("DangXuat","User")'">Đăng xuất</button>
            </div>
        }
        else
        {
    <div class="login">
        <p>

            @if (HttpContext.Current.Application["ChoPhepDangKy"] != null && (bool)HttpContext.Current.Application["ChoPhepDangKy"] == false)
            {
                <span style="color: gray; font-style: italic;">(Đăng ký hiện đang đóng)</span>
            }
            else
            {
                <a href="@Url.Action("dangky","User")" class="dk">Bạn đã có tài khoản?</a>
            }
        </p>
        <button onclick="location.href='@Url.Action("dangnhap","User")'">Đăng nhập</button>
    </div>
        }

    </header>


    <!-- HERO / BANNER -->
    <section class="hero">

        <div class="hero-left">
            <img src="@Url.Content("~/Img/Gemini_Generated_Image_xdycdaxdycdaxdyc-removebg-preview (1).png")" alt="Học tiếng Anh online">
        </div>

        <div class="hero-right">


            <img src="@Url.Content("~/Img/Gemini_Generated_Image_khrd5ikhrd5ikhrd-removebg-preview.png")" style="width :420px">
            <h1>
            </h1>

            <button class="start-btn" onclick="location.href='@Url.Action("khoadaotao","Page")'">
                Chọn khóa đào tạo
            </button>
            <button class="start-btn" onclick="location.href='@Url.Action("thong_tin_bai_test","bai_test")'">
                Bắt đầu làm bài test
            </button>
           @if (Session["TenDN"] != null)
            {
                <button class="start-btn" onclick="location.href='@Url.Action("TrangMuaVIP","Page")'">
                    Nâng cấp tài khoản
                </button>
            }

        </div>

    </section>
    <div class="gioi_thieu_khoa_hoc">
        <p>
            Giới thiệu

            Trang web học tiếng Anh của chúng tôi được tạo ra với mục tiêu giúp người học tiếp cận tiếng Anh một cách dễ dàng và thú vị. Thay vì chỉ học lý thuyết khô khan, người dùng có thể vừa học vừa chơi thông qua các bài quiz, trò chơi từ vựng và các bài tập tương tác.

            Trang web cung cấp nhiều nội dung như bài test từ vựng, bài tập ngữ pháp và trò chơi tiếng Anh, giúp người học ghi nhớ kiến thức nhanh hơn và luyện tập thường xuyên. Với giao diện đơn giản, dễ sử dụng, người học ở mọi trình độ đều có thể tham gia.

            Chúng tôi mong muốn tạo ra một môi trường học tập vui vẻ, hiệu quả và dễ tiếp cận, giúp mọi người cải thiện kỹ năng tiếng Anh mỗi ngày.
        </p>
    </div>
    <div class="gioi_thieu_cac_uu_dai">

        <div class="feature-row">
            <div class="feature-content right-align">
                <h2>Lộ trình cá nhân hóa<br>ứng dụng Adaptive Learning</h2>
                <p>Trang web áp dụng Adaptive Learning, cá nhân hóa lộ trình học theo trình độ và mục tiêu của bạn. Hệ thống giúp xác định điểm mạnh, điểm yếu ở từng kỹ năng và gợi ý nhiệm vụ luyện tập chi tiết.</p>
            </div>
            <div class="feature-image">
                <img src="https://images.unsplash.com/photo-1611162617474-5b21e879e113?w=600&q=80" alt="Giao diện 1">
            </div>
        </div>

        <div class="feature-row reverse">
            <div class="feature-content left-align">
                <h2>Luyện tập hiệu quả với<br>Hệ thống Learn - Practice - Test</h2>
                <p>Kho bài giảng, bài luyện và bài thi chuẩn xác, phù hợp với mọi trình độ. Học đúng lộ trình, luyện tập thông minh, tăng trình độ hiệu quả cùng hệ thống của chúng tôi.</p>
            </div>
            <div class="feature-image">
                <img src="https://images.unsplash.com/photo-1531403009284-440f080d1e12?w=600&q=80" alt="Giao diện 2">
            </div>
        </div>

    </div>

    <div class="testimonials-section" id="khu-vuc-binh-luan">
        <h2>Học viên nói gì về chúng tôi?</h2>

        <div class="testimonial-grid">
            @{
                // ÉP KIỂU LẠI THÀNH IPagedList
                var listBinhLuan = ViewBag.DanhSachBinhLuan as IPagedList<wed_learn_e.Models.binh_luan>;

                if (listBinhLuan != null && listBinhLuan.Count > 0)
                {
                    string[] colors = { "f4b400", "4786e3", "28a745", "dc3545", "17a2b8" };
                    int colorIndex = 0;

                    foreach (var item in listBinhLuan)
                    {
                        string tenHocVien = (item.nguoi_dung != null) ? item.nguoi_dung.ho_va_ten : "Học viên";
                        string tenAvatar = tenHocVien.Replace(" ", "+");
                        string bgColor = colors[colorIndex % colors.Length];
                        colorIndex++;

                        // Kiểm tra xem bình luận này có phải của Admin không
                        bool isAdmin = (item.nguoi_dung != null && item.nguoi_dung.vai_tro == "quan_tri_vien");

                        // Nếu là Admin thì thêm style viền vàng cho nổi bật
                        <div class="testimonial-card" style="@(isAdmin ? "border: 2px solid #f4b400; background: #fffcf0;" : "")">

                            @if (isAdmin)
                            {
                                <div style="position: absolute; top: -12px; left: 20px; background: #f4b400; color: white; padding: 3px 12px; border-radius: 12px; font-size: 12px; font-weight: bold;">
                                    📌 Thông báo Admin
                                </div>
                            }

                            <div class="user-info">
                                <img src="https://ui-avatars.com/api/?name=@tenAvatar&background=@(isAdmin ? "f4b400" : bgColor)&color=fff" alt="User">
                                <div>
                                    <div class="user-name" style="@(isAdmin ? "color: red;" : "")">
                                        @tenHocVien @(isAdmin ? "✔" : "")
                                    </div>
                                    <div class="user-role">
                                        @if (isAdmin)
                                        {
                                            <span>Quản trị viên KityLearn</span>
                                        }
                                        else
                                        {
                                            @* HIỂN THỊ TRẠNG THÁI TRẢ LỜI CHO USER *@
                                            if (item.trang_thai == true)
                                            {
                                                <span style="color: #28a745; font-weight: bold;"><i class="fas fa-check-double"></i> Đã được hỗ trợ</span>
                                            }
                                            else
                                            {
                                                <span style="color: #888;">🕒 Đang chờ phản hồi</span>
                                            }
                                        }
                                    </div>
                                </div>
                            </div>
                            <div class="comment">"@item.noi_dung"</div>
                        </div>
                    }
                }
                else
                {
                    <p style="color: #888; font-style: italic;">Chưa có đánh giá nào từ học viên.</p>
                }
            }
        </div>

        <div style="text-align: center; margin-top: 40px;">
            @if (listBinhLuan != null && listBinhLuan.PageCount > 1)
            {
                // Thêm cái mỏ neo #khu-vuc-binh-luan vào cuối đường link
                @Html.PagedListPager(listBinhLuan, page => Url.Action("Index", new { page }) + "#khu-vuc-binh-luan")
            }
        </div>
        <div style="text-align: center; margin: 40px 0;">
            <button class="start-btn" onclick="location.href='@Url.Action("LienHe", "Trang_chu")'" style="padding: 15px 40px; font-size: 20px;">
                📞 Liên Hệ & Đóng Góp Ý Kiến
            </button>
        </div>
    </div>

    <footer class="footer">

        <div class="footer-container">

            <div class="footer-col">
                <a href="#"><h2>TRANG CHỦ</h2></a>

                <p><b>Liên hệ</b></p>
                <p>0123456789</p>
                <p>123@gmail.com</p>

                <a href="#">Tư vấn về học tập</a>
            </div>


            <div class="footer-col">
                <h3>Câu hỏi thường gặp</h3>

                <p>Kitting  hoạt động như thế nào?</p>
                <p>Kitting có miễn phí không?</p>
                <p>Hướng dẫn thanh toán Kitting</p>
                <p>Đăng ký mua Kitting</p>
                <p>Adaptive Learning là gì?</p>
            </div>


            <div class="footer-col">
                <h3>Cộng đồng</h3>

                <a href="#">fb</a><br>
                <a href="#">yt</a>
            </div>

        </div>

    </footer>
</body>
</html>

