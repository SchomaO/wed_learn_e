@model List<wed_learn_e.Models.ngu_phap>


@{
    ViewBag.Title = "Khóa Học Ngữ Pháp";
    Layout = "~/Views/Shared/_Layoutcauhoi.cshtml";
}

<style>

    body {
        background: #f4f7fb;
    }

    /* banner */

    .banner {
        width: 100%;
        padding: 60px 20px;
        text-align: center;
        background: linear-gradient(135deg,#4facfe,#00f2fe);
        color: white;
    }

        .banner h1 {
            font-size: 40px;
            font-weight: bold;
        }

        .banner p {
            font-size: 18px;
            opacity: 0.9;
        }

    /* container */

    .grammar-container {
        width: 90%;
        margin: 50px auto;
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(240px,1fr));
        gap: 25px;
    }

    /* card */

    /* container */
    .grammar-container {
        width: 90%;
        margin: 50px auto;
        /* CHUYỂN SANG FLEXBOX ĐỂ CỐ ĐỊNH KÍCH THƯỚC */
        display: flex;
        flex-wrap: wrap; /* Cho phép rớt dòng nếu hết chỗ */
        justify-content: center; /* Căn giữa toàn bộ các thẻ */
        gap: 25px;
    }

    /* card */
    .grammar-card {
        background: white;
        border-radius: 15px;
        padding: 30px;
        text-align: center;
        box-shadow: 0 6px 15px rgba(0,0,0,0.1);
        transition: 0.3s;
        position: relative;
        /* CỐ ĐỊNH KÍCH THƯỚC THẺ TẠI ĐÂY */
        width: 260px; /* Chiều rộng cố định */
        flex: 0 0 auto; /* Không cho phép bóp méo hay kéo giãn thẻ */
        /* (Mẹo nhỏ) Giúp nút "Học ngay" luôn nằm ở dưới cùng cho dù phần mô tả dài ngắn khác nhau */
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    /* icon */

    .icon {
        font-size: 40px;
        margin-bottom: 15px;
    }

    /* title */

    .lesson-title {
        font-size: 20px;
        font-weight: bold;
        color: #0d6efd;
    }

    /* description */

    .lesson-desc {
        margin-top: 10px;
        color: #666;
        font-size: 14px;
    }

    /* button */

    .btn-learn {
        display: inline-block;
        margin-top: 18px;
        padding: 8px 18px;
        border-radius: 6px;
        background: #0d6efd;
        color: white;
        text-decoration: none;
    }

        .btn-learn:hover {
            background: #0b5ed7;
        }

    /* mascot */

    .cat-mascot {
        position: fixed;
        bottom: 20px;
        right: 20px;
    }

    .cat-text {
        position: absolute;
        bottom: 70px;
        right: 0;
        background: white;
        padding: 6px 10px;
        border-radius: 10px;
        font-size: 14px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    }
</style>


<div class="banner">

    <h1>Khóa Học Ngữ Pháp Tiếng Anh</h1>

    <p>
        Học ngữ pháp từ cơ bản đến nâng cao một cách dễ hiểu.
    </p>

</div>
@Html.Partial("_NutQuayLai", new ViewDataDictionary {
  // Thêm đoạn new { id = ... } để hệ thống tạo ra link có đuôi /1
  { "LinkQuayVe", Url.Action("thong_tin_khoa_hoc", "Page", new { id = Request.QueryString["id_cap_do"] }) },
  { "TieuDe", " "  }
})


<div class="grammar-container">
    @if (Model != null && Model.Count > 0)
    {
        foreach (var item in Model)
        {
            <div class="grammar-card">
                <div class="icon">@item.icon</div>
                <div class="lesson-title">@item.tieu_de</div>
                <div class="lesson-desc">@item.mo_ta_ngan</div>

                <a href="@Url.Action("ChiTietNguPhap", "Page", new { id = item.id_ngu_phap, id_cap_do = ViewBag.IdCapDo })" class="btn-learn">
                    Học ngay
                </a>
            </div>
        }
    }
    else
    {
        <div style="text-align: center; grid-column: 1 / -1; color: #888;">Chưa có bài ngữ pháp nào!</div>
    }
</div>

<div class="cat-mascot">

    <img src="https://cdn-icons-png.flaticon.com/512/763/763704.png" width="55">

    <div class="cat-text">
        Grammar makes English easier!
    </div>

</div>