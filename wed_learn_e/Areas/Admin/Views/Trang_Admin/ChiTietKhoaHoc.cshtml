@model IEnumerable<wed_learn_e.Models.tien_do_hoc_tap>
@{
    ViewBag.Title = "Admin - Quản lý khóa học của học viên";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
    var hocVien = ViewBag.HocVien as wed_learn_e.Models.nguoi_dung;
    var khoaChuaHoc = ViewBag.KhoaChuaHoc as IEnumerable<wed_learn_e.Models.khoa_hoc>;
}

@* Phần Header có chứa nút Quay lại *@
<div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 mb-6 flex justify-between items-center">
    <div>
        <h2 class="text-2xl font-bold text-gray-800">Quản lý khóa học</h2>
        <p class="text-gray-500 mt-1">Đang thao tác trên học viên: <b class="text-indigo-600">@hocVien.ho_va_ten (@hocVien.email)</b></p>
    </div>

    @* Nút Quay lại trang danh sách (Dùng Url.Action để trỏ về trang Index) *@
    <a href="@Url.Action("Index")" class="flex items-center gap-2 bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold py-2.5 px-5 rounded-lg transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
        </svg>
        Quay lại danh sách
    </a>
</div>

@* Khu vực Thêm khóa học mới *@
<div class="bg-gray-50 p-6 rounded-xl border border-gray-200 mb-6 flex gap-4 items-center">
    <select id="cbKhoaHocMoi" class="flex-1 p-3 border border-gray-300 rounded-lg">
        <option value="">-- Chọn khóa học muốn cấp quyền --</option>

        @{
            // Gộp nhóm các khóa học chưa học theo ID Cấp độ (sắp xếp từ thấp lên cao)
            var khoaTheoCap = khoaChuaHoc.GroupBy(k => k.id_cap_do).OrderBy(g => g.Key);
        }

        @foreach (var nhomCapDo in khoaTheoCap)
        {
            <optgroup label="⭐ CẤP ĐỘ @nhomCapDo.Key">
                @foreach (var k in nhomCapDo)
                {
                    <option value="@k.id_khoa_hoc">@k.ten_khoa_hoc</option>
                }
            </optgroup>
        }
    </select>

    <button id="btnThemKhoa" class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 px-6 rounded-lg transition whitespace-nowrap">
        + Thêm khóa học
    </button>
</div>

@* Bảng danh sách khóa học ĐANG CÓ *@
<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <table class="w-full text-left border-collapse">
        <thead>
            <tr class="bg-gray-100 text-gray-500 text-xs uppercase font-semibold">
                <th class="px-6 py-4">Tên khóa học</th>
                <th class="px-6 py-4">Cấp độ</th>
                <th class="px-6 py-4 text-right">Thao tác</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 text-sm" id="bangKhoaHoc">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr class="hover:bg-gray-50 transition">
                        <td class="px-6 py-4 font-bold text-gray-700">@item.khoa_hoc.ten_khoa_hoc</td>
                        <td class="px-6 py-4 text-gray-500">Cấp @item.khoa_hoc.id_cap_do</td>
                        <td class="px-6 py-4 text-right">
                            <button onclick="xoaKhoaHoc(@item.id_khoa_hoc)" class="bg-red-100 text-red-600 hover:bg-red-200 px-3 py-1.5 rounded text-xs font-bold transition">
                                <i class="fas fa-trash"></i> Thu hồi (Xóa)
                            </button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="3" class="px-6 py-8 text-center text-gray-400 italic">Học viên này chưa đăng ký khóa học nào.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    var userId = @hocVien.id_nguoi_dung;

    // THÊM KHÓA HỌC BẰNG AJAX
    $("#btnThemKhoa").click(function () {
        var idKhoaHoc = $("#cbKhoaHocMoi").val();
        if (!idKhoaHoc) {
            alert("Vui lòng chọn 1 khóa học để thêm!");
            return;
        }

        $.ajax({
            type: "POST",
            url: '@Url.Action("ThemKhoaHocChoHocVien")',
            data: { id_nguoi_dung: userId, id_khoa_hoc: idKhoaHoc },
            success: function (res) {
                if (res.success) {
                    alert(res.message);
                    location.reload(); // Load lại trang để cập nhật bảng
                } else {
                    alert(res.message);
                }
            }
        });
    });

    // XÓA KHÓA HỌC BẰNG AJAX
    function xoaKhoaHoc(idKhoaHoc) {
        if (confirm("Bạn có chắc chắn muốn gỡ khóa học này khỏi học viên không?")) {
            $.ajax({
                type: "POST",
                url: '@Url.Action("XoaKhoaHocCuaHocVien")',
                data: { id_nguoi_dung: userId, id_khoa_hoc: idKhoaHoc },
                success: function (res) {
                    if (res.success) {
                        alert(res.message);
                        location.reload(); // Load lại trang
                    } else {
                        alert(res.message);
                    }
                }
            });
        }
    }
</script>