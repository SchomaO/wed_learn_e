@model IEnumerable<wed_learn_e.Models.nguoi_dung>

@{
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

@* 1. Phần thống kê nhanh *@
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
        <p class="text-gray-500 text-sm font-medium">Tổng người dùng</p>
        <h3 class="text-3xl font-bold mt-1">@Model.Count()</h3>
        <p class="text-green-500 text-xs mt-2 font-bold"><i class="fas fa-users"></i> Dữ liệu thực tế</p>
    </div>
    <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 flex justify-between items-center">
        <div>
            <p class="text-gray-500 text-sm font-medium">Cấu hình hệ thống</p>
            <h3 class="text-xl font-bold mt-1 text-gray-800">Giới hạn học thử</h3>
        </div>
        <button onclick="openSettingsModal()" class="bg-gray-800 hover:bg-black text-white p-3 rounded-lg shadow transition">
            <i class="fas fa-cog"></i> Cài đặt
        </button>
    </div>
</div>

@* 2. Bảng hiển thị danh sách người dùng *@
<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="p-6 border-b border-gray-50 flex justify-between items-center">
        <h3 class="font-bold text-lg text-gray-700">Danh sách tài khoản</h3>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wider font-semibold">
                    <th class="px-6 py-4">Người dùng</th>
                    <th class="px-6 py-4">Tài khoản & Ngày tạo</th>
                    <th class="px-6 py-4 text-center whitespace-nowrap">Vai trò</th>
                    <th class="px-6 py-4 text-center">Trạng thái VIP</th>
                    <th class="px-6 py-4 text-center">Khóa học</th>
                    <th class="px-6 py-4 text-right whitespace-nowrap">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 text-sm">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-gray-50 transition" id="user-row-@item.id_nguoi_dung">

                        @* CỘT 1: AVATAR + HỌ TÊN + EMAIL *@
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                @* LOGIC ẢNH ĐẠI DIỆN CHUẨN *@
                                @if (!string.IsNullOrEmpty(item.anh_dai_dien))
                                {
                                    <img src="@Url.Content("~/Images/Avatars/" + item.anh_dai_dien)" onerror="this.src='https://ui-avatars.com/api/?name=@item.ho_va_ten&background=random'" class="w-10 h-10 rounded-full object-cover border border-gray-200" alt="Avatar" />
                                }
                                else
                                {
                                    <img src="https://ui-avatars.com/api/?name=@(string.IsNullOrEmpty(item.ho_va_ten) ? "U" : item.ho_va_ten)&background=random" class="w-10 h-10 rounded-full object-cover border border-gray-200" alt="Avatar" />
                                }

                                <div>
                                    <div class="font-bold text-gray-800">@item.ho_va_ten</div>
                                    <div class="text-xs text-gray-500 mt-0.5">@item.email</div>
                                </div>
                            </div>
                        </td>

                        @* CỘT 2: TÊN ĐĂNG NHẬP + NGÀY TẠO *@
                        <td class="px-6 py-4">
                            <div class="font-medium text-gray-700">@item.ten_dang_nhap</div>
                            <div class="text-xs text-gray-400 mt-0.5">
                                Tham gia: @(item.ngay_tao.HasValue ? item.ngay_tao.Value.ToString("dd/MM/yyyy") : "Chưa cập nhật")
                            </div>
                        </td>

                        @* CỘT 3: VAI TRÒ *@
                        <td class="px-6 py-4 text-center">
                            @if (item.vai_tro == "quan_tri_vien" || item.vai_tro == "admin")
                            {
                                <span class="bg-red-100 text-red-600 px-3 py-1 rounded-full text-[10px] font-bold uppercase whitespace-nowrap">Admin</span>
                            }
                            else
                            {
                                <span class="bg-blue-100 text-blue-600 px-3 py-1 rounded-full text-[10px] font-bold uppercase whitespace-nowrap">Học viên</span>
                            }
                        </td>

                        @* CỘT 4: LOẠI TÀI KHOẢN (VIP) + XỬ LÝ NULL *@
                        <td class="px-6 py-4 text-center">
                            @if (item.loai_tai_khoan == 2)
                            {
                                <span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs font-bold border border-green-200">VIP THÁNG</span>
                            }
                            else if (item.loai_tai_khoan == 3)
                            {
                                <span class="bg-yellow-100 text-yellow-700 px-2 py-1 rounded text-xs font-bold border border-yellow-200">VIP NĂM</span>
                            }
                            else // Gộp cả Null và 1 vào chung
                            {
                                <span class="bg-gray-100 text-gray-500 px-2 py-1 rounded text-xs font-bold border border-gray-200">THƯỜNG</span>
                            }

                            @if (item.ngay_het_han_vip != null)
                            {
                                <div class="text-[11px] text-gray-500 mt-1.5"><i class="fas fa-clock mr-1"></i>HSD: @item.ngay_het_han_vip.Value.ToString("dd/MM/yyyy")</div>
                            }
                        </td>

                        @* CỘT 5: SỐ LƯỢNG KHÓA HỌC *@
                        <td class="px-6 py-4 text-center">
                            <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-indigo-50 font-bold text-indigo-700">
                                @(item.so_luong_khoa_hoc ?? 0)
                            </span>
                        </td>

                        @* CỘT 6: THAO TÁC (Đổi Mật Khẩu, Sửa, Xóa, Khóa học) *@
                        @* CỘT 6: THAO TÁC (Đổi Mật Khẩu, Sửa, Xóa, Khóa học) *@
                        <td class="px-6 py-4 text-right whitespace-nowrap">
                            <div class="flex items-center justify-end gap-2">
                                <button onclick="openPasswordModal(@item.id_nguoi_dung, '@item.ho_va_ten')" class="text-orange-500 hover:text-orange-700 font-bold transition px-2.5 py-1.5 bg-orange-50 rounded hover:bg-orange-100 flex items-center">
                                    <i class="fas fa-key mr-1.5"></i> Đổi MK
                                </button>

                                <button onclick="openEditModal(@item.id_nguoi_dung, '@item.ho_va_ten', '@item.email', '@item.vai_tro', @(item.loai_tai_khoan ?? 1))" class="text-blue-600 hover:text-blue-900 font-bold transition px-2.5 py-1.5 bg-blue-50 rounded hover:bg-blue-100 flex items-center">
                                    <i class="fas fa-edit mr-1.5"></i> Sửa
                                </button>

                                <button onclick="confirmDelete(@item.id_nguoi_dung)" class="text-red-500 hover:text-red-700 font-bold transition px-2.5 py-1.5 bg-red-50 rounded hover:bg-red-100 flex items-center">
                                    <i class="fas fa-trash-alt mr-1.5"></i> Xóa
                                </button>

                                <a href="@Url.Action("ChiTietKhoaHoc", "Trang_Admin", new { id_nguoi_dung = item.id_nguoi_dung })" class="text-indigo-600 hover:text-indigo-900 font-bold transition px-2.5 py-1.5 bg-indigo-50 rounded hover:bg-indigo-100 flex items-center">
                                    <i class="fas fa-book mr-1.5"></i> Khóa học
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div id="editUserModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm hidden z-[9999] flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-6 relative">
        <button onclick="closeEditModal()" class="absolute top-4 right-4 text-gray-400 hover:text-red-500"><i class="fas fa-times text-xl"></i></button>
        <h3 class="text-xl font-bold text-indigo-900 mb-4 border-b pb-2"><i class="fas fa-user-edit mr-2"></i>Chỉnh sửa học viên</h3>

        <input type="hidden" id="edit_user_id" />
        <div class="space-y-4">
            <div>
                <label class="block text-xs font-bold text-gray-500 uppercase">Họ và tên</label>
                <input type="text" id="edit_ho_ten" class="w-full mt-1 border-2 rounded-lg p-2 focus:border-indigo-500 outline-none font-medium" />
            </div>
            <div>
                <label class="block text-xs font-bold text-gray-500 uppercase">Email</label>
                <input type="email" id="edit_email" class="w-full mt-1 border-2 rounded-lg p-2 focus:border-indigo-500 outline-none font-medium" />
            </div>
            <div class="hidden">
                <label class="block text-xs font-bold text-gray-500 uppercase">Vai trò (Quyền)</label>
                <select id="edit_vai_tro" class="w-full mt-1 border-2 rounded-lg p-2 focus:border-indigo-500 outline-none font-bold text-blue-600">
                    <option value="nguoi_dung">Học viên</option>
                    <option value="quan_tri_vien">Quản trị viên (Admin)</option>
                </select>
            </div>
            <div>
                <label class="block text-xs font-bold text-gray-500 uppercase">Loại tài khoản (VIP)</label>
                <select id="edit_loai_tk" class="w-full mt-1 border-2 rounded-lg p-2 focus:border-indigo-500 outline-none font-bold text-green-600">
                    <option value="1">Thường (Miễn phí)</option>
                    <option value="2">VIP Tháng</option>
                    <option value="3">VIP Năm</option>
                </select>
            </div>
        </div>
        <div class="mt-6 flex justify-end gap-3">
            <button onclick="closeEditModal()" class="flex-1 py-2 bg-gray-100 text-gray-700 font-bold rounded-lg hover:bg-gray-200">Hủy</button>
            <button onclick="saveUserChanges()" class="flex-1 py-2 bg-indigo-600 text-white font-bold rounded-lg shadow-lg hover:bg-indigo-700">Lưu thay đổi</button>
        </div>
    </div>
</div>

<div id="passwordModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm hidden z-[9999] flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm p-6 relative">
        <button onclick="closePasswordModal()" class="absolute top-4 right-4 text-gray-400 hover:text-red-500"><i class="fas fa-times text-xl"></i></button>
        <h3 class="text-xl font-bold text-orange-600 mb-2 border-b pb-2"><i class="fas fa-key mr-2"></i>Đổi Mật Khẩu</h3>
        <p class="text-sm text-gray-600 mb-4">Đang đổi mật khẩu cho: <b id="lblPwUserName" class="text-indigo-900"></b></p>

        <input type="hidden" id="pw_user_id" />
        <div class="space-y-4">
            <div>
                <label class="block text-xs font-bold text-gray-500 uppercase">Nhập mật khẩu mới</label>
                <input type="text" id="txtNewPassword" placeholder="Nhập mật khẩu mới..." class="w-full mt-1 border-2 border-orange-200 rounded-lg p-3 font-bold text-lg focus:border-orange-500 outline-none" />
                <p class="text-[11px] text-gray-400 mt-1 italic">*Mật khẩu mới sẽ được áp dụng ngay lập tức.</p>
            </div>
        </div>
        <div class="mt-6 flex gap-3">
            <button onclick="closePasswordModal()" class="flex-1 py-2 bg-gray-100 text-gray-700 font-bold rounded-lg hover:bg-gray-200">Hủy</button>
            <button onclick="saveNewPassword()" class="flex-1 py-2 bg-orange-500 text-white font-bold rounded-lg shadow-lg hover:bg-orange-600">Đổi Mật Khẩu</button>
        </div>
    </div>
</div>
<div id="modalSettings" class="fixed inset-0 bg-black/60 backdrop-blur-sm hidden z-[9999] flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm p-6 relative">
        <button onclick="closeSettingsModal()" class="absolute top-4 right-4 text-gray-400 hover:text-red-500"><i class="fas fa-times text-xl"></i></button>
        <h3 class="text-xl font-bold text-gray-800 mb-4 border-b pb-2"><i class="fas fa-cogs mr-2"></i>Cài đặt hệ thống</h3>

        <div class="space-y-4">
            <div>
                <label class="block text-xs font-bold text-gray-500 uppercase">Giới hạn cấp độ (TK Thường)</label>
                <input type="number" id="txtLimitNormal" min="0" class="w-full mt-1 border-2 border-gray-200 rounded-lg p-3 font-bold text-3xl text-center focus:border-indigo-500 outline-none text-indigo-600" />
                <p class="text-[11px] text-gray-400 mt-2 italic text-center">*Nhập 0 nếu bắt buộc phải mua VIP mới được học. Số càng lớn học thử càng nhiều.</p>
            </div>
        </div>
        <div class="mt-6 flex gap-3">
            <button onclick="closeSettingsModal()" class="flex-1 py-2 bg-gray-100 text-gray-700 font-bold rounded-lg hover:bg-gray-200">Hủy</button>
            <button onclick="saveSettings()" class="flex-1 py-2 bg-gray-800 text-white font-bold rounded-lg shadow-lg hover:bg-black">Lưu Cài Đặt</button>
        </div>
    </div>
</div>
@section scripts {
    <script>
        // --- CHỨC NĂNG SỬA THÔNG TIN ---
        function openEditModal(id, ten, email, vaiTro, loaiTk) {
            $("#edit_user_id").val(id);
            $("#edit_ho_ten").val(ten);
            $("#edit_email").val(email);

            // Gán đúng value cho dropdown (Mặc định nếu lỗi thì về học viên)
            let vTro = (vaiTro == 'quan_tri_vien' || vaiTro == 'admin') ? 'quan_tri_vien' : 'nguoi_dung';
            $("#edit_vai_tro").val(vTro);

            $("#edit_loai_tk").val(loaiTk || 1);
            $("#editUserModal").removeClass("hidden").addClass("flex");
        }

        function closeEditModal() { $("#editUserModal").addClass("hidden").removeClass("flex"); }

        function saveUserChanges() {
            var data = {
                id: $("#edit_user_id").val(),
                ho_ten: $("#edit_ho_ten").val(),
                email: $("#edit_email").val(),
                vai_tro: $("#edit_vai_tro").val(),
                loai_tk: $("#edit_loai_tk").val()
            };

            $.post("/Admin/Trang_Admin/SuaNguoiDung", data, function (res) {
                if (res.success) {
                    alert("✅ " + res.message);
                    location.reload();
                } else {
                    alert("❌ Lỗi: " + res.message);
                }
            });
        }

        // --- CHỨC NĂNG ĐỔI MẬT KHẨU ---
        function openPasswordModal(id, name) {
            $("#pw_user_id").val(id);
            $("#lblPwUserName").text(name);
            $("#txtNewPassword").val(""); // Xóa trắng ô pass
            $("#passwordModal").removeClass("hidden").addClass("flex");
        }

        function closePasswordModal() { $("#passwordModal").addClass("hidden").removeClass("flex"); }

        function saveNewPassword() {
            let pass = $("#txtNewPassword").val().trim();
            if (pass.length < 3) { alert("⚠️ Mật khẩu quá ngắn, vui lòng nhập lại!"); return; }

            if (confirm("Chắc chắn muốn đổi mật khẩu cho người này?")) {
                $.post("/Admin/Trang_Admin/DoiMatKhauNguoiDung", { id: $("#pw_user_id").val(), mat_khau_moi: pass }, function (res) {
                    if (res.success) {
                        alert("✅ " + res.message);
                        closePasswordModal();
                    } else {
                        alert("❌ Lỗi: " + res.message);
                    }
                });
            }
        }
        // --- CHỨC NĂNG CÀI ĐẶT HỆ THỐNG ---
        function openSettingsModal() {
            $.get("/Admin/Trang_Admin/GetCaiDatHeThong", function (res) {
                if (res.success) {
                    $("#txtLimitNormal").val(res.limit);
                    $("#modalSettings").removeClass("hidden").addClass("flex");
                }
            });
        }

        function closeSettingsModal() { $("#modalSettings").addClass("hidden").removeClass("flex"); }

        function saveSettings() {
            let val = $("#txtLimitNormal").val();
            if (val === "") { alert("Vui lòng nhập một con số!"); return; }

            $.post("/Admin/Trang_Admin/LuuCaiDatHeThong", { limit: val }, function (res) {
                if (res.success) {
                    alert("✅ " + res.message);
                    closeSettingsModal();
                } else {
                    alert("❌ Lỗi: " + res.message);
                }
            });
        }
        // --- CHỨC NĂNG XÓA NGƯỜI DÙNG ---
        function confirmDelete(id) {
            if (confirm("Bạn có chắc chắn muốn xóa vĩnh viễn người dùng này và mọi dữ liệu liên quan không?")) {
                $.post("/Admin/Trang_Admin/XoaNguoiDung", { id: id }, function (res) {
                    if (res.success) {
                        alert("✅ " + res.message);
                        // Ẩn dòng đó đi cho hiệu ứng mượt mà (hoặc dùng location.reload() để tải lại trang)
                        $("#user-row-" + id).fadeOut();
                    } else {
                        alert("❌ Lỗi: " + res.message);
                    }
                });
            }
        }
    </script>
}