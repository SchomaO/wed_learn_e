@{
    ViewBag.Title = "Liên Hệ & Hỗ Trợ";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title</title>
    <style>
        body {
            background: #f8f9fa;
            font-family: Arial, sans-serif;
            margin: 0;
        }

        .contact-wrapper {
            width: 85%;
            margin: 50px auto;
            display: flex;
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            overflow: hidden;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: linear-gradient(360deg, #e5e5e5, #f4b400);
            padding: 20px 60px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.1);
            border-bottom-left-radius: 50px;
            border-bottom-right-radius: 50px;
        }

        .login button {
            margin-left: 15px;
            padding: 8px 18px;
            border: none;
            border-radius: 20px;
            background: white;
            color: #4f83cc;
            font-weight: bold;
            cursor: pointer;
        }

            .login button:hover {
                background: #2dafff;
                color: black;
            }

        .user {
            color: white;
            font-weight: bold;
            text-decoration: none;
        }

            .user:hover {
                color: #2dafff;
            }

        /* --- CỘT TRÁI: THÔNG TIN (NỀN XANH) --- */
        .contact-info {
            flex: 4;
            background: linear-gradient(135deg, #0d6efd, #4786e3);
            color: white;
            padding: 40px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

            .contact-info h2 {
                margin-top: 0;
                font-size: 28px;
            }

            .contact-info p {
                line-height: 1.6;
                font-size: 15px;
                opacity: 0.9;
            }

        .info-list {
            margin-top: 30px;
            list-style: none;
            padding: 0;
        }

            .info-list li {
                margin-bottom: 25px;
                display: flex;
                align-items: center;
                font-size: 16px;
            }

                .info-list li span {
                    font-size: 24px;
                    margin-right: 15px;
                }

        .map-container {
            margin-top: 30px;
            border-radius: 10px;
            overflow: hidden;
            height: 200px;
            border: 3px solid rgba(255,255,255,0.2);
        }

        /* --- CỘT PHẢI: FORM ĐIỀN TIN NHẮN --- */
        .contact-form {
            flex: 6;
            padding: 50px 60px;
        }

            .contact-form h2 {
                color: #333;
                margin-top: 0;
                margin-bottom: 30px;
                font-size: 28px;
            }

        .form-group {
            margin-bottom: 20px;
        }

            .form-group label {
                display: block;
                font-weight: bold;
                margin-bottom: 8px;
                color: #555;
            }

        .form-control {
            width: 100%;
            padding: 12px 15px;
            border: 1px solid #ccc;
            border-radius: 8px;
            font-size: 15px;
            box-sizing: border-box;
            transition: 0.3s;
        }

            .form-control:focus {
                border-color: #0d6efd;
                outline: none;
                box-shadow: 0 0 5px rgba(13,110,253,0.3);
            }

        .form-row {
            display: flex;
            gap: 20px;
        }

            .form-row .form-group {
                flex: 1;
            }

        textarea.form-control {
            resize: vertical;
            min-height: 120px;
        }

        .btn-submit {
            background: #0d6efd;
            color: white;
            padding: 15px 30px;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            width: 100%;
            transition: 0.3s;
        }

            .btn-submit:hover {
                background: #0b5ed7;
            }

        /* --- POPUP THÔNG BÁO --- */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.6);
            z-index: 9999;
            align-items: center;
            justify-content: center;
        }

        .modal-box {
            background: white;
            padding: 40px;
            border-radius: 15px;
            width: 400px;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }

        .modal-icon {
            font-size: 60px;
            color: #28a745;
            margin-bottom: 15px;
        }

        .modal-title {
            font-size: 22px;
            font-weight: bold;
            color: #333;
            margin-bottom: 10px;
        }

        .modal-text {
            color: #666;
            margin-bottom: 25px;
            line-height: 1.5;
        }

        .btn-close-modal {
            background: #e9ecef;
            color: #333;
            padding: 10px 25px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: bold;
        }

            .btn-close-modal:hover {
                background: #dde2e6;
            }
    </style>
    <style>

        body {
            margin: 0;
            font-family: Arial;
            background: white;
        }


        /* HEADER */

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: linear-gradient(360deg, #e5e5e5, #f4b400);
            padding: 20px 60px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.1);
            border-bottom-left-radius: 50px;
            border-bottom-right-radius: 50px;
        }

        .logo {
            font-size: 24px;
            font-weight: bold;
            color: white;
            cursor: pointer;
        }

        .logo {
            position: relative; /* Làm gốc tọa độ cho 2 ảnh bên trong */
            width: 80px; /* Khai báo chiều rộng cụ thể */
            height: 80px; /* Khai báo chiều cao (tùy chỉnh theo ảnh của bạn) */
        }

            .logo img {
                position: absolute; /* Chồng 2 ảnh lên nhau */
                top: 0;
                left: 0;
                width: 160px;
                transition: opacity 0.6s ease; /* Thời gian chuyển từ từ (0.6 giây) */
            }

            /* Ảnh 2 mặc định sẽ bị ẩn đi */
            .logo .img-2 {
                opacity: 0;
                z-index: 2; /* Nằm trên ảnh 1 */
            }

            /* Ảnh 1 mặc định hiện ra */
            .logo .img-1 {
                opacity: 1;
                z-index: 1;
            }

            /* Khi rà chuột vào khu vực .logo */
            .logo:hover .img-2 {
                opacity: 1; /* Hiện ảnh 2 lên */
            }

            .logo:hover .img-1 {
                opacity: 0; /* Ẩn ảnh 1 đi */
            }

        .login {
            color: white;
            display: flex;
            align-items: center; /* Căn giữa tất cả theo chiều dọc */
            gap: 15px; /* Tạo khoảng cách đều giữa cụm Avatar và nút Đăng xuất */
        }

            .login button {
                /* Đã bỏ margin-left vì dùng gap ở trên rồi */
                padding: 8px 18px;
                border: none;
                border-radius: 20px;
                background: white;
                color: #4f83cc;
                font-weight: bold;
                cursor: pointer;
                transition: 0.3s; /* Thêm tí mượt mà khi hover */
            }

                .login button:hover {
                    background: #2dafff;
                    color: white; /* Sửa màu chữ khi hover cho đẹp hơn */
                }


        /* HERO */

        .hero {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 80px;
        }


        /* LEFT IMAGE */

        .hero-left img {
            width: 420px;
        }


        /* RIGHT TEXT */

        .hero-right {
            margin-left: 80px;
        }

        .title {
            color: #f4b400;
        }

        .hero-right h1 {
            color: #4f83cc;
            font-size: 36px;
        }


        .start-btn {
            margin-top: 30px;
            padding: 15px 35px;
            border: none;
            border-radius: 10px;
            background: #4786e3;
            color: white;
            font-size: 18px;
            cursor: pointer;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
        }

            .start-btn:hover {
                background: #2dafff;
            }

        a {
            text-decoration: none;
            color: white;
            border-bottom: 5px solid transparent;
        }

        .footer {
            background: #4786e3;
            padding: 50px 0;
            color: white;
        }

        .footer-container {
            width: 80%;
            margin: auto;
            display: flex;
            justify-content: space-between;
        }

        .footer-col {
            width: 30%;
        }

            .footer-col h2,
            .footer-col h3 {
                margin-bottom: 15px;
            }

            .footer-col p {
                margin: 8px 0;
            }

            .footer-col a {
                color: white;
            }

        .gioi_thieu_khoa_hoc {
            width: 70%;
            margin: 40px auto;
            background: #ffffff;
            padding: 30px 35px;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            font-family: Arial, sans-serif;
            line-height: 1.7;
            background: beige;
        }

            .gioi_thieu_khoa_hoc p {
                font-size: 17px;
                color: #333;
                text-align: justify;
            }

                .gioi_thieu_khoa_hoc p::first-line {
                    font-weight: bold;
                    font-size: 20px;
                    color: #2c7be5;
                }

        /* --- PHẦN 1: TÍNH NĂNG (ZIGZAG GIỐNG ẢNH MẪU) --- */
        .gioi_thieu_cac_uu_dai {
            width: 100%;
            background: white;
            padding: 40px 0;
        }

        .feature-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 40px 12%;
            gap: 60px;
        }

            /* Đảo ngược vị trí cho khối thứ 2 */
            .feature-row.reverse {
                flex-direction: row-reverse;
            }

        .feature-content {
            flex: 1;
        }

            /* Ép chữ căn lề phải cho khối 1 giống hệt trong ảnh */
            .feature-content.right-align {
                text-align: right;
            }

            .feature-content.left-align {
                text-align: left;
            }

            .feature-content h2 {
                color: #4786e3; /* Màu xanh giống header của bạn */
                font-size: 26px;
                margin-bottom: 20px;
                line-height: 1.4;
            }

            .feature-content p {
                font-size: 16px;
                color: #333;
                line-height: 1.6;
            }

        .feature-image {
            flex: 1.2; /* Cho ảnh to hơn chữ một tí */
            text-align: center;
        }

            .feature-image img {
                width: 100%;
                max-width: 500px;
                height: auto;
                border-radius: 10px;
                box-shadow: 0 10px 25px rgba(0,0,0,0.1); /* Đổ bóng cho ảnh app nổi lên */
            }


        /* --- PHẦN 2: BÌNH LUẬN CỦA HỌC VIÊN --- */
        .testimonials-section {
            background: #f8f9fa; /* Nền xám rất nhạt để phân biệt với phần 1 */
            padding: 70px 10%;
            text-align: center;
        }

            .testimonials-section h2 {
                color: #4786e3;
                font-size: 30px;
                margin-bottom: 50px;
            }

        .testimonial-grid {
            display: flex;
            gap: 30px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .testimonial-card {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            width: 320px;
            text-align: left;
            position: relative;
        }

            /* Dấu ngoặc kép trang trí */
            .testimonial-card::before {
                content: "❝";
                font-size: 50px;
                color: #e5e5e5;
                position: absolute;
                top: 10px;
                right: 20px;
            }

        .user-info {
            display: flex;
            align-items: center;
            margin-bottom: 15px;
        }

            .user-info img {
                width: 60px;
                height: 60px;
                border-radius: 50%;
                margin-right: 15px;
                object-fit: cover;
            }

        .user-name {
            font-weight: bold;
            color: #333;
            font-size: 16px;
        }

        .user-role {
            font-size: 14px;
            color: #f4b400; /* Màu vàng giống header của bạn */
            font-weight: bold;
        }

        .comment {
            color: #555;
            font-size: 15px;
            font-style: italic;
            line-height: 1.6;
        }

        .user {
            color: white;
            font-weight: bold;
        }

            .user:hover {
                color: #2dafff;
            }
        /* --- CSS CHO THANH PHÂN TRANG (PAGINATION) --- */
        .pagination {
            display: inline-flex;
            padding-left: 0;
            list-style: none;
            justify-content: center;
            margin-top: 20px;
        }

            .pagination li {
                margin: 0 5px;
            }

                .pagination li a, .pagination li span {
                    display: block;
                    padding: 10px 18px;
                    color: #4786e3;
                    text-decoration: none;
                    background-color: #fff;
                    border: 1px solid #ddd;
                    border-radius: 8px;
                    font-weight: bold;
                    font-size: 16px;
                    transition: 0.3s;
                }

                    .pagination li a:hover {
                        background-color: #f8f9fa;
                        color: #0b5ed7;
                        border-color: #4786e3;
                    }

            /* Nút của trang hiện tại đang đứng */
            .pagination .active span {
                background-color: #4786e3;
                color: white;
                border-color: #4786e3;
            }

            /* Nút bị mờ (Ví dụ: Đang ở trang 1 thì nút "Lùi lại" bị mờ) */
            .pagination .disabled span {
                color: #ccc;
                cursor: not-allowed;
                background-color: #f9f9f9;
            }
        /* CSS cho khối Avatar và Tên trên thanh Nav */
        .user-profile-nav {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 5px 10px !important;
            color: white; /* Đảm bảo tên màu trắng */
            text-decoration: none; /* Bỏ gạch chân */
        }

            .user-profile-nav img {
                width: 35px;
                height: 35px;
                border-radius: 50%;
                object-fit: cover;
                border: 2px solid white; /* Thêm viền trắng mỏng cho ảnh nổi bật */
                box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            }

        .user-profile-name {
            font-size: 15px;
        }

        .dk:hover {
            color: #2295d682;
            font-weight: bold;
        }
    </style>
</head>
</head>
<body>

    <header>
        <div class="logo">
            <img src="@Url.Content("~/Img/Gemini_Generated_Image_khrd5ikhrd5ikhrd-removebg-preview.png")"
                 class="img-1" alt="">
            <img src="@Url.Content("~/Img/Gemini_Generated_Image_pj8wj4pj8wj4pj8w-removebg-preview.png")"
                 class="img-2" alt="" onclick="location.href='@Url.Action("Index","Trang_chu")'">
        </div>
        @if (Session["TenDN"] != null)
        {
            <div class="login">
                <a href="@Url.Action("TrangCaNhan", "User")" class="user-profile-nav">
                    <img src="@(Session["Avatar"] == null ? "https://ui-avatars.com/api/?name=" + Session["HoTen"]?.ToString().Replace(" ", "+") + "&background=random" : Url.Content("~/Images/Avatars/" + Session["Avatar"]))" alt="Avatar">

                    <span class="user-profile-name">@Session["HoTen"]</span>
                </a>
                <button onclick="location.href='@Url.Action("DangXuat","User")'">Đăng xuất</button>
            </div>
        }
        else
        {
            <div class="login">
                <p>

                    @if (HttpContext.Current.Application["ChoPhepDangKy"] != null && (bool)HttpContext.Current.Application["ChoPhepDangKy"] == false)
                    {
                        <span style="color: gray; font-style: italic;">(Đăng ký hiện đang đóng)</span>
                    }
                    else
                    {
                        <a href="@Url.Action("dangky","User")" class="dk">Bạn đã có tài khoản?</a>
                    }
                </p>
                <button onclick="location.href='@Url.Action("dangnhap","User")'">Đăng nhập</button>
            </div>
        }

    </header>


    <div class="contact-wrapper">
        <div class="contact-info">
            <div>
                <h2>Thông tin liên hệ</h2>
                <p>Chúng tôi luôn sẵn sàng lắng nghe và hỗ trợ bạn trong suốt quá trình học tập. Đừng ngần ngại liên hệ nhé!</p>
                <ul class="info-list">
                    <li><span>📍</span> Tòa nhà E-Learning, Quận 1, TP.HCM</li>
                    <li><span>📞</span> Hotline: 0123 456 789</li>
                    <li><span>✉️</span> Email: hotro@kitting.edu.vn</li>
                    <li><span>🌐</span> Fanpage: Kitting - Học tiếng Anh</li>
                </ul>
            </div>
            <div class="map-container">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1m3!1d3919.5132741062075!2d106.6990749!3d10.7719448!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31752f40a3b49e59%3A0xa1bd14e483a602db!2sB%E1%BA%BFn%20Th%C3%A0nh%20Market!5e0!3m2!1sen!2s!4v1700000000000!5m2!1sen!2s" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
            </div>
        </div>

        <div class="contact-form">
            <h2>Gửi tin nhắn cho chúng tôi</h2>
            <div class="form-row">
                <div class="form-group">
                    <label>Họ và tên *</label>
                    <input type="text" id="txtHoTen" class="form-control" placeholder="Nhập họ tên của bạn"
                           value="@(Session["HoTen"] != null ? Session["HoTen"] : "")"
                           @(Session["HoTen"] != null ? "readonly style=background-color:#e9ecef;cursor:not-allowed;" : "")>
                </div>
                <div class="form-group">
                    <label>Email liên hệ *</label>
                    <input type="email" id="txtEmail" class="form-control" placeholder="Ví dụ: abc@gmail.com"
                           value="@(Session["Email"] != null ? Session["Email"] : "")"
                           @(Session["Email"] != null ? "readonly style=background-color:#e9ecef;cursor:not-allowed;" : "")>
                </div>
            </div>

            <div class="form-group">
                <label>Chủ đề cần hỗ trợ</label>
                <select id="cbChuDe" class="form-control">
                    <option value="Tư vấn lộ trình học">📚 Tư vấn lộ trình học</option>
                    <option value="Hỗ trợ thanh toán / Lỗi nạp VIP">💳 Hỗ trợ thanh toán / Lỗi nạp VIP</option>
                    <option value="Lỗi kỹ thuật web/app">⚙️ Lỗi kỹ thuật web/app</option>
                    <option value="Đóng góp ý kiến">💡 Đóng góp ý kiến</option>
                    <option value="Khác">Khác</option>
                </select>
            </div>

            <div class="form-group">
                <label>Nội dung chi tiết *</label>
                <textarea id="txtNoiDung" class="form-control" placeholder="Mô tả vấn đề bạn đang gặp phải..."></textarea>
            </div>

            <button class="btn-submit" id="btnGuiTinNhan" onclick="XuLyGuiLienHe()">Gửi Tin Nhắn 🚀</button>
        </div>
    </div>

    <div class="modal-overlay" id="successModal">
        <div class="modal-box">
            <div class="modal-icon">✔</div>
            <div class="modal-title">Gửi thành công!</div>
            <div class="modal-text" id="successMessage">Tin nhắn của bạn đã được tiếp nhận.</div>
            <button class="btn-close-modal" onclick="DongModal()">Đóng</button>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
    function XuLyGuiLienHe() {
        // Lấy dữ liệu (Đã xóa lấy Số điện thoại)
        var hoTen = $("#txtHoTen").val().trim();
        var email = $("#txtEmail").val().trim();
        var chuDe = $("#cbChuDe").val();
        var noiDung = $("#txtNoiDung").val().trim();

        if (hoTen === "" || email === "" || noiDung === "") {
            alert("Vui lòng điền đầy đủ Họ tên, Email và Nội dung tin nhắn!");
            return;
        }

        var btn = $("#btnGuiTinNhan");
        btn.text("Đang gửi...");
        btn.prop("disabled", true);
        btn.css("opacity", "0.7");

        $.ajax({
            url: '@Url.Action("GuiLienHe", "Trang_chu")', // Đảm bảo tên Controller đúng là Trang_chu
            type: 'POST',
            data: {
                ho_ten: hoTen,
                email: email,
                chu_de: chuDe,
                noi_dung: noiDung
            },
            success: function (res) {
                if (res.success) {
                    if ('@(Session["HoTen"])' === '') $("#txtHoTen").val('');
                    $("#txtEmail").val('');
                    $("#txtNoiDung").val('');

                    $("#successMessage").text(res.message);
                    $("#successModal").css("display", "flex");
                } else {
                    alert(res.message);
                }
            },
            error: function () {
                alert("Có lỗi xảy ra khi kết nối máy chủ. Vui lòng thử lại!");
            },
            complete: function () {
                btn.text("Gửi Tin Nhắn 🚀");
                btn.prop("disabled", false);
                btn.css("opacity", "1");
            }
        });
    }

    function DongModal() {
        $("#successModal").css("display", "none");
    }
    </script>
</body>
</html>