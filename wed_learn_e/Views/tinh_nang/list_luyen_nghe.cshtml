@using PagedList.Mvc;
@model PagedList.IPagedList<wed_learn_e.Models.bai_luyen_nghe>

@{
    ViewBag.Title = "Danh Sách Bài Luyện Nghe";
    Layout = "~/Views/Shared/_Layoutcauhoi.cshtml";
}

<link href="~/Content/PagedList.css" rel="stylesheet" type="text/css" />

<style>
    body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: #f4f9ff;
    }

    .list-container {
        max-width: 900px;
        margin: 40px auto;
        padding: 0 20px;
    }

    .page-title {
        text-align: center;
        color: #1a73e8;
        font-size: 32px;
        font-weight: bold;
        margin-bottom: 30px;
    }

    /* CSS THANH TÌM KIẾM */
    .search-box {
        background: white;
        padding: 20px;
        border-radius: 12px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        margin-bottom: 25px;
        display: flex;
        gap: 10px;
    }

    .search-input {
        flex: 1;
        padding: 12px 15px;
        border: 1px solid #ddd;
        border-radius: 8px;
        font-size: 16px;
        outline: none;
        transition: 0.3s;
    }

        .search-input:focus {
            border-color: #1a73e8;
            box-shadow: 0 0 5px rgba(26,115,232,0.3);
        }

    .btn-search {
        background: #1a73e8;
        color: white;
        border: none;
        padding: 0 25px;
        border-radius: 8px;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
        white-space: nowrap;
    }

        .btn-search:hover {
            background: #1557b0;
        }

    /* CSS THẺ BÀI HỌC */
    .lesson-card {
        background: white;
        border-radius: 12px;
        padding: 20px 25px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        margin-bottom: 20px;
        border-left: 6px solid #1a73e8;
        transition: 0.3s;
    }

        .lesson-card:hover {
            transform: translateX(10px);
            box-shadow: 0 6px 15px rgba(0,0,0,0.1);
            border-left-color: #ff9800;
        }

    .lesson-info {
        display: flex;
        align-items: center;
        gap: 20px;
        width: 75%;
    }

    .lesson-icon {
        font-size: 35px;
        background: #eef7ff;
        min-width: 60px;
        height: 60px;
        display: flex;
        justify-content: center;
        align-items: center;
        border-radius: 50%;
    }

    .lesson-details h3 {
        margin: 0 0 5px 0;
        font-size: 20px;
        color: #333;
    }

    .lesson-details p {
        margin: 0;
        color: #777;
        font-size: 14px;
    }

    .btn-play {
        background: #1a73e8;
        color: white;
        padding: 10px 20px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: bold;
        transition: 0.2s;
        white-space: nowrap;
    }

        .btn-play:hover {
            background: #1557b0;
        }

    .empty-msg {
        text-align: center;
        color: #dc3545;
        font-size: 18px;
        background: white;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        font-weight: bold;
    }

    /* CSS RIÊNG CHO BÀI ĐÃ HOÀN THÀNH */
    .lesson-card.completed {
        border-left-color: #28a745;
        background: #f4fff6;
    }

        .lesson-card.completed .lesson-icon {
            background: #d4edda;
            color: #155724;
        }

    .btn-play.btn-success {
        background: #28a745;
    }

    /* CSS PHÂN TRANG */
    .pagination-container {
        text-align: center;
        margin-top: 30px;
    }

    .pagination {
        display: inline-flex;
        padding-left: 0;
        list-style: none;
        border-radius: 0.25rem;
    }
</style>

<div class="list-container">
    @Html.Partial("_NutQuayLai", new ViewDataDictionary {
  // Thêm đoạn new { id = ... } để hệ thống tạo ra link có đuôi /1
  { "LinkQuayVe", Url.Action("thong_tin_khoa_hoc", "Page", new { id = Request.QueryString["id_cap_do"] }) },
 
})
    <div class="page-title">
        🎧 Luyện Nghe: @ViewBag.TenCapDo
    </div>

    @using (Html.BeginForm("list_luyen_nghe", "tinh_nang", FormMethod.Get))
    {
        <div class="search-box">
            <input type="hidden" name="id_cap_do" value="@ViewBag.IdCapDo" />

            <input type="text" name="searchString" value="@ViewBag.CurrentFilter" class="search-input" placeholder="Nhập tên bài luyện nghe bạn muốn tìm kiếm..." />
            <button type="submit" class="btn-search">🔍 Tìm Kiếm</button>
        </div>
    }

    @if (Model == null || Model.Count == 0)
    {
        <div class="empty-msg">
            Hiện tại chưa có bài nghe nào phù hợp với tìm kiếm của bạn. Hãy kiểm tra lại nhé!
        </div>
    }
    else
    {
        var listDaHoanThanh = ViewBag.ListDaHoanThanh as List<int?> ?? new List<int?>();

        // Thuật toán để số thứ tự tiếp nối khi sang trang mới
        int stt = (Model.PageNumber - 1) * Model.PageSize + 1;

        foreach (var item in Model)
        {
            bool daXong = listDaHoanThanh.Contains(item.id_bai_nghe);

            <div class="lesson-card @(daXong ? "completed" : "")">
                <div class="lesson-info">
                    <div class="lesson-icon">@(daXong ? "✔" : "▶️")</div>
                    <div class="lesson-details">
                        <h3>Bài @stt: @item.tieu_de</h3>
                        <p>@item.mo_ta</p>
                    </div>
                </div>

                <a href="@Url.Action("LuyenNghe", "tinh_nang", new { id_bai_nghe = item.id_bai_nghe })"
                   class="btn-play @(daXong ? "btn-success" : "")">
                    @(daXong ? "Nghe lại" : "Vào học")
                </a>
            </div>

            stt++;
        }
    }

    <div class="pagination-container">
        <div style="margin-bottom: 10px; color: #666; font-weight: bold;">
            Trang @(Model.PageCount < Model.PageNumber ? 0 : Model.PageNumber) / @Model.PageCount
        </div>

        @Html.PagedListPager(Model, page => Url.Action("list_luyen_nghe",
            new { page, searchString = ViewBag.CurrentFilter, id_cap_do = ViewBag.IdCapDo }))
    </div>
</div>