@{
    ViewBag.Title = "Thành Ngữ Tiếng Anh";
    Layout = "~/Views/Shared/_Layoutcauhoi.cshtml";
}

<style>

    body {
        background: linear-gradient(135deg, #eaf8ff, #a6e1ff);
        font-family: Arial;
        margin: 0;
    }

    /* HEADER */
    .page-header {
        text-align: center;
   
        color: #333;
    }

        .page-header h1 {
            font-size: 30px;
            margin-bottom: 8px;
        }

        .page-header p {
            font-size: 14px;
            color: #666;
        }

    /* SEARCH */
    #searchBox {
        display: block;
        margin: 0 auto 30px auto;
        padding: 10px 18px;
        width: 480px;
        border-radius: 25px;
        border: 1px solid black;
        outline: none;
        background: white;
    }

    /* GRID */
    .idiom-container {
        width: 90%;
        margin: auto;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
    }

    .idiom-card {
        background: linear-gradient(135deg, #ffffff, #d9f1ff);
        border-radius: 12px;
        padding: 20px;
        text-align: center;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        transition: 0.3s;
        cursor: pointer;
        height: 160px;
        perspective: 1000px;
        border: 1px solid #d0eaff;
        position: relative;
    }

        .idiom-card:hover {
            transform: translateY(-6px) scale(1.02);
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }

    .inner {
        width: 100%;
        height: 100%;
        position: relative;
        transform-style: preserve-3d;
        transition: transform 0.5s;
    }

    .idiom-card.flip .inner {
        transform: rotateY(180deg);
    }

    /* BOX */
    .front, .back {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        border-radius: 12px;
        padding: 15px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        background: #eaf6ff;
        border: 1px solid #e0e0e0;
        box-shadow: 0 4px 10px rgba(0,0,0,0.08); /* 👉 nổi nhẹ */
        box-sizing: border-box;
        backface-visibility: hidden;
        -webkit-backface-visibility: hidden;
    }

    .back {
        transform: rotateY(180deg);
    }

    /* TEXT */
    .idiom {
        font-size: 16px;
        font-weight: bold;
        color: #333;
    }

    .meaning {
        margin-top: 6px;
        font-size: 14px;
        color: #666;
    }

    .example {
        margin-top: 6px;
        font-size: 13px;
        color: #777;
        font-style: italic;
    }

    /* MASCOT */
    .cat-mascot {
        position: fixed;
        bottom: 15px;
        right: 15px;
    }

    .cat-text {
        position: absolute;
        bottom: 60px;
        right: 0;
        background: white;
        padding: 6px 10px;
        border-radius: 10px;
        font-size: 12px;
        border: 1px solid #ddd;
    }
</style>

<div class="page-header">

    @Html.Partial("_NutQuayLai", new ViewDataDictionary {
   // Thêm đoạn new { id = ... } để hệ thống tạo ra link có đuôi /1
   { "LinkQuayVe", Url.Action("thong_tin_khoa_hoc", "Page", new { id = Request.QueryString["id_cap_do"] }) },
   { "TieuDe", "Thành Ngữ Tiếng Anh "  }
 })

    <p>
        Khám phá các thành ngữ phổ biến trong tiếng Anh và cách sử dụng chúng trong giao tiếp hàng ngày.
