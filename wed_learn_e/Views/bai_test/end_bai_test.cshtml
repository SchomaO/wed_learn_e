@{
    ViewBag.Title = "end_bai_test";
    Layout = "~/Views/Shared/_Layoutcauhoi.cshtml";

    var done = ViewBag.Done as List<int> ?? new List<int>();
    var notdone = ViewBag.NotDone as List<int> ?? new List<int>();
}

<style>
    body {
        background: white;
    }

    .submit-box {
        width: 500px;
        margin: auto;
        margin-top: 120px;
        background: white;
        padding: 30px;
        border-radius: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        text-align: center;
    }

        .submit-box h2 {
            color: #2b4a5a;
            margin-bottom: 25px;
        }

    .done-title,
    .notdone-title {
        font-weight: bold;
        margin: 15px 0;
        color: #3a5f73;
    }

    .done-list {
        display: grid;
        grid-template-columns: repeat(5,1fr);
        gap: 10px;
        margin-bottom: 20px;
    }

    .q {
        background: #eef8ff;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .q.done {
            background: #6ec8ff;
            color: white;
        }

    .done-list a {
        text-decoration: none;
    }

    .submit-btns {
        margin-top: 25px;
        display: flex;
        justify-content: space-between;
    }

    .back-btn {
        text-decoration: none;
        background: #cfefff;
        padding: 10px 18px;
        border-radius: 10px;
        color: #1b4d63;
        font-weight: bold;
    }

    .submit-btn {
        background: #6ec8ff;
        padding: 10px 25px;
        border-radius: 10px;
        font-weight: bold;
        color: white;
        text-decoration: none;
    }

        .submit-btn:hover {
            background: #48b9ff;
        }

    .warning {
        color: red;
        font-weight: bold;
        margin-bottom: 10px;
    }
</style>

<div class="submit-box">

    <h2>Kiểm tra bài làm</h2>

    <!-- ⚠️ cảnh báo -->
    @if (notdone.Count > 0)
    {
        <div class="warning">
            Bạn còn @notdone.Count câu chưa làm!
        </div>
    }

    <!-- ✅ Đã làm -->
    <div class="done-title">Câu đã trả lời</div>

    <div class="done-list">
        @foreach (var i in done)
        {
            <a href="@Url.Action("bai_test","bai_test", new { index = i })">
                <div class="q done">@(i + 1)</div>
            </a>
        }
    </div>

    <!-- ❌ Chưa làm -->
    <div class="notdone-title">Câu chưa trả lời</div>

    <div class="done-list">
        @foreach (var i in notdone)
        {
            <a href="@Url.Action("bai_test","bai_test", new { index = i })">
                <div class="q">@(i + 1)</div> 
            </a>
        }
    </div>

    <!-- nút -->
    <div class="submit-btns">

        <a href="@Url.Action("bai_test","bai_test")" class="back-btn">
            ← Quay lại làm bài
        </a>

        <a href="@Url.Action("kq_bai_test","bai_test")" class="submit-btn">
            Nộp bài
        </a>

    </div>

</div>