@{
    ViewBag.Title = "Quên mật khẩu";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

<style>
    /* Hộp thông báo kết quả */
    #thongBaoAJAX {
        display: none;
        padding: 12px;
        margin-bottom: 15px;
        border-radius: 5px;
        font-weight: bold;
        text-align: center;
        font-size: 14px;
    }

    .alert-success {
        background-color: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }

    .alert-error {
        background-color: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
    }

    .btn-forgot {
        width: 100%;
        padding: 12px;
        background-color: #f39c12;
        color: white;
        border: none;
        border-radius: 4px;
        font-weight: bold;
        font-size: 15px;
        cursor: pointer;
        transition: 0.3s;
    }

        .btn-forgot:hover {
            background-color: #e67e22;
        }

        .btn-forgot:disabled {
            background-color: #95a5a6;
            cursor: not-allowed;
        }
</style>

<div class="title">
    <button class="close-btn" onclick="location.href='@Url.Action("dangnhap","User")'">
        <span>&times;</span>
    </button>
    <h2>Quên mật khẩu</h2>
</div>

<div class="content" style="max-width: 450px; margin: 0 auto; padding-bottom: 30px;">
    <h2 style="margin-bottom: 10px;">Khôi phục tài khoản</h2>
    <p style="color: #666; font-size: 14px; text-align: center; margin-bottom: 20px; line-height: 1.5;">
        Vui lòng nhập địa chỉ email bạn đã dùng để đăng ký. Hệ thống sẽ cấp lại mật khẩu mặc định và gửi vào hòm thư của bạn.
    </p>

    <div id="thongBaoAJAX"></div>

    <form id="forgotForm">
        <div style="margin-bottom: 20px;">
            <input type="email" id="emailKhoiPhuc" placeholder="Nhập địa chỉ email của bạn..." required
                   style="width: 100%; padding: 12px; border: 1px solid #ccc; border-radius: 4px; font-size: 15px; box-sizing: border-box;">
        </div>

        <button type="submit" id="btnXacNhan" class="btn-forgot">Gửi mật khẩu mới</button>
    </form>

    <p style="text-align: center; margin-top: 20px;">
        Nhớ ra mật khẩu rồi?
        <a href="@Url.Action("dangnhap", "User")" style="color: #3498db; font-weight: bold; text-decoration: none;">Đăng nhập ngay</a>
    </p>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            $("#forgotForm").submit(function (e) {
                e.preventDefault(); // Chặn load lại trang

                var email = $("#emailKhoiPhuc").val();
                var btn = $("#btnXacNhan");
                var thongBao = $("#thongBaoAJAX");

                if (!email) {
                    thongBao.removeClass("alert-success").addClass("alert-error").text("❌ Vui lòng nhập địa chỉ email!").fadeIn();
                    return;
                }

                // Hiển thị trạng thái đang gửi
                btn.prop("disabled", true).text("Đang xử lý & gửi mail...");
                thongBao.hide().removeClass("alert-success alert-error");

                // Gửi AJAX xuống Controller
                $.ajax({
                    type: "POST",
                    url: '@Url.Action("QuenMatKhau", "User")', // Tự động gọi vào [HttpPost] QuenMatKhau
                    data: { email: email },
                    dataType: "json",
                    success: function (res) {
                        if (res.success) {
                            thongBao.addClass("alert-success").text(res.message).fadeIn();
                            $("#emailKhoiPhuc").val(''); // Xóa trắng ô email khi gửi thành công
                        } else {
                            thongBao.addClass("alert-error").text(res.message).fadeIn();
                        }
                        // Nhả nút ra
                        btn.prop("disabled", false).text("Gửi mật khẩu mới");
                    },
                    error: function () {
                        thongBao.addClass("alert-error").text("❌ Lỗi kết nối đến máy chủ! Vui lòng thử lại sau.").fadeIn();
                        btn.prop("disabled", false).text("Gửi mật khẩu mới");
                    }
                });
            });
        });
    </script>
}