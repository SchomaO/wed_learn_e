@model wed_learn_e.Models.nguoi_dung
@{
    ViewBag.Title = "Đăng ký tài khoản";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

@section Scripts{
    @Scripts.Render("~/bundles/jqueryval")
}

<style>
    /* Chữ báo lỗi đỏ bên dưới mỗi ô nhập liệu */
    .field-validation-error {
        color: red;
        font-size: 13px;
        font-style: italic;
    }

    /* Thông báo lỗi tổng quát từ Server (ViewBag.error) */
    .alert-danger {
        color: white;
        background-color: #e74c3c;
        padding: 10px;
        margin-bottom: 15px;
        border-radius: 4px;
        list-style-type: none;
    }
</style>

<div class="title">
    <button class="close-btn" onclick="location.href='@Url.Action("Index","User")'">
        <span>&times;</span>
    </button>
    <h2>Đăng ký</h2>
</div>

<div class="content">
    <h2>Tạo tài khoản mới</h2>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        @* 1. Hiển thị thông báo lỗi nếu trùng tên đăng nhập từ Controller *@
        if (ViewBag.error != null)
        {
            <div class="alert-danger">
                @ViewBag.error
            </div>
        }

        <table>
            <tr>
                <td>Họ tên:</td>
                <td>
                    @Html.TextBoxFor(m => m.ho_va_ten, new { @placeholder = "Nhập họ và tên..." })<br>
                    @Html.ValidationMessageFor(m => m.ho_va_ten)
                </td>
            </tr>

            <tr>
                <td>Tên đăng nhập:</td>
                <td>
                    @Html.TextBoxFor(m => m.ten_dang_nhap, new { @placeholder = "Tên đăng nhập..." })<br>
                    @Html.ValidationMessageFor(m => m.ten_dang_nhap)
                </td>
            </tr>

            <tr>
                <td>Mật khẩu:</td>
                <td>
                    @Html.PasswordFor(m => m.mat_khau, new { @placeholder = "Mật khẩu..." })<br>
                    @Html.ValidationMessageFor(m => m.mat_khau)
                </td>
            </tr>

            <tr>
                <td>Nhập lại mật khẩu:</td>
                <td>
                    @Html.PasswordFor(m => m.MatKhauNL, new { @placeholder = "Nhập lại mật khẩu..." })<br>
                    @Html.ValidationMessageFor(m => m.MatKhauNL)
                </td>
            </tr>

            <tr>
                <td>Email:</td>
                <td>
                    @Html.TextBoxFor(m => m.email, new { @placeholder = "Địa chỉ email...", @type = "email" })<br>
                    @Html.ValidationMessageFor(m => m.email)
                </td>
            </tr>
        </table>

        <button type="submit" class="btn-submit">Đăng ký ngay</button>
    }
</div>
